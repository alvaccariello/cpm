{
    "@graph": [
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc50_NO",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP33"
            },
            "skos:notation": "pc50_NO",
            "rdfs:label": {
                "@language": "en",
                "@value": "illustrates"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of CP33 Conservation Project with an instance of CP 34 Architecture Depiction. The property intends to describe the specificity of the conservation project that is conceived as a result of the gathering of several analysis that are normally represented through different architectural depictions."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP34"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP33",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E29_Design_or_Procedure"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Architecture Conservation Project"
            },
            "rdfs:comment": " This class comprises documented plans for the executions of actions in order to achieve the preservation and compatible use or fruition of historic architectures, archaeological sites, hight-value modern buildings. These plans are depicted by drawings, protocols, and check list and they may result in new instances of CP38 Architecture Representation Object. They are used for shaping or guiding the execution of an instance of CP25 Conservation Intervention though the property Pc33 foresees (is foreseen by).  The existence of an instance of CP33 Architecture Conservation Project normally implies the intention of any actor to realize it, because it derives from the necessity to hinder any kind of conservation problems. CP33 Architecture Conservation Project is an architectural project dedicated to an existing building that is recognised as being of particular interest and value. For this reason, the role assumed by the study of the pre-existence takes on a particular importance, since the design choices of both conservative and creative nature are based on it. In fact, the main objective of the project is to preserve the material, historical and figurative values of the historic building, without sacrificing the building's formal and functional effectiveness.CP33 Architecture Conservation Project differs from ActE2 Activity Plan because of its specific nature that requires special technical tools also prescribed by law which must give information about the final state of the building and the specific techniques of intervention. An instance of an ActE2 Activity Plan, on the other hand, consists of a site implementation plan or a site safety plan, which regulate how the various restoration activities are to be conducted on site, also taking into account workers' clothing, as well as working times and methods.  ",
            "skos:notation": "CP33",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP34",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E31_Document"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Architecture Depiction"
            },
            "rdfs:comment": "This class allows the study of architecture to be documented through a description in words, orthophotos, drawings, digital models retrieved from an architectural survey.  It represents the knowledge expressed through a physical document (E22 Human made object) such as a drawing or a report.",
            "skos:notation": "CP34",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/Pc24",
            "rdfs:subPropertyOf": [
                {
                    "@id": "http://www.cidoc-crm.org/cidoc-crm/P108_has_produced"
                },
                {
                    "@id": "http://www.cidoc-crm.org/cidoc-crm/P31_has_modified"
                }
            ],
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP25"
            },
            "skos:notation": "Pc24",
            "rdfs:label": {
                "@language": "en",
                "@value": "occurred in"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property identifies the result (CP1 Bult Entity) of an instance CP25 Conservation Intervention. This property enables the documentation of the outcome of a conservation intervention. Conservation intervention realized in a building may also entail the modification of some features such as its internal distribution, the shape of some of its components (windows, roof etc.), its function, without modifying its identity and with the aim of preserving it for the future."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "http://www.cidoc-crm.org/cidoc-crm/P108_has_produced",
            "rdfs:domain": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E12_Production"
            },
            "skos:notation": "P108",
            "rdfs:label": {
                "@language": "en",
                "@value": "has produced"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property identifies the instance of E24 Physical Human-Made Thing that came into existence as a result of the instance of E12 Production.The identity of an instance of E24 Physical Human-Made Thing is not defined by its matter, but by its existence as a subject of documentation. An E12 Production can result in the creation of multiple instances of E24 Physical Human-Made Thing."
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "http://www.cidoc-crm.org/cidoc-crm/P31_has_modified",
            "rdfs:domain": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E11_Modification"
            },
            "skos:notation": "P31",
            "rdfs:label": {
                "@language": "en",
                "@value": "has modified"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property identifies the instance of E18 Physical Thing modified in an instance of E11 Modification."
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E18_Physical_Thing"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP25",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E7_Activity"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Conservation Intervention"
            },
            "rdfs:comment": "This class comprises instances of E7 Activity produced to preserve historic architectures following the prescriptions of a CP24Conservation Project Activity documented in CP33 Conservation Project.  as restoration project, protocols for planned conservation, maintenance plans, diagnostic plan.   ",
            "skos:notation": "CP25",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP1",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Built Entity"
            },
            "rdfs:comment": "This class comprises instances of man-made things such as freestanding buildings, construction units, construction components, construction elements, and complexes of buildings. It refers to man-made environments serving a practical purpose, being relatively permanent and stable. Instances of CP1 Built Entity consist of parts that perform a specific constructive or architectural function. Natural components, such as caves or rocky outcrops, even unworked ones, that are constructively and/or functionally integrated with existing architecture are also instances of CP1 Built Entity.",
            "skos:notation": "CP1",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/Pc23",
            "rdfs:domain": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E11_Modification"
            },
            "skos:notation": "Pc23",
            "rdfs:label": {
                "@language": "en",
                "@value": "made use of"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property identifies an instance of CP9 Building material used by an instance of E11 Modification. E11 Modification commonly foresees the use of particular instances of S10 Material substantial. The modification realized to consolidate lime mortars, for example, requires ethyl silicate. This property enables this to be documented."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP9"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "http://www.cidoc-crm.org/cidoc-crm/E11_Modification",
            "rdfs:label": {
                "@language": "en",
                "@value": "Modification"
            },
            "rdfs:comment": "This class comprises instances of E7 Activity that are undertaken to create, alter or change instances of E24 Physical Human-Made Thing.This class includes the production of an item from raw materials and other so far undocumented objects. It also includes the conservation treatment of an object.Since the distinction between modification and production is not always clear, modification is regarded as the more generally applicable concept. This implies that some items may be consumed or destroyed in an instance of E11 Modification, and that others may be produced as a result of it. An event should also be documented using an instance of E81 Transformation if it results in the destruction of one or more objects and the simultaneous production of others using parts or material from the originals. In this case, the new items have separate identities.An activity undertaken on an object which was designed to alter it, but which, in fact, it did not in any seemingly significant way (such as the application of a solvent during conservation which failed to dissolve any part of the object), is still considered as an instance of E11 Modification. Typically, any such activity will leave at least forensic traces of evidence on the object.If the instance of E29 Design or Procedure utilized for the modification prescribes the use of specific materials, they should be documented using property P68 foresees use of (use foreseen by): E57 Material of E29 Design or Procedure, rather than via P126 employed (was employed in): E57 Material.",
            "skos:notation": "E11",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP9",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Building Material"
            },
            "rdfs:comment": "This class includes instances of structural products, manufactured as standard units, intended for use in building construction (AAT).",
            "skos:notation": "CP9",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/Pc22",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP2"
            },
            "skos:notation": "Pc22",
            "rdfs:label": {
                "@language": "en",
                "@value": "shows building formal type"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property documents that an instance CP2 Architectural Work shows a particular typology. This may be further specified whether the information concerns its distribution or its structural system (eg. continuous, punctual)."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP35"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP2",
            "rdfs:subClassOf": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Architecture work"
            },
            "rdfs:comment": "This class comprises instances of Physical Human-Made Thing such as freestanding buildings and complexes of buildings, created for hosting or supporting every kind of human activities. Other instances can be urban or rural constructions realised to protect humans or to host different functions also with a symbolic meaning, as for triumphal arches and for funeral chapels. In addition, instances can be terminals of infrastructures, such as monumental fountains, as well as rooms created by excavating and modelling a rock for residential or religious purposes. CP2 Architectural Work may also comprise components of buildings when they maintain a recognisable formal identity, such as for a renaissance chapel built in a medieval basilica or a façade of a building, with its proper formal, constructive and material features. It refers to man-made environments, built for human needs, either practical, aesthetic or symbolic, being relatively permanent and stable and with a size and scale appropriate for - but not limited to - habitable buildings.",
            "skos:notation": "CP2",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP35",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E55_Type"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Building-Formal Type"
            },
            "rdfs:comment": "This class includes types that collect formal or constructive characteristics shared by structures, units, components, and elements of architecture. Instances of CP37 Building-formal Type may concern the figurative organization of facades (e.g., facades with overlapping orders, with giant order, with regular windows) or the construction characteristics of masonry (e.g., regular row wall in squared ashlars; wall in irregular drafts; listed work; reticulated work). Each aspect of architecture that lends itself to being identified according to defined design or construction rules can be instantiated using CP37 Building-formal Type, according to its own typology of reference.",
            "skos:notation": "CP35",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/Pc21",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP49"
            },
            "skos:notation": "Pc21",
            "rdfs:label": {
                "@language": "en",
                "@value": "addressed"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property documents that an instance CP 49 Urban Plan Addressed an instance of CP45 Architecture project. It intends to describe the relation that exists between an urban plan and an architecture project that is normally subdued to the former and conceived within the framework that the urban plan describes."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP45"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP49",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E29_Design_or_Procedure"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Urban Plan"
            },
            "rdfs:comment": "This class includes urban planning instruments aimed at planning the activities to be carried out on cities; these instruments design and regulate uses of space focused on the physical form, economic functions, and social impacts of the urban environment. Instances of CP49 Urban Plan are urban instruments that identify the architectural, functional and constructive characteristics of existing buildings and sites and envisage the operations to be carried out in terms of the provision of services and infrastructure, new construction, transformation of existing buildings They can also contain restrictive constraints on the actions to be taken on the existing building. These plans are depicted by drawings, reports, check list, and forms address new instances of CP5 Architecture Project. Instances of CP49 Urban Plan can also be related to plans that modify already existing plans",
            "skos:notation": "CP49",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP45",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E29_Design_or_Procedure"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Architecture Project"
            },
            "rdfs:comment": "This class comprises documented plans for the executions of actions to realise new architectures (in the present or in the past) or to radically transform existing buildings. These plans are depicted by drawings, reports, check list, bill of quantities, etc., and they may result in new instances of CP1 Built Entity or for shaping or guiding the execution of an instance of E7 Activity.Instances of CP45 Architectural Project can be related to the different kinds of the project of an architecture (concept plan, final project, executive project, execution variant, etc.). Architectural project can be also constituted by models, sketches, analytic description, in short, any kind of indication that may have been worked out for the purpose of on-site implementation of the building.",
            "skos:notation": "CP45",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/Pc20",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP2"
            },
            "skos:notation": "Pc20",
            "rdfs:label": {
                "@language": "en",
                "@value": "shows building homogeneity with"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property documents that an instance CP2 Architectural work shows building homogeneity with another instance of CP2 Architectural work."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP2"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/Pc19",
            "rdfs:subPropertyOf": {
                "@id": "https://w3id.org/cpm-arch/cpm/Pc4"
            },
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP5"
            },
            "skos:notation": "Pc19",
            "rdfs:label": {
                "@language": "en",
                "@value": "shows masonry feature"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property documents that an instance CP5 Constructive Element Plural Shows masonry features specified by an instance of CP28 Building features."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP28"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/Pc4",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "skos:notation": "Pc4",
            "rdfs:label": {
                "@language": "en",
                "@value": "shows building feature"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property documents that an instance of CP1 Built entity Shows building features specified by an instance of CP28 Building Features"
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP28"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP5",
            "rdfs:subClassOf": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP20"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Construction Element Plural"
            },
            "rdfs:comment": "This class includes instances of the constructive component characterised by a technical specificity. Such instances may consist of masonry faces, roofing systems covering the trusses in a wooden roof, coffering ceiling, the window frames, the plaster cladding a wall.",
            "skos:notation": "CP5",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP28",
            "rdfs:subClassOf": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP27"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Building Feature"
            },
            "rdfs:comment": "This class comprises instances of CP2 Architectural Work related to the constitution of the building by a certain condition over a timespan. Among them, we have instances related to the masonry quality under different points of view, concerning the building characteristics, structural capacity, resistance to decay etc. Instances of CP28 Building Feature are also other characteristic, such as the presence and the nature of transverse connections, vertical inhomogeneities, connections between orthogonal walls and so on.",
            "skos:notation": "CP28",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/Pc18",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "skos:notation": "Pc18",
            "rdfs:label": {
                "@language": "en",
                "@value": "has physical relation with"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of CP1 Built Entity with another instance of CP1 Built Entity documenting the physical relation existing between them. This property allows to describe the constructive layering shown by a building or a part of it. It is generally completed by a property type which specifies the kind of relation. If, for example, a wall has a physical relation with another wall beeing built on it or filling one of its windows."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/Pc17",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP2"
            },
            "skos:notation": "Pc17",
            "rdfs:label": {
                "@language": "en",
                "@value": "has performance efficiency documented in"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of CP2 Architecture work with an E73 Information Object documenting specifically performance efficiency. This can be required in several different domains as accessibility, sustainability, or plants efficiency."
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E73_Information_Object"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "http://www.cidoc-crm.org/cidoc-crm/E73_Information_Object",
            "rdfs:label": {
                "@language": "en",
                "@value": "Information Object"
            },
            "rdfs:comment": "This class comprises identifiable immaterial items, such as poems, jokes, data sets, images, texts, multimedia objects, procedural prescriptions, computer program code, algorithm or mathematical formulae, that have an objectively recognizable structure and are documented as single units. The encoding structure known as a \"named graph\" also falls under this class, so that each \"named graph\" is an instance of E73 Information Object.An instance of E73 Information Object does not depend on a specific physical carrier, which can include human memory, and it can exist on one or more carriers simultaneously.Instances of E73 Information Object of a linguistic nature should be declared as instances of the E33 Linguistic Object subclass. Instances of E73 Information Object of a documentary nature should be declared as instances of the E31 Document subclass. Conceptual items such as types and classes are not instances of E73 Information Object, nor are ideas without a reproducible expression.",
            "skos:notation": "E73",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/Pc16",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "skos:notation": "Pc16",
            "rdfs:label": {
                "@language": "en",
                "@value": "shows structural system"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of CP35 Building Formal Type with an instance of CP1 Built Entity. It allows to describe the structural system of a building relating it to a thesaurus that gathers both formal, constructive and structural features."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP35"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/Pc15",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP10"
            },
            "skos:notation": "Pc15",
            "rdfs:label": {
                "@language": "en",
                "@value": "shows plan configuration type"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property documents that an instance of CP2 Architectural work shows plan configuration type expressed by an instance of the class E55 Type."
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E55_Type"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP10",
            "rdfs:subClassOf": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP2"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Building Unit"
            },
            "rdfs:comment": "This class includes instances of coherent architectural organisms populating an urban historical setting. It consists in a single construction phase or by the merging/recasting of several pre-existing building units. This kind of organism is characterized by the presence of one or more functional units (residential and non-residential) connected to each other through common distribution elements and served by access at the road level; it is bordered by external facades with a generally continuous eaves line and a unitary or composite roof composed of flat and/or inclined parts consistent with all fronts (Acierno, Fiorani, Velios 2021). Instances of CP10 Building Unit differ from instances of CP2 Architectural Work for being related to an edifice that is considered a component of an urban historical setting. Meaning that instances of CP10 Building Unit are buildings which are components of an urban tissue, where the main characteristics are the relationships established among them.",
            "skos:notation": "CP10",
            "@type": "rdfs:Class"
        },
        {
            "@id": "http://www.cidoc-crm.org/cidoc-crm/E55_Type",
            "rdfs:label": {
                "@language": "en",
                "@value": "Type"
            },
            "rdfs:comment": "This class comprises concepts denoted by terms from thesauri and controlled vocabularies used to characterize and classify instances of CIDOC CRM classes. Instances of E55 Type represent concepts in contrast to instances of E41 Appellation which are used to name instances of CIDOC CRM classes. E55 Type is the CIDOC CRM’s interface to domain specific ontologies and thesauri. These can be represented in the CIDOC CRM as subclasses of E55 Type, forming hierarchies of terms, i.e., instances of E55 Type linked via P127 has broader term (has narrower term): E55 Type. Such hierarchies may be extended with additional properties. ",
            "skos:notation": "E55",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/Pc14",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP19"
            },
            "skos:notation": "Pc14",
            "rdfs:label": {
                "@language": "en",
                "@value": "is regulated by"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property documents that an instance of Cp18 Space entity is protected from the legislative point of view by an instance of E32 Authority document, in the sense that every action performed on the instance considered must follow the prescriptions expressed in the document. The authority document may be a monumental constraint, an urban planning tool etc. "
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E32_Authority_Document"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP19",
            "rdfs:subClassOf": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP18"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Historic Centre"
            },
            "rdfs:comment": "This class includes instances of urban agglomeration composed by the historical buildings and the open spaces which formerly constituted the town during all the time of its existence. These instances represent 4D ensembles and refer to the set that collects the constructed buildings and the empty spaces between them. These instances are mutable over time, meaning that the shape and extent of the CP19 Historic Centre can be changed over time and become precisely defined with the intersection of E53 Place and E52 Time-Span instances.",
            "skos:notation": "CP19",
            "@type": "rdfs:Class"
        },
        {
            "@id": "http://www.cidoc-crm.org/cidoc-crm/E32_Authority_Document",
            "rdfs:label": {
                "@language": "en",
                "@value": "Authority Document"
            },
            "rdfs:comment": "This class comprises encyclopaedia, thesauri, authority lists and other documents that define terminology or conceptual systems for consistent use.",
            "skos:notation": "E32",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/Pc13",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP2"
            },
            "skos:notation": "Pc13",
            "rdfs:label": {
                "@language": "en",
                "@value": "is regulated by"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property documents that an instance of CP2 Architectural Work is regulated from the legislative point of view by an instance of E32 Authority document, in the sense that every action performed on the object must follow the prescriptions expressed in the document. The authority document may be a monumental constraint, an urban planning tool etc. "
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E32_Authority_Document"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/Pc12",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP10"
            },
            "skos:notation": "Pc12",
            "rdfs:label": {
                "@language": "en",
                "@value": "is related to public area through"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property documents that an instance of CP10 Building Unit is related to public area through (Pc 12) an instance of CP11 Building Front. The property allows to describe the relation between a building unit and its façade. The property aims at describing both the constructive relation between the building and its façade and the nature of the façade that acts as a threshold between private and public space."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP11"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP11",
            "rdfs:subClassOf": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP2"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Building Front"
            },
            "rdfs:comment": "This class includes instances corresponding to the façades of single building unit overlooking on an urban space or, more generally, on a street or a square but also on the natural margin of the town (maritime, river, lake coast, promontory limit, etc.) (Acierno, Fiorani, Velios 2021)",
            "skos:notation": "CP11",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/Pc11",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP16"
            },
            "skos:notation": "Pc11",
            "rdfs:label": {
                "@language": "en",
                "@value": "is bounded by"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property documents that an instance of CP 16 Urban Area is bounded by (Pc11) an instance of CP 14 Urban Unit Front. The property intends to describe the boundaries of an urban area in the cases in which they are constituted by the façades of the buildings. Particularly the property intends to describe not only the geometrical perimeter but the elevations that characterize the area."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP14"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP16",
            "rdfs:subClassOf": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP15"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Urban Area"
            },
            "rdfs:comment": "This class includes instances relating to the hollows of historic urban settlements, bounded by the fronts related to the urban units facing them and containing pavements, furniture, and possibly public green elements. These instances constitute a unified whole from a perceptual and functional point of view and very often represent particularly connotative elements of historic centers.",
            "skos:notation": "CP16",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP14",
            "rdfs:subClassOf": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP2"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Urban Unit Front"
            },
            "rdfs:comment": "This class includes instances corresponding to the set of facades on the same urban space – street or square – of the individual building units composing an urban unit. ",
            "skos:notation": "CP14",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/Pc10",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP2"
            },
            "skos:notation": "Pc10",
            "rdfs:label": {
                "@language": "en",
                "@value": "belongs to"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property documents that an instance of CP2 Architectural Work belongs to an instance of   E39 Actor."
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E39_Actor"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "http://www.cidoc-crm.org/cidoc-crm/E39_Actor",
            "rdfs:label": {
                "@language": "en",
                "@value": "Actor"
            },
            "rdfs:comment": "This class comprises people, either individually or in groups, who have the potential to perform intentional actions of kinds for which someone may be held responsible. ",
            "skos:notation": "E39",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/Pc9",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP18"
            },
            "skos:notation": "Pc9",
            "rdfs:label": {
                "@language": "en",
                "@value": "belongs to"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property documents that an instance CP18 Space Entity belongs to an instance of  E39 Actor."
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E39_Actor"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP18",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E92_Spacetime_Volume"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Space Entity"
            },
            "rdfs:comment": "This class includes instances defined by sets of CP2 Architectural Work together with spaces related to architectural organisms, urban ensembles, or man-made landscapes. These instances represent 4D ensembles and can refer to the set that collects the constructed buildings and the empty spaces between them or to just the footprint of the empty spaces bounded by an urban physical perimeter or an architectural envelope. In either case, these instances are mutable over time, meaning that the shape and extent of the CP20 Spatial Entity can be changed over time and become precisely defined with the intersection of E53 Place and E52 Time-Span instances.",
            "skos:notation": "CP18",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/Pc8",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "skos:notation": "Pc8",
            "rdfs:label": {
                "@language": "en",
                "@value": "is connected to"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property documents that an instance of CP1 Built entity is connected to another instance of CP1 Built entityThis circumstance is mainly referred to historical centres’ fabric."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/Pc7",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "skos:notation": "Pc7",
            "rdfs:label": {
                "@language": "en",
                "@value": "is connected through"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property documents that an instance of CP1 Built entity is connected through an instance of CP1 Built entity to another built element. This circumstance is mainly referred to historical centres’ fabric."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/Pc6",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP42"
            },
            "skos:notation": "Pc6",
            "rdfs:label": {
                "@language": "en",
                "@value": "was fostered by"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property documents that an instance of CP42 Material Decay was made possible by a specific E3 Condition State. It refers to the need to describe, beyond the causes of a particular state of degradation due to specific factors such as dampness as an example, the environmental agents such as climate or exposition that are described through the class condition state."
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E3_Condition_State"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP42",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E5_Event"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Material Decay"
            },
            "rdfs:comment": "This class comprises natural events or man-made processes that create, alter or change physical things, with special reference to building material, by affecting permanently their form or consistency without changing their identity. These phenomena are generally pathological in nature per se or potentially and affect the physical features of a B1 Built Entity or, more generally, of a E18 Physical Thing. Instances of CP42 Material Decay are specifically referred to the phenomenon of material deterioration as defined in the Italian UNI 11182/2006 or in the Illustrated Glossary on Stone Deterioration Patterns from Icomos and ISCS. They collect the effect of addition to the material (surface deposit, efflorescence, crust, biological coating), but also the situations derived from the loss of material (disintegration, detachment, exfoliation, lacuna) or, simply, the change of some original characteristic of the material, such as the color appearance or the formation of stains, due to deterioration mechanisms.",
            "skos:notation": "CP42",
            "@type": "rdfs:Class"
        },
        {
            "@id": "http://www.cidoc-crm.org/cidoc-crm/E3_Condition_State",
            "rdfs:label": {
                "@language": "en",
                "@value": "Condition State"
            },
            "rdfs:comment": "This class comprises the states of objects characterised by a certain condition over a time-span. An instance of this class describes the prevailing physical condition of any material object or feature during a specific instance of E52 Time-Span. In general, the time-span for which a certain condition can be asserted may be shorter than the real time-span, for which this condition held.The nature of that condition can be described using P2 has type. For example, the instance of E3 Condition State “condition of the SS Great Britain between 22nd September 1846 and 27th August 1847” can be characterized as an instance “wrecked” of E55 Type. ",
            "skos:notation": "E3",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/Pc5",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP19"
            },
            "skos:notation": "Pc5",
            "rdfs:label": {
                "@language": "en",
                "@value": "is inhabited by"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property documents that an instance of CP19 Historic Centre is related with an instance of E74 Group. The property is conceived to specify properties about the people who live in the area considered either to specify the number or other characteristics such as the origin, the religion etc."
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E74_Group"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "http://www.cidoc-crm.org/cidoc-crm/E74_Group",
            "rdfs:label": {
                "@language": "en",
                "@value": "Group"
            },
            "rdfs:comment": "This class comprises any gatherings or organizations of human individuals or groups that act collectively or in a similar way due to any form of unifying relationship. In the wider sense this class also comprises official positions which used to be regarded in certain contexts as one actor, independent of the current holder of the office, such as the president of a country. In such cases, it may happen that the group never had more than one member. A joint pseudonym (i.e., a name that seems indicative of an individual but that is actually used as a persona by two or more people) is a particular case of E74 Group.A gathering of people becomes an instance of E74 Group when it exhibits organizational characteristics usually typified by a set of ideas or beliefs held in common, or actions performed together. These might be communication, creating some common artifact, a common purpose such as study, worship, business, sports, etc. Nationality can be modelled as membership in an instance of E74 Group. Married couples and other concepts of family are regarded as particular examples of E74 Group.",
            "skos:notation": "E74",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/Pc3",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP40"
            },
            "skos:notation": "Pc3",
            "rdfs:label": {
                "@language": "en",
                "@value": "has connection through"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property documents that an instance of CP40 Historic Centre is joined (connected) to its environment through an instance of E24 Physical Human made thing. The property is mainly conceived to describe which is the main route of communication that connects an historical centre to the territory."
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP40",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Historic Centre"
            },
            "rdfs:comment": "This class includes instances of urban agglomeration composed by the historical buildings and the open spaces which formerly constituted the town. The historic centre is delimited by a perimeter that can sometimes coincide with the boundary of the city walls when they still exist or when they can be identified on the basis of historical records, material evidence, or on natural limits (streams, strong slopes, etc.). The chronological limit before the World War 1 (1919) normally identifies a part - generally central - of the town, but the contemporary city can also include several historic districts that are in fact disjointed. This threshold can sometimes result from the evident constructive mutation of the building, verified by the comparison with the available cartographic and historical graphic documentation and direct feedback (Fiorani 2019; Geores 2021). In terms of CPM ontology, instances of CP40 Historic Centres are composed by instances of CP13 Urban Units and CP16 Urban Area.",
            "skos:notation": "CP40",
            "@type": "rdfs:Class"
        },
        {
            "@id": "http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing",
            "rdfs:label": {
                "@language": "en",
                "@value": "Physical Human-Made Thing"
            },
            "rdfs:comment": "This class comprises all persistent physical items of any size that are purposely created by human activity. This class comprises, besides others, Human-Made objects, such as a sword, and Human-Made features, such as rock art. For example, a “cup and ring” carving on bedrock is regarded as instance of E24 Physical Human-Made Thing.Instances of Human-Made thing may be the result of modifying pre-existing physical things, preserving larger parts or most of the original matter and structure, which poses the question if they are new or even Human-Made, the respective interventions of production made on such original material should be obvious and sufficient to regard that the product has a new, distinct identity and intended function and is human-made. Substantial continuity of the previous matter and structure in the new product can be documented by describing the production process also as an instance of E81 Transformation.Whereas interventions of conservation and repair are not regarded to produce a new Human-Made thing, the results of preparation of natural history specimens that substantially change their natural or original state should be regarded as physical Human-Made things, including the uncovering of petrified biological features from a solid piece of stone. On the other side, scribbling a museum number on a natural object should not be regarded to make it Human-Made. This notwithstanding, parts, sections, segments, or features of a physical Human-Made thing may continue to be non-Human-Made and preserved during the production process, for example natural pearls used as a part of an eardrop.",
            "skos:notation": "E24",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/Pc2",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP18"
            },
            "skos:notation": "Pc2",
            "rdfs:label": {
                "@language": "en",
                "@value": "has as general vocation"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property documents that an instance of E7 Activity is mainly performed within an instance of CP20 Space Entity. The property allows the description of the functional vocation of activity mainly performed in an architectural (CP20 Spatial Unit or CP21 Spatial component) or urban space (CP21 Historic Centre or CP 19 Spatial Ensemble), that are subclasses of CP20 Space Entity. This property is mainly referring to  conditions revealed by economic and statistical surveys. As an example, this property may describe the agricultural vocation of a village or the specific productive activity (industry, fishing, handycrafts etc.) of an historic centre or the religious vocation of a district. "
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E7_Activity"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "http://www.cidoc-crm.org/cidoc-crm/E7_Activity",
            "rdfs:label": {
                "@language": "en",
                "@value": "Activity"
            },
            "rdfs:comment": "This class comprises actions intentionally carried out by instances of E39 Actor that result in changes of state in the cultural, social, or physical systems documented. This notion includes complex, composite and long-lasting actions such as the building of a settlement or a war, as well as simple, short-lived actions such as the opening of a door.",
            "skos:notation": "E7",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/Pc1",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP41"
            },
            "skos:notation": "Pc1",
            "rdfs:label": {
                "@language": "en",
                "@value": "affects"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property documents that an instance of CP41 Environmental Observable Entity affects an instance of class E1 Entity. This property may be used to describe the fact that external factors that can be observed through visual analysis or by the means of special instruments are affecting a whichever instance of E1 Entity. It has been conceived to describe the action of natural phenomenon such as winds, temperature, atmospheric agents on, either, man-made items, as architecture, or natural elements, as caves or cliffs. Man made items may refer to very heterogenous elements spreading from urban areas to singular building component."
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E1_CRM_Entity"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP41",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E1_CRM_Entity"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Environmental Observable Entity"
            },
            "rdfs:comment": "This class includes instances of E5 Event that can be observed by human sensory impression on a global scale. It describes different types of environmental phenomena related to a specific place and affecting the state of preservation of buildings located there. Class CP41 Observable Environmental Entity describes qualitatively - referring to common categories developed by experts in the field - the most relevant environmental conditions of a site, especially in relation to weather and climate conditions.",
            "skos:notation": "CP41",
            "@type": "rdfs:Class"
        },
        {
            "@id": "http://www.cidoc-crm.org/cidoc-crm/E1_CRM_Entity",
            "rdfs:label": {
                "@language": "en",
                "@value": "CRM Entity"
            },
            "rdfs:comment": "This class comprises all things in the universe of discourse of the CIDOC Conceptual Reference Model. It is an abstract concept providing for three general properties:Identification by name or appellation, and in particular by a preferred identifierClassification by type, allowing further refinement of the specific subclass an instance belongs to Attachment of free text and other unstructured data for the expression of anything not captured by formal propertiesAll other classes within the CIDOC CRM are directly or indirectly specialisations of E1 CRM Entity. ",
            "skos:notation": "E1",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc21_1",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP2"
            },
            "skos:notation": "pc21_1",
            "rdfs:label": {
                "@language": "en",
                "@value": "has type"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property can be used to specify the type of typology the architectural work presents"
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP36"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP36",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E55_Type"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Architecture Type"
            },
            "rdfs:comment": "This class describes the presence of specific formal invariants related to the inherent organizational, functional and constructive aspects of the building. Instances of CP38 Architectural Type can concern form and relative distribution of spaces in architecture, the nature of which has been codified over time by architectural history. Instances of CP38 Architectural Type are the residential building types of townhouses, courtyard, in-line, etc., or the church types with three naves, central, Greek cross, etc.",
            "skos:notation": "CP36",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc19_1",
            "rdfs:subPropertyOf": {
                "@id": "https://w3id.org/cpm-arch/cpm/Pc19"
            },
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP5"
            },
            "skos:notation": "pc19_1",
            "rdfs:label": {
                "@language": "en",
                "@value": "has type"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property can be used to specify the type of masonry features the CP5 Constructive El. Plural is showing."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP28"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc18_1",
            "rdfs:subPropertyOf": {
                "@id": "https://w3id.org/cpm-arch/cpm/Pc18"
            },
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "skos:notation": "pc18_1",
            "rdfs:label": {
                "@language": "en",
                "@value": "has type"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property can be used to specify the type of physical relation the CP1 Built entity has with another CP1 Built entity."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc88",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP16"
            },
            "skos:notation": "pc88",
            "rdfs:label": {
                "@language": "en",
                "@value": "is regulated by"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": " This property documents that an instance of CP16 Urban area is regulated by (regulates), from the legislative point of view, an instance of E32 Authority Document, in the sense that every intervention performed on the area must follow the prescriptions expressed in the document. The authority document may be a monumental constraint, an urban planning tool etc. There is no case of a urban area not being under legislative authority control."
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E32_Authority_Document"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc87",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP50"
            },
            "skos:notation": "pc87",
            "rdfs:label": {
                "@language": "en",
                "@value": "specified"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance of CP 50 Urban conservation Plan with an instance of CP49 Urban Plan addressing the hierarchy relationship existing between the urban planning and urban conservation planning. The first needs to be specified by the latter and leaves necessarily some open issues that are addressed to by conservation. "
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP49"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP50",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E29_Design_or_Procedure"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Urban Conservation Plan"
            },
            "rdfs:comment": "This class includes urban planning instruments aimed at planning the conservation activities to be carried out on historical architecture; these instruments design and regulate interventions focused on the physical form and the construction structure of the historical urban environment. Instances of CP50 Urban Conservation Plan are urban instruments that identify the architectural, functional and constructive characteristics of existing buildings and sites and envisage the operations to be carried out in terms conservation and restoration of of existing buildings They contain restrictive constraints on the actions to be taken on the existing building but also the guidelines to orient how to intervene on the historical façades (in terms of colours, materials and constructive solutions), to the inner part of the building (preserving their historical character but also using compatible solution to allow the introduction of modern equipment and services), to the open areas (orienting the choices about materials, techniques and furniture). These plans are depicted by drawings, reports, check list, and forms address new instances of CP33 Architecture Conservation Project. Instances of CP50 Urban Conservation Plan can also be related to plans that modify already existing plans",
            "skos:notation": "CP50",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc86",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP50"
            },
            "skos:notation": "pc86",
            "rdfs:label": {
                "@language": "en",
                "@value": "addressed"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance of CP 50 Urban conservation Plan with an instance of CP 33 Conservation Project addressing the hierarchy relationship existing between the urban and the architectural scale. The conservation activity developed at the urban level necessarily orient the conservation of the buildings."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP33"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc85",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "skos:notation": "pc85",
            "rdfs:label": {
                "@language": "en",
                "@value": "was subdued to"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance of CP1 Built Entity with an instance of CP 23 Maintenance. This property allows to describe that a building or part of it was the object of a maintenance activity. Differently from conservation intervention, maintenance may be realised without a proper project, but just referring to a sequence of activities to be repeated in time."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP23"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP23",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E11_Modification"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Maintenance"
            },
            "rdfs:comment": " This class comprises instances of E11 Modification undertaken to maintain the form, structure, and construction apparatus of the CP2 Architectural Work. This activity occurs at periodic scheduled intervals or resulting from the detection of local malfunctions in the building system; it is aimed at extending the life of the existing building and may involve the replacement or addition of materials, elements and construction components, while still pursuing a conservative intent. Instances of CP23 Maintenance differ from instances of CP25 Conservation Intervention because of their specific character of repetitiveness and cyclicality and the low conceptual problematic nature of the operations to be performed. In fact, these are carried out using general protocols based on different issues that can be: 1) the expectation of effectiveness of a product (e.g., a stone surface protector); 2) the expectation of effectiveness of a building component (such as the drainage of an eave in a roof); 3) the expectation of effectiveness of a building technique (such as the roofing tile covering of a roof); 4) the potential harmfulness of a climatic event (rain, heavy wind, etc); 5) the expected consequences of a phenomenon (deposition of limestone contained in water, growth of nearby vegetation). These issues can be tackled without having to field special diagnostics and studies and the severity of the problem, as well as the material impact of the intervention are always limited.It follows that the maintenance plan, as a simple management protocol, can be formalised via the CIDOC CRM. This plan can in fact be instantiated using the class E29 Design or Procedure, related to an instance of CP23 Maintenance via the property P33 used specific technique (was used by), inherited from its superclass E7 Activity.",
            "skos:notation": "CP23",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc84",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP34"
            },
            "skos:notation": "pc84",
            "rdfs:label": {
                "@language": "en",
                "@value": "gathers"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance of CP 34 Architecture Depiction with an instance of CP27 Architecture Analysis Output. This property allows to describe the nature of the class architectural depiction. It specifies its role within conservation process as a document that, gathering the results of the analysis that have been developed on the building, represents the knowledge required to orient a conservation project."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP27"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP27",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E13_Attribute_Assignment"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Architecture Analysis Output"
            },
            "rdfs:comment": "This class comprises the actions of making assertions about one historical architecture or one or more of its components, also considering any single relation between various aspects concerning different architectures.  These assertions derive from the specialistic study of the historic architecture, concerning different aspects of the discipline. For example, the class describes the actions of scholars and architects who make propositions and statements during some scientific procedures. These may be pertaining to the nature and layering of construction techniques present in the building, past units of measurement used to dimension spaces and structures, geometric proportioning criteria underlying the definition of spaces and structures, and lexical and linguistic references adopted as reference for formal choices.Possible instances of this class describe the results of the CP30 Architecture Condition Assessment or  the CP34 Architectural Feature Assessment.  ",
            "skos:notation": "CP27",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc83",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP30"
            },
            "skos:notation": "pc83",
            "rdfs:label": {
                "@language": "en",
                "@value": "assessed the decay conditions of"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance of CP 30 Architecture Condition Assessment with an instance of CP9 Building Material specifying the nature of the assessment the building is going through. Particularly the property refers to the decay condition of the building materials the architecture is made of."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP9"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP30",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E14_Condition_Assessment"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Architecture Condition Assessment"
            },
            "rdfs:comment": "This class comprises actions of making propositions or statements about architecture conditions based on hypothesis and any form or formal or informal logic. The aim of the CP30 Architecture Condition Assessment is the understanding of material decay and structural failure of CP2 Architectural Work and B1 Built Work.",
            "skos:notation": "CP30",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc82",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP30"
            },
            "skos:notation": "pc82",
            "rdfs:label": {
                "@language": "en",
                "@value": "assessed the structural condition of"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance of CP 30 Architecture Condition Assessment with an instance of CP2 Architecture Work specifying the nature of the assessment the building or part of is going through. Particularly the property refers to the structural assessment that may detect a structural damage.\n "
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP2"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc81",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP50"
            },
            "skos:notation": "pc81",
            "rdfs:label": {
                "@language": "en",
                "@value": "planned the conservation of"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": " This property allows to relate an instance of CP50 Urban Conservation Plan with an instance of CP16 Urban Area. It specifies the object of the urban conservation plan."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP16"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc80",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP29"
            },
            "skos:notation": "pc80",
            "rdfs:label": {
                "@language": "en",
                "@value": "is referred to"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance of CP 29 Building Phase with an instance of CP1 Built Entity to refer a building or part of it to the reconstruction of the transformation phases formulated through a study to asses its historical and architectural value. More in detail the property allows to specify which is the building phase the architecture may be referred to. "
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP29",
            "rdfs:subClassOf": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP27"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Building Phase"
            },
            "rdfs:comment": "This class comprises instances of CP2 Architectural Work related to a unified construction process carried out over a defined period of time of a built presence. These instances, related to the restitution of the configuration of a historical building in a given historical period, are the product of in-depth knowledge of the building in its current state and inferential processes that can offer as objective indications as possible of the configuration of the building in a specific era.",
            "skos:notation": "CP29",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc79",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP26"
            },
            "skos:notation": "pc79",
            "rdfs:label": {
                "@language": "en",
                "@value": "transformed"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance of CP 26 Typological variation with an instance of CP2 Architecture Work to describe the kind of transformation that occurred in an architecture work. The typological variation implies the transformation of architecture identity as it may tackle figurative, functional and structural issues that qualify a building."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP2"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP26",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E81_Transformation"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Typological Variation"
            },
            "rdfs:comment": "This class comprises the event that result in the simultaneous destruction of one or more than one CP2 Architectural Work and the creation of one or more than one CP2 Architectural Work that preserve recognizable substance and structure from the first one(s) but has fundamentally different nature or identity. Instances of CP26 Typological Variation deal with the organization of inner spaces, such as the distribution and connection of interior spaces in a residence or the internal organization of a church. A common example is the recasting of row houses into in-line palaces, with the interrelation of rooms on the same level, the elimination of the original vertical connectives and their replacement by a single staircase that distributes to all levels. Equally frequent was, especially during the late Italian Renaissance, the transformation of medieval three-nave churches into single-nave churches with chapels to meet post-Tridentine liturgical needs. Typological variation does not necessarily entail a change in function and may tie in with fairly limited transformations of material substance, but it still brings about a substantial transformation in the way the affected architecture is used and experienced.",
            "skos:notation": "CP26",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc78",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP18"
            },
            "skos:notation": "pc78",
            "rdfs:label": {
                "@language": "en",
                "@value": "is visually related to"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to describe the relation between two instances of CP18 Space Entity to specify whether there is a visual continuity or not. As an example, a chapel may be communicating with the aisle of a church or may be separated from it through a wall and put into connection through a door. The property is conceived to express the relation at the higher level of the hierarchy of the architecture spaces (CP18 Space Entity) so to describe all the possible spatial solutions occurred in a specific time."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP18"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc77",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP21"
            },
            "skos:notation": "pc77",
            "rdfs:label": {
                "@language": "en",
                "@value": "has as space component"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance of CP 21 Space Unit to an instance of CP 22 Space Component in order to describe the mereological relations between the elements that produce the spatial composition of an architecture work considering both dimension of space and time. A space unit may be a unitary area or the result of the juxtaposition of several space components. As an example, a church that shows Hallenkirche typology is conceived as a CP 21 Space Unit that cannot be further divided into spatial components) CP 22). Besides, a three naves church with an apse, is considered as a CP 21 Space Unit, that may be divided into several space components as the central nave, the two ailes and the apse."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP22"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP21",
            "rdfs:subClassOf": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP18"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Space Unit"
            },
            "rdfs:comment": "This class includes instances relating to the substance of the architectural or urban organism uniquely determinable on the basis of the characters of continuity and recognizability referred to the built (A-F Ingenio 2017). The instances of CP21 Space Unit are not physical objects but deals with the footprint of empty spaces defined by its changing physical presence over time, representing 4D ensembles.  ",
            "skos:notation": "CP21",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP22",
            "rdfs:subClassOf": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP18"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Space Component"
            },
            "rdfs:comment": "This class includes instances relating to a part of the architectural organism endowed with a spatial identity that cannot be further subdivided. Instances of CP22 Space Component are identified by their specific characters of continuity and recognizability referring to the built (A-F Ingenio 2017). They do not involve physical objects, but the footprint of empty space defined by them, subject to change over time, and represent 4D ensembles.",
            "skos:notation": "CP22",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc76",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP19"
            },
            "skos:notation": "pc76",
            "rdfs:label": {
                "@language": "en",
                "@value": "is marked by"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance of CP 40 Historic Centre to an instance of CP 17 Cultural Heritage Landscape Element in order to describe the features characterizing the urban landscape of an historic centre. different types of landscape element could be parcs, gardens, special viewpoints, panoramic views etc."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP17"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP17",
            "rdfs:subClassOf": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP15"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Landscape Element"
            },
            "rdfs:comment": "This class includes instances relating to environments resulting consistent for natural and anthropic features and having a special cultural value. Sometimes this consistency is evident from a perceptive viewpoint, sometimes this consistency is perceivable as homogeneity. Such instances may possess a special cultural value and be defined as outstanding universal value in Unesco list or may have been subject to spatial and landscape constraints by national conservation agencies or zoning regulations. However, instances of CP17 Cultural Heritage Landscape Element may also simply connote a recognized locally significant urban or rural landscape.",
            "skos:notation": "CP17",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc75",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP17"
            },
            "skos:notation": "pc75",
            "rdfs:label": {
                "@language": "en",
                "@value": "can be referred to landscape type"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance of CP 17 Cultural Heritage Landscape Element to an instance of E55 Type in order to describe the element and associate it to the thesaurus derived from the Institutional Cultural Heritage Protection Lists. As a matter of facts the Italian Cultural Heritage code specifies different type of landscape element such as: parcs, panoramic views etc."
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E55_Type"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc74",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP42"
            },
            "skos:notation": "pc74",
            "rdfs:label": {
                "@language": "en",
                "@value": "was caused by"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance of CP 42 Material Decay to an instance of E5 Event in order to describe the event that eventually caused the material decay. Although material decay is mostly triggered by environmental condition, some events may occur fostering decay or provoking some specific deterioration. The property is mainly conceived to describe extraordinary events, such as earthquakes of floodings."
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E5_Event"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "http://www.cidoc-crm.org/cidoc-crm/E5_Event",
            "rdfs:label": {
                "@language": "en",
                "@value": "Event"
            },
            "rdfs:comment": "This class comprises distinct, delimited and coherent processes and interactions of a material nature, in cultural, social or physical systems, involving and affecting instances of E77 Persistent Item in a way characteristic of the kind of process. Typical examples are meetings, births, deaths, actions of decision taking, making or inventing things, but also more complex and extended ones such as conferences, elections, building of a castle, or battles.While the continuous growth of a tree lacks the limits characteristic of an event, its germination from a seed does qualify as an event. Similarly, the blowing of the wind lacks the distinctness and limits of an event, but a hurricane, flood or earthquake would qualify as an event. Mental processes are considered as events, in cases where they are connected with the material externalization of their results; for example, the creation of a poem, a performance or a change of intention that becomes obvious from subsequent actions or declarations.The effects of an instance of E5 Event may not lead to relevant permanent changes of properties or relations of the items involved in it, for example an unrecorded performance. Of course, in order to be documented, some kind of evidence for an event must exist, be it witnesses, traces or products of the event.While instances of E4 Period always require some form of coherence between its constituent phenomena, in addition, the essential constituents of instances of E5 Event should contribute to an overall effect; for example, the statements made during a meeting and the listening of the audience.Viewed at a coarse level of detail, an instance of E5 Event may appear as if it had an ‘instantaneous’ overall effect, but any process or interaction of material nature in reality have an extent in time and space. At a fine level, instances of E5 Event may be analysed into component phenomena and phases within a space and timeframe, and as such can be seen as a period, regardless of the size of the phenomena. The reverse is not necessarily the case: not all instances of E4 Period give rise to a noteworthy overall effect and are thus not instances of E5 Event.",
            "skos:notation": "E5",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc73",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP2"
            },
            "skos:notation": "pc73",
            "rdfs:label": {
                "@language": "en",
                "@value": "is facing onto"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of CP2 Architecture work with an instance of CP 15 Open Air Area and allows to describe that a building is overlooking an area that is not a urban area. This property is necessary to express the physical relation that is established between a building and the space onto it is facing. It is describing a twofold relationship referring either to the connection that an observer may have with the outer space through a window looking outside or to the role that the building façade is playing as a backdrop for the open air area."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP15"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP15",
            "rdfs:subClassOf": [
                {
                    "@id": "http://www.cidoc-crm.org/cidoc-crm/E19_Physical_Object"
                },
                {
                    "@id": "https://w3id.org/cpm-arch/cpm/CP13"
                }
            ],
            "rdfs:label": {
                "@language": "en",
                "@value": "Open Air Area"
            },
            "rdfs:comment": "This class includes instances relating to environments and landscapes resulting consistent for natural and anthropic features. Sometimes this consistency is evident from a perceptive viewpoint, sometimes this consistency is perceivable as homogeneity of constituent features. Instances of CP15 Open Air Area can be squares, streets or gardens of an urban centre, but also parks and open landscapes related to a historic architectures or urban centres. Such instances may have a particular cultural value or also constitute elements of local connotation of a specific urban landscape.",
            "skos:notation": "CP15",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc72",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP13"
            },
            "skos:notation": "pc72",
            "rdfs:label": {
                "@language": "en",
                "@value": "shows geometry plan type"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance of CP 13 Urban Unit to an instance of E55 Type in order to identify the geometry plan type of the building. The property is conceived to allow referring to thesauri describing the different geometries that are relevant not only for the formal reasons but mainly because they are influencing the structural vulnerability of the building."
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E55_Type"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP13",
            "rdfs:subClassOf": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP2"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Urban Unit"
            },
            "rdfs:comment": "This class includes instances corresponding to a coherent architectural organism populating an urban historical setting. It consists in a single construction phase or by the merging/recasting of several pre-existing building units and can be described only in its exterior features. This organism is characterized by the presence of one or more functional units (residential and non-residential) connected to each other through common distribution elements and served by access at the road level; it is bordered by external facades with a generally continuous eaves line and a unitary or composite roof composed of flat and/or inclined parts consistent with all fronts. An urban unit can be constituted by a continuous set of structurally connected but distinguishable building units as organisms that are architecturally coherent populating an urban historical setting and may contain within it places relevant to one or more building units.  In this case, it overlooks on urban spaces through fronts that result from the succession of the individual facades of the building units. This specific type of urban unit is called ‘aggregate’. Alternatively, the urban unit can be a homogeneous and autonomous unitary element, bordered by urban spaces with whom it communicates through accesses to the ground floor and can contain open places inside. It overlooks urban spaces through a variable number of fronts generally figuratively and constructively coherent with each other. This another type is called 'residential or specialist punctual building unit' and consists in buildings such as villas or cottages (residential building) or complexes as hospitals or schools (specialist building) (Acierno, Fiorani, Velios 2021).Instances of CP13 Urban Unit differ from instances of CP2 Architectural Work for being related to an edifice that is considered a component of an urban historical setting. Meaning that instances of CP12 Urban Unit are building which are components of an urban tissue, where the main characteristic are the relationships established among them.",
            "skos:notation": "CP13",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc71",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP12"
            },
            "skos:notation": "pc71",
            "rdfs:label": {
                "@language": "en",
                "@value": "is intrinsically connected to"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate two instances of CP 12 Building Floor to describe the condition of the connection between two floors. Particularly within conservation process this is a very sensitive condition that requires a major care, as ancient buildings may not bear the presence of them if not adequately designed."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP12"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP12",
            "rdfs:subClassOf": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP2"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Building Floor"
            },
            "rdfs:comment": "This class includes instances relating to a portion of a CP10 Building Unit between the floor and the ceiling. In residential buildings, instances of CP12 Building Floor normally correspond to the presence of one or more residential units, but in historic buildings, instances of CP12 Building Floor may include only part of a residential unit (such as for a row house, composed of overlapping rooms, or for a noble palace, which housed and may still house a family and its employees on all levels of the building). It is also not uncommon for historic residential buildings to combine a ground floor with commercial functions and residential upper floors or for different functions to overlap with each other. This is often the case in specialised buildings, where instances of CP12 Building Floor may also involve floor-to-ceiling portions with different organisational and functional characteristics (e.g. classrooms and staff offices in a school).",
            "skos:notation": "CP12",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc70",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP8"
            },
            "skos:notation": "pc70",
            "rdfs:label": {
                "@language": "en",
                "@value": "passes through"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance of CP8 Equipment with an instance of the class CP 20 Construction Work to describe the condition of an equipment crossing a whatever part of the building. Particularly within conservation process this is a very sensitive condition that requires a major care, as ancient buildings may not bear the presence of them if not adequately designed."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP20"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP8",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Equipment"
            },
            "rdfs:comment": "This class includes instances of plant systems pertaining a single architectural work. Such instances can have different nature, regarding the web and the terminals used for the distribution of water, electricity, heating or cooling etc. in a building.",
            "skos:notation": "CP8",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP20",
            "rdfs:subClassOf": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Construction Work"
            },
            "rdfs:comment": "This class includes instances of the constructive apparatus that characterizes an architecture. Instances of CP20 Construction Work can gather building units, components and elements that have specific functions from a constructional point of view or that delimit and/or support the building or parts of it. ",
            "skos:notation": "CP20",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc69",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP5"
            },
            "skos:notation": "pc69",
            "rdfs:label": {
                "@language": "en",
                "@value": "shows as construction element singular"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance of CP5 Construction Element Plural with an instance of the class CP6 Construction Element Singular to describe their specific mereological relation. The property intends to make explicit the singular elements (CP6) that are constituting the construction element plural (CP5). As an example the plaster shows as single construction elements the different layers of mortar, or a masonry shows as single construction elements the stone ashlars."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP6"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP6",
            "rdfs:subClassOf": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP20"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Construction Element Singular"
            },
            "rdfs:comment": "This class includes instances of the constructive component characterised by a proper material specificity. Such instances may consist of masonry faces, roofing systems covering the trusses in a wooden roof, coffering ceiling, the window frames, the plaster cladding a wall.",
            "skos:notation": "CP6",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc68",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP4"
            },
            "skos:notation": "pc68",
            "rdfs:label": {
                "@language": "en",
                "@value": "shows as construction element plural"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance of CP4 Construction Component with an instance of the class CP5 Construction Element Plural to describe their specific mereological relation. The property intends to make explicit the components that are constituting the construction component. As an example, a wall shows as construction element plural the masonry and the plaster cladding it."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP5"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP4",
            "rdfs:subClassOf": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP20"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Construction Component"
            },
            "rdfs:comment": "This class includes instances of a part of the building unit which is consistent from the structural or technological viewpoint. Such instances may consist of the structural component of a floor or of a vault, excluding finishings such as flooring and plastering, the construction part of a wall (e.g., the two opposing faces and the intermediate core), as well as the door and window shutters.",
            "skos:notation": "CP4",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc67",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP3"
            },
            "skos:notation": "pc67",
            "rdfs:label": {
                "@language": "en",
                "@value": "shows as construction component"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance of CP3 Construction Unit with an instance of the class CP4 Construction Component to describe their specific mereological relation. The property intends to make explicit the components that are constituting the construction unit. As an example the façade of a church shows as construction component the wall."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP4"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP3",
            "rdfs:subClassOf": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP20"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Construction Unit"
            },
            "rdfs:comment": "This class includes instances of composite portions of a building that have specific functions from a constructional point of view or that delimit and/or support the building or parts of it.  Such instances may consist of the network of empty channels within the walls for smoke evacuation, the construction system of a wall (e.g., the two opposing faces and the intermediate core, any stone or plaster cladding), the construction system of a floor (e.g., consisting of main beams, secondary frames and wood planking, a layer of bedding mortar, and flooring).",
            "skos:notation": "CP3",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc66",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP51"
            },
            "skos:notation": "pc66",
            "rdfs:label": {
                "@language": "en",
                "@value": "is defined by"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate tan instance of CP51 Building Component with an instance of CP20 Construction Work so to describe their topographical relation and the boundaries a building component, as a nave of a church may have The property refers to boundaries that are constituted by built element or part of them."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP20"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP51",
            "rdfs:subClassOf": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP2"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Building Component"
            },
            "rdfs:comment": "This class includes instances relating to parts of the architectural organism that subtend spaces that cannot be further subdivided. The instances of CP51 Building Component are identified on the basis of their specific characters of continuity and recognisability ascribable to a given period of time. These characters refer both to the physical architectural and building components and to the space that is defined by them. ",
            "skos:notation": "CP51",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc65",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP40"
            },
            "skos:notation": "pc65",
            "rdfs:label": {
                "@language": "en",
                "@value": "is delimited by"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance of CP40 Historic Centre to an instance of E18 Physical Thing and describe their topographical relation. The property is connecting CP40 Historic Centre class with E18 Physical Thing that can represent very broad condition so to describe any kind of boundary an historic centre may have."
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E18_Physical_Thing"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "http://www.cidoc-crm.org/cidoc-crm/E18_Physical_Thing",
            "rdfs:label": {
                "@language": "en",
                "@value": "Physical Thing"
            },
            "rdfs:comment": "This class comprises all persistent physical items with a relatively stable form, human-made or natural.Depending on the existence of natural boundaries of such things, the CIDOC CRM distinguishes the instances of E19 Physical Object from instances of E26 Physical Feature, such as holes, rivers, pieces of land etc. Most instances of E19 Physical Object can be moved (if not too heavy), whereas features are integral to the surrounding matter.An instance of E18 Physical Thing occupies not only a particular geometric space at any instant of its existence, but in the course of its existence it also forms a trajectory through spacetime, which occupies a real, that is phenomenal, volume in spacetime. We include in the occupied space the space filled by the matter of the physical thing and all its inner spaces, such as the interior of a box. For the purpose of more detailed descriptions of the presence of an instance of E18 Physical Thing in space and time it can be associated with its specific instance of E92 Spacetime Volume by the property P196 defines (is defined by). The CIDOC CRM is generally not concerned with amounts of matter in fluid or gaseous states, as long as they are not confined in an identifiable way for an identifiable minimal time-span.",
            "skos:notation": "E18",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc64",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "skos:notation": "pc64",
            "rdfs:label": {
                "@language": "en",
                "@value": "is cladded by"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance of CP5 Construction Element Plural to an instance of CP1 Built Entity. It intends to describe the relation between a construction element plural and a built Entity, either it is an architecture work or a part of it, describing the cladding function of the first towards the second."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP5"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc63",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "skos:notation": "pc63",
            "rdfs:label": {
                "@language": "en",
                "@value": "is crossed by"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance of CP 20 Construction Work to an instance of CP1 Built Entity. It intends to describe the relation between a construction element and an architecture work or part of it when they are in a condition of mutual interference. Particularly this property allows to describe the condition of a construction element intersecting a building or part of, as for example a lintel intersecting the apse of a church or a trace to realise electric system intersecting a wall."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP20"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc62",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP43"
            },
            "skos:notation": "pc62",
            "rdfs:label": {
                "@language": "en",
                "@value": "was caused by"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance of CP 43 Structural damage with an instance of E5 Event. It identifies which event was at the origin of a specific structural damage."
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E5_Event"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP43",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E5_Event"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Structural Damage"
            },
            "rdfs:comment": "CP43 Structural Damage cases refer specifically to phenomena that cause changes in the structural behaviour of a CP1 Built Entity. These changes are normally due to failure mechanisms that favour the partial or total loss of a building's resistance capacity. Induced failure mechanisms manifest themselves with specific recognisable effects on building structures.Instances of CP43 Structural Damage thus refer, among others, to the phenomena of cracking, crushing of materials, deformation or change in the original position of a building structure as a whole or a part thereof.",
            "skos:notation": "CP43",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc61",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "skos:notation": "pc61",
            "rdfs:label": {
                "@language": "en",
                "@value": "was affected by"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance CP1 Built Entity to an instance of CP43 Structural damage. It intends to identify the structural damage that was produced in a building and specify which part of it was involved. It allows to describe the structural condition within a decay analysis."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP43"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc60",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP46"
            },
            "skos:notation": "pc60",
            "rdfs:label": {
                "@language": "en",
                "@value": "realised"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance CP46 Building Activity to an instance of CP1 Built Entity. It intends to identify the activity that produced the building or part of it, allowing to describe all the activities connected to the yard, the providing of materials, the workers etc."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP46",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E7_Activity"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Building Activity"
            },
            "rdfs:comment": "This class comprises instances of E7 Activity produced to build a new architecture or to introduce new important transformation in it, normally documented in CP45 Architectural Project. Instances of CP45 Architectural Project can also deal with activities carried out without any real design when they are equally significant for the final architectural configuration",
            "skos:notation": "CP46",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc59",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP8"
            },
            "skos:notation": "pc59",
            "rdfs:label": {
                "@language": "en",
                "@value": "shows equipment type"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance CP8 Equipment to an instance of CP 49 Equipment Type intends to specify the nature of the equipment referring to exiting thesauri. Equipment a conservation project refers to may be of any kind hydraulic, electric, air conditioning, heating etc."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP48"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP48",
            "rdfs:comment": [
                "This class specifies the different types of CP8 Equipment. Instances of CP48 Equipment Type can refer to plumbing, electrical or heating system, etc",
                " This class specifies the different types of CP8 Equipment. Instances of CP48 Equipment Type can refer to plumbing, electrical or heating system, etc."
            ],
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E55_Type"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Equipment Type"
            },
            "skos:notation": "CP48",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc58",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP7"
            },
            "skos:notation": "pc58",
            "rdfs:label": {
                "@language": "en",
                "@value": "represents"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance of CP 7 Architecture decoration to an instance of E1 Entity and intends to describe the contents its representation."
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E1_CRM_Entity"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP7",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Architecture Decoration"
            },
            "rdfs:comment": "This class includes instances of decorative apparatus closely related to the composition of the architectural work. Such instances may consist of figurative paintings on the façades of a building or on the inner face of the walls in a church, as well as stuccoes, graffiti, ceramic cladding and sculptures attached to the walls of the building. Unlike instances of CP6 Constructive Element Singular, instances of CP7 Architectural Decoration do not usually play a specific role in the construction other than strictly decorative. This means that in the presence of a stone lintel carved in bas-relief, the lintel as a structural element must be considered as an instance of CP6 Constructive Element Singular, while its vertical surface with bas-relief can be instantiated as CP7 Architectural Decoration. Similarly, the metal key head should be instantiated as of CP6 Constructive Element Singular, while the cover stud should be instantiated as CP7 Architectural Decoration. When the constructive and decorative aspects are not separable (e.g. the decorated wrought iron balustrade of a balcony), the element may be instantiated as either CP6 Constructive Element Singular or CP7 Architectural Decoration.",
            "skos:notation": "CP7",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc57",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP7"
            },
            "skos:notation": "pc57",
            "rdfs:label": {
                "@language": "en",
                "@value": "shows decoration type"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance of CP 7 Architecture decoration to an instance of CP 47 Decoration Type and refers to the several thesauri that may be considered within an architectural description. The description of the decoration may refer to its material, formal or typological nature."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP47"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP47",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E55_Type"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Decoration Type"
            },
            "rdfs:comment": "This class specifies the different types of decoration existing in a CP1 Built Entity. Instances of CP47 Decoration Type concern techniques used for decorating architectures, components or elements, such as painting techniques, sculptural treatments of stone or wood, etc",
            "skos:notation": "CP47",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc56",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP46"
            },
            "skos:notation": "pc56",
            "rdfs:label": {
                "@language": "en",
                "@value": "was realised on"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate a Cp1 Built Entity to the building activity that has generated it. It is particularly useful when the documentation of a building or a part of it requires to refer to the specific intervention that was at the origin of it."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc55",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP45"
            },
            "skos:notation": "pc55",
            "rdfs:label": {
                "@language": "en",
                "@value": "directed"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of CP45 Architecture Project to an instance of CP46 Building Activity to allow the description of the document the building activity is referring to. Actually, the architecture project involves many different activities, not only describing the design but also giving practical instructions to make the realisation of the building possible, such as the executive drawings or the planning of the yard."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP46"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc54",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP45"
            },
            "skos:notation": "pc54",
            "rdfs:label": {
                "@language": "en",
                "@value": "planned"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate a project to a building or a part of it. Such a description is generally needed within the documentation of an architecture when it is necessary to distinguish the phases of the transformation occurred and more specifically the origin of the particular parts."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc53",
            "rdfs:comment": [
                {
                    "@language": "en",
                    "@value": "This property allows to relate two different instances of PC45 Architecture Project making it possible describe all the modifications that may occur during the constructive phases of an architectural project."
                },
                {
                    "@language": "en",
                    "@value": "vs"
                }
            ],
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP45"
            },
            "skos:notation": "pc53",
            "rdfs:label": {
                "@language": "en",
                "@value": "has modified"
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP45"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc52",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "skos:notation": "pc52",
            "rdfs:label": {
                "@language": "en",
                "@value": "was assessed by"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of CP1 Built Entity with an instance of CP31 Mechanical damage assessment. The property intends to describe which structural evaluation process CP31 Mechanical damage assessment has involved a particular building or part of it."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP31"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP31",
            "rdfs:subClassOf": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP30"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Mechanical Damage Assessment"
            },
            "rdfs:comment": "This class describes the act of assessing the mechanical kinematism of a structure during a particular period. The mechanical kinematism may be carried out by the observation (directly or using a sufficient number of photos) of the structural decay of the building (cracks, deformation and so on) and/or through historical research. It indicates the assessment about the manner in which a building is deformed and/or damaged by kinematic stresses, with particular reference to seismic phenomena.",
            "skos:notation": "CP31",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc51",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP9"
            },
            "skos:notation": "pc51",
            "rdfs:label": {
                "@language": "en",
                "@value": "is affected by"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of CP 9 Building Material with an instance of CP 42 Material Decay. The property intends to describe which is the material decay (CP 42 Material Decay) that has affected the material that constitutes a particular physical object or part of it."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP42"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc50",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP33"
            },
            "skos:notation": "pc50",
            "rdfs:label": {
                "@language": "en",
                "@value": "incorporates"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "v"
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP34"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc49",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP43"
            },
            "skos:notation": "pc49",
            "rdfs:label": {
                "@language": "en",
                "@value": "was fostered by"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to relate an instance of CP 43 Structural damage with an instance of E3 Condition State. It allows to describe the conditions of a building or part of it that have fostered a structural damage. As a matter of facts the structural damage may be caused by specific events or by some building conditions that may influence the decay phenomenons. Those condition may be referred either to a inadequate maintenance or to not inappropriate interventions. As an example, a defect in a roof if not quickly repaired could make it possible that the water hits the structure which may be not able to resist. As a consequence, the building or part of it at first shows cracks and secondly collapses. Also a superelevation of a building if not adequately planned may provoke an excessive load on the masonry generating cracks."
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E3_Condition_State"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc48",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP49"
            },
            "skos:notation": "pc48",
            "rdfs:label": {
                "@language": "en",
                "@value": "planned"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of CP49 Urban Plan with an instance of CP 16 Urban Area and it allows to refer an urban area (CP 16) to an urban plan (CP49)."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP16"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc47",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP49"
            },
            "skos:notation": "pc47",
            "rdfs:label": {
                "@language": "en",
                "@value": "has modified"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property allows to document the modifications that may occur on an urban plan. This circumstance may be addressed either to describe modifications that may be needed during the urban designing process or as the result of later intervention. These modifications may be triggered by intrinsic or extrinsic factors that may have intervened also independently of the designer''s will."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP49"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc46",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP44"
            },
            "skos:notation": "pc46",
            "rdfs:label": {
                "@language": "en",
                "@value": "has geology type"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of CP44 Construction Site with an instance of E55 Type. The property intends to describe the specific geological nature of an area of property on the surface of the Earth or a landscape involved in the built area. As for the morphology documentation it may concern either historical centres or buildings."
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E55_Type"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP44",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E27_Site"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Construction Site"
            },
            "rdfs:comment": "This class includes pieces of land or see plan where a single building, a group of buildings, or a historic centre has been placed. The concept of a site is broader than the area exactly occupied by the single architecture and defines the main characters of this area and its surroundings; in the presence of a villa, the construction site gathers the area of the entire complex, both built and green.In contrast to the purely geometric notion of E53 Place, this class describes constellations of matter on the surface of the Earth containing buildings, which can be represented by photographs, paintings, and maps.Instances of CP44 Construction Site e are composed of relatively immobile material items and features with specific morphology and use and a proper geologic composition of the ground.",
            "skos:notation": "CP44",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc45",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP44"
            },
            "skos:notation": "pc45",
            "rdfs:label": {
                "@language": "en",
                "@value": "has morphology type"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of CP44 Construction Site with an instance of E55 Type. The property intends to describe the morphology of identifiable features, as they are described in CIDOC CRM, that “are physically attached in an integral way to particular physical objects or are portions of particular objects with partially imaginary borders, such as the core of the Earth, an area of property on the surface of the Earth, a landscape or the head of a contiguous marble statue”. In architecture this property may be used to describe the morphology of the CP 44 Construction Site, that is a subclass of E26 Physical feature. It is conceived to represent the land involved in the construction, regardless of the construction consistency and nature. The morphology of the construction site may be documented either for a historical centre or for a building."
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E55_Type"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc44",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP38"
            },
            "skos:notation": "pc44",
            "rdfs:label": {
                "@language": "en",
                "@value": "illustrates"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of CP38 Architecture Representation Element with an instance of CP 34 Architecture Depiction and allows to describe the content of a graphic representation"
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP34"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP38",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Architecture Representation Object"
            },
            "rdfs:comment": "This class comprises discrete, identifiable human made items created with the purpose to represent every kind of CP1 Built Entity using graphic or alpha-numeric representation, regardless to the scale of representation (from the urban scale to the detailed one). Instances of Cp38 Architecture Representation Object can be material objects (such as printed drawings, handmade sketches on paper, maquettes, reports on paper, etc.) or immaterial items (such as digital models or 2D representation, files with structural or economic calculation, etc.)",
            "skos:notation": "CP38",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc43",
            "rdfs:subPropertyOf": {
                "@id": "https://w3id.org/cpm-arch/cpm/Pc2"
            },
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "skos:notation": "pc43",
            "rdfs:label": {
                "@language": "en",
                "@value": "is used for"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of E7 Activity with an instance of CP1 Built Entity and allows to describe the activity the building (CP2 architectural Work) or a part of it (CP1 Built Entity) is used for. It refers to the utilitas of the building coping with the building as physical shelter, differently from the property Pc 6 that put into relation an activity with an architectural space (formalized as a space time volume)."
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E7_Activity"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc42",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "skos:notation": "pc42",
            "rdfs:label": {
                "@language": "en",
                "@value": "was embodied by"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of CP1 Built Entity with an instance of CP1 Built Entity and allows to describe the result of a modification a building went through."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc4_1",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP28"
            },
            "skos:notation": "pc4_1",
            "rdfs:label": {
                "@language": "en",
                "@value": "has chromatic"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "mknj"
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E55_Type"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc41",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "skos:notation": "pc41",
            "rdfs:label": {
                "@language": "en",
                "@value": "shows as main material"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of CP1 Built Entity with an instance of CP9 Building material and allows to describe which is the principal material that can be observed in a building, or a part of it, without intending to specify all the materials that have been used to build the edifice, but the one which is prevailing and directly observable through the view. It refers explicitly to a building material (eg. concrete, marble etc.)."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP9"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc40",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP2"
            },
            "skos:notation": "pc40",
            "rdfs:label": {
                "@language": "en",
                "@value": "is facing onto"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of CP2 Architecture work with an instance of CP16 Urban Area and allows to describe that a building is overlooking an Urba Area (CP 16). This property is necessary to express the physical relation that is established between a building and the space onto it is facing through the façade. This relation is expressing the threshold role that is recognized to a façade between private and public space. It is describing a twofold relationship referring either to the connection that an observer may have with the outer space through a window looking outside or to the role that the building façade is playing as a backdrop for the urban space."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP16"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc39",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "skos:notation": "pc39",
            "rdfs:label": {
                "@language": "en",
                "@value": "characterizes"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of CP1 Built Entity with an instance of CP18 Space Entity and allows to describe which is the connotative element of an historical centre or an urban area. Connotative elements may be very heterogeneous such as built towers or balconies or opus craticium walls."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP18"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc38",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP27"
            },
            "skos:notation": "pc38",
            "rdfs:label": {
                "@language": "en",
                "@value": "specifies"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of CP27 Architecture Analysis Output with an instance of CP9 Building material and it allows to express which materials have been identified within the building material analysis. The specification of the material substantial is the result of an assessment and is considered as an output of the analysis process."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP9"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc37",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP33"
            },
            "skos:notation": "pc37",
            "rdfs:label": {
                "@language": "en",
                "@value": "complies with"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of CP24 Conservation Project Activity with an instance of E32 Autority Document and it allows to associate the conservation project activity to the pertaining normative references. The conservation project activity in Italy matches necessarily with the D.lgs. n.42/2004"
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E32_Authority_Document"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc36",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP24"
            },
            "skos:notation": "pc36",
            "rdfs:label": {
                "@language": "en",
                "@value": "addressed"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of CP24 Conservation Project Activity with an instance of CP25 Conservation Intervention and it allows to distinguish between the activity of elaborating the conservation project and the realisation of it. The conservation Project Activity (CP24) has addressed the conservation intervention (CP25) which was realised by the construction company."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP25"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP24",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E7_Activity"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Architecture Conservation Project Activity"
            },
            "rdfs:comment": "This class comprises instances of E7 Activity intentionally carried out by instances of E39 Actor in order to develop a CP33Conservation Project. The aim of this activity is to define technically the best choices for preserving, safeguarding, and using in a compatible way historic architectures, archaeological sites, hight value modern buildings developing the appropriate project tools. This activity has a multidisciplinary character and is oriented by the knowledge of the architecture to conserve.",
            "skos:notation": "CP24",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc35",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP24"
            },
            "skos:notation": "pc35",
            "rdfs:label": {
                "@language": "en",
                "@value": "is expressed in"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of CP24 Conservation Project Activity with an instance of CP33 Conservation Project and it allows to distinguish between the activity of elaborating the conservation project and the document that represents the result of this activity which is the project itself"
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP33"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc34",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP24"
            },
            "skos:notation": "pc34",
            "rdfs:label": {
                "@language": "en",
                "@value": "used as input"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of CP33 Conservation project activity with an instance of CP27 Architecture Analysis Output that act as a guideline for the conservation project. Conservation project (CP33) is elaborated moving from the attribute assignments carried out as outputs (CP27) during the architecture analysis which is compulsory to intervene on cultural heritage architecture. A use case of this property is to describe what elements, retrieved from the architecture analysis, have oriented the conservation project."
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E13_Attribute_Assignment"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "http://www.cidoc-crm.org/cidoc-crm/E13_Attribute_Assignment",
            "rdfs:label": {
                "@language": "en",
                "@value": "Attribute Assignment"
            },
            "rdfs:comment": "This class comprises the actions of making assertions about one property of an object or any single relation between two items or concepts. The type of the property asserted to hold between two items or concepts can be described by the property P177 assigned property of type (is type of property assigned): E55 Type. For example, the class describes the actions of people making propositions and statements during certain scientific/scholarly procedures, e.g., the person and date when a condition statement was made, an identifier was assigned, the museum object was measured, etc. Which kinds of such assignments and statements need to be documented explicitly in structures of a schema rather than free text, depends on whether this information should be accessible by structured queries.This class allows for the documentation of how the respective assignment came about, and whose opinion it was. Note that all instances of properties described in a knowledge base are the opinion of someone. Per default, they are the opinion of the team maintaining the knowledge base. This fact must not individually be registered for all instances of properties provided by the maintaining team, because it would result in an endless recursion of whose opinion was the description of an opinion. Therefore, the use of instances of E13 Attribute Assignment marks the fact, that the maintaining team is in general neutral to the validity of the respective assertion, but registers someone else’s opinion and how it came about.All properties assigned in such an action can also be seen as directly relating the respective pair of items or concepts. Multiple use of instances of E13 Attribute Assignment may possibly lead to a collection of contradictory values. All cases of properties in this model that are also described indirectly through a subclass of E13 Attribute Assignment are characterised as \"short cuts\" of a path via this subclass. This redundant modelling of two alternative views is preferred because many implementations may have good reasons to model either the action of assertion or the short cut, and the relation between both alternatives can be captured by simple rules.",
            "skos:notation": "E13",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc33",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP33"
            },
            "skos:notation": "pc33",
            "rdfs:label": {
                "@language": "en",
                "@value": "forsees"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of CP25Conservation intervention with an instance of CP33 Conservation Project and it allows to express the allographic nature of architecture and its conservation. The project itself is a subclass of E29 design while its realisation is conceived as a subclass of E7 activity. "
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP25"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc32",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP32"
            },
            "skos:notation": "pc32",
            "rdfs:label": {
                "@language": "en",
                "@value": "provided as output"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of CP32 Architecture features assessment with an instance of CP27  Architecture Analysis Output.  The outputs of the architectural analysis result from inferences as the assessments that orient the conservation project are not only based on data collection but require reasoning taking into account the architectural features of the building or the documentary sources existing on it. Inferences elaborated from the observation of architectural features provide as output the result of the architectural analysis."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP27"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP32",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E7_Activity"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Architecture Features Analysis"
            },
            "rdfs:comment": "This class comprises actions investigating instances of CP1 Built Entity, that can be determined by a systematic procedure. The aim of the CP32 Architectural Features Assessment is the understanding of constructive and formal features of CP2Architectural Work and CP1 Built Entity. This class is used to document the building development, the technical, figurative and typological references of the architecture.",
            "skos:notation": "CP32",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc31",
            "rdfs:domain": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E81_Transformation"
            },
            "skos:notation": "pc31",
            "rdfs:label": {
                "@language": "en",
                "@value": "transformed"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of E81 Transformation with an instance of CP1 Buit Entity. It allows to describe all the interventions occurred on a building or part of it that have modified its identity."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "http://www.cidoc-crm.org/cidoc-crm/E81_Transformation",
            "rdfs:label": {
                "@language": "en",
                "@value": "Transformation"
            },
            "rdfs:comment": "This class comprises the events that result in the simultaneous destruction of one or more than one E18 Physical Thing and the creation of one or more than one E18 Physical Thing that preserves recognizable substance and structure from the first one(s) but has fundamentally different nature or identity.Although the old and the new instances of E18 Physical Thing are treated as discrete entities having separate, unique identities, they are causally connected through the E81 Transformation; the destruction of the old E18 Physical Thing(s) directly causes the creation of the new one(s) using or preserving some relevant substance and structure. Instances of E81 Transformation are therefore distinct from re-classifications (documented using E17 Type Assignment) or modifications (documented using E11 Modification) of objects that do not fundamentally change their nature or identity. Characteristic cases are reconstructions and repurposing of historical buildings or ruins, fires leaving buildings in ruins, taxidermy of specimen in natural history.Even though such instances of E81 Transformation are often motivated by a change of intended use, substantial material changes should justify the documentation of the result as a new instance of E18 Physical Thing and not just the change of function. The latter may be documented as an extended activity (instance of E7 Activity) of using it.",
            "skos:notation": "E81",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc30",
            "rdfs:domain": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E81_Transformation"
            },
            "skos:notation": "pc30",
            "rdfs:label": {
                "@language": "en",
                "@value": "resulted in"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of E81 Transformation with an instance of CP1 Built Entity. It aims at documenting the result of transformation interventions which may involve either a building or a part of it."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc29",
            "rdfs:domain": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E81_Transformation"
            },
            "skos:notation": "pc29",
            "rdfs:label": {
                "@language": "en",
                "@value": "adopted"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property identifies the materials (CP9) adopted by (Pc30i) an instance of E81 Transformation.\nE81 Transformation necessarily adopts different materials. This property enables this to be documented"
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP9"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc28",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP23"
            },
            "skos:notation": "pc28",
            "rdfs:label": {
                "@language": "en",
                "@value": "requires to be repeated within"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of the class CP23 Maintenance with and instance of the class of E52 Timespan. It enables to document the timespan that it is foreseen to be observed between two consequent maintenance interventions (CP23). "
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E52_Time-Span"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "http://www.cidoc-crm.org/cidoc-crm/E52_Time-Span",
            "rdfs:label": {
                "@language": "en",
                "@value": "Time-Span"
            },
            "rdfs:comment": "This class comprises abstract temporal extents, in the sense of Galilean physics, having a beginning, an end and a duration. Instances of E52 Time-Span have no semantic connotations about phenomena happening within the temporal extent they represent. They do not convey any meaning other than a positioning on the “time-line” of chronology. The actual extent of an instance of E52 Time-Span can be approximated by properties of E52 Time-Span giving inner and outer bounds in the form of dates (instances of E61 Time Primitive). Comparing knowledge about time-spans is fundamental for chronological reasoning.Some instances of E52 Time-Span may be defined as the actual, in principle observable, temporal extent of instances of E2 Temporal Entity via the property P4 has time-span (is time-span of): E52 Time-Span. They constitute phenomenal time-spans as defined in CRMgeo (Doerr   Hiebel 2013). Since our knowledge of history is imperfect and physical phenomena are fuzzy in nature, the extent of phenomenal time-spans can only be described in approximation. An extreme case of approximation, might, for example, define an instance of E52 Time-Span having unknown beginning, end and duration. It may, nevertheless, be associated with other descriptions by which we can infer knowledge about it, such as in relative chronologies.Some instances of E52 may be defined precisely as representing a declaration of a temporal extent, as, for instance, done in a business contract. They constitute declarative time-spans as defined in CRMgeo (Doerr   Hiebel 2013) and can be described via the property E61 Time Primitive P170 defines time (time is defined by): E52 Time-Span. When used as a common E52 Time-Span for two events, it will nevertheless describe them as being simultaneous, even if nothing else is known.",
            "skos:notation": "E52",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc27",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP25"
            },
            "skos:notation": "pc27",
            "rdfs:label": {
                "@language": "en",
                "@value": "entails"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property documents that a conservation intervention (CP 25) has realised a modification (E11) on the building it has involved. It is useful to specify the kind of result obtained by the conservation intervention."
            },
            "rdfs:range": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E11_Modification"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc26",
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP33"
            },
            "skos:notation": "pc26",
            "rdfs:label": {
                "@language": "en",
                "@value": "is illustrated by"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property associates an instance of CP38 Architecture Representation Object with an instance of CP 33 Architecture Conservation Project and it allows to relate the conservation project to the different levels of representation, that may concern either alphanumeric documents as the project report, bill of quantities or graphic documents."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP38"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/pc25",
            "rdfs:subPropertyOf": [
                {
                    "@id": "http://www.cidoc-crm.org/cidoc-crm/P108_has_produced"
                },
                {
                    "@id": "http://www.cidoc-crm.org/cidoc-crm/P31_has_modified"
                }
            ],
            "rdfs:domain": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP25"
            },
            "skos:notation": "pc25",
            "rdfs:label": {
                "@language": "en",
                "@value": "occurs in"
            },
            "rdfs:comment": {
                "@language": "en",
                "@value": "This property identifies the building  (CP2 Architectural Work) on which the intervention s occurring at the moment of the documentation."
            },
            "rdfs:range": {
                "@id": "https://w3id.org/cpm-arch/cpm/CP1"
            },
            "@type": "rdf:Property"
        },
        {
            "@id": "http://www.cidoc-crm.org/cidoc-crm/E12_Production",
            "rdfs:label": {
                "@language": "en",
                "@value": "Production"
            },
            "rdfs:comment": "This class comprises activities that are designed to, and succeed in, creating one or more new items. It specializes the notion of modification into production. The decision as to whether or not an object is regarded as new is context sensitive. Normally, items are considered “new” if there is no obvious overall similarity between them and the consumed items and material used in their production. In other cases, an item is considered “new” because it becomes relevant to documentation by a modification. For example, the scribbling of a name on a potsherd may make it a voting token. The original potsherd may not be worth documenting, in contrast to the inscribed one. This entity can be collective: the printing of a thousand books, for example, would normally be considered a single event. An event should also be documented using an instance of E81 Transformation if it results in the destruction of one or more objects and the simultaneous production of others using parts or material from the originals. In this case, the new items have separate identities and matter is preserved, but identity is not.",
            "skos:notation": "E12",
            "@type": "rdfs:Class"
        },
        {
            "@id": "http://www.cidoc-crm.org/cidoc-crm/E92_Spacetime_Volume",
            "rdfs:label": {
                "@language": "en",
                "@value": "Spacetime Volume"
            },
            "rdfs:comment": "This class comprises 4-dimensional point sets (volumes) in physical spacetime (in contrast to mathematical models of it) regardless their true geometric forms. They may derive their identity from being the extent of a material phenomenon or from being the interpretation of an expression defining an extent in spacetime. Intersections of instances of E92 Spacetime Volume, E53 Place and E52 Time-Span are also regarded as instances of E92 Spacetime Volume. An instance of E92 Spacetime Volume is either contiguous or composed of a finite number of contiguous subsets. Its boundaries may be fuzzy due to the properties of the phenomena it derives from or due to the limited precision up to which defining expression can be identified with a real extent in spacetime. The duration of existence of an instance of E92 Spacetime Volume is its projection on time.",
            "skos:notation": "E92",
            "@type": "rdfs:Class"
        },
        {
            "@id": "http://www.cidoc-crm.org/cidoc-crm/E31_Document",
            "rdfs:label": {
                "@language": "en",
                "@value": "Document"
            },
            "rdfs:comment": "This class comprises identifiable immaterial items that make propositions about reality.These propositions may be expressed in text, graphics, images, audiograms, videograms or by other similar means. Documentation databases are regarded as instances of E31 Document. This class should not be confused with the concept “document” in Information Technology, which is compatible with E73 Information Object.",
            "skos:notation": "E31",
            "@type": "rdfs:Class"
        },
        {
            "@id": "http://www.cidoc-crm.org/cidoc-crm/E29_Design_or_Procedure",
            "rdfs:label": {
                "@language": "en",
                "@value": "Design or Procedure"
            },
            "rdfs:comment": "This class comprises documented plans for the execution of actions in order to achieve a result of a specific quality, form or contents. In particular, it comprises plans for deliberate human activities that may result in new instances of E71 Human-Made Thing or for shaping or guiding the execution of an instance of E7 Activity.Instances of E29 Design or Procedure can be structured in parts and sequences or depend on others.This is modelled using P69 has association with (is associated with): E29 Design or Procedure.Designs or procedures can be seen as one of the followingA schema for the activities it describesA schema of the products that result from their application.An independent intellectual product that may have never been applied, such as Leonardo da Vinci’s famous plans for flying machines.Because designs or procedures may never be applied or only partially executed, the CIDOC CRM models a loose relationship between the plan and the respective product.",
            "skos:notation": "E29",
            "@type": "rdfs:Class"
        },
        {
            "@id": "http://www.cidoc-crm.org/cidoc-crm/E27_Site",
            "rdfs:label": {
                "@language": "en",
                "@value": "Site"
            },
            "rdfs:comment": "This class comprises pieces of land or sea floor. In contrast to the purely geometric notion of E53 Place, this class describes constellations of matter on the surface of the Earth or other celestial body, which can be represented by photographs, paintings and maps.Instances of E27 Site are composed of relatively immobile material items and features in a particular configuration at a particular location. ",
            "skos:notation": "E27",
            "@type": "rdfs:Class"
        },
        {
            "@id": "http://www.cidoc-crm.org/cidoc-crm/E19_Physical_Object",
            "rdfs:label": {
                "@language": "en",
                "@value": "Physical Object"
            },
            "rdfs:comment": "This class comprises items of a material nature that are units for documentation and have physical boundaries that separate them completely in an objective way from other objects. The class also includes all aggregates of objects made for functional purposes of whatever kind, independent of physical coherence, such as a set of chessmen. Typically, instances of E19 Physical Object can be moved (if not too heavy).In some contexts, such objects, except for aggregates, are also called “bona fide objects” (Smith   Varzi, 2000, pp.401-420), i.e., naturally defined objects. The decision as to what is documented as a complete item, rather than by its parts or components, may be a purely administrative decision or may be a result of the order in which the item was acquired.",
            "skos:notation": "E19",
            "@type": "rdfs:Class"
        },
        {
            "@id": "http://www.cidoc-crm.org/cidoc-crm/E14_Condition_Assessment",
            "rdfs:label": {
                "@language": "en",
                "@value": "Condition Assessment"
            },
            "rdfs:comment": "This class describes the act of assessing the state of preservation of an object during a particular period. The condition assessment may be carried out by inspection, measurement or through historical research. This class is used to document circumstances of the respective assessment that may be relevant to interpret its quality at a later stage, or to continue research on related documents. ",
            "skos:notation": "E14",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP39",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E55_Type"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Architecture Alpha-Numeric Representation Type"
            },
            "rdfs:comment": "This class is a specialization of E55 Type and comprises the concepts of architecture that can be expressed by written and/or numerical elaboration. Instances of CP41 Architectural Alpha-Numeric Representation can be written reports, calculation reports, sheets and tables. ",
            "skos:notation": "CP39",
            "@type": "rdfs:Class"
        },
        {
            "@id": "https://w3id.org/cpm-arch/cpm/CP37",
            "rdfs:subClassOf": {
                "@id": "http://www.cidoc-crm.org/cidoc-crm/E55_Type"
            },
            "rdfs:label": {
                "@language": "en",
                "@value": "Architecture Graphic Representation Type"
            },
            "rdfs:comment": " This class is a specialization of E55 Type and comprises the concepts of architectural representation. Instances of CP37 Architecture Graphic Representation Type can be orthophotos, 3D models, orthographic projections. ",
            "skos:notation": "CP37",
            "@type": "rdfs:Class"
        }
    ],
    "@context": {
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "owl": "http://www.w3.org/2002/07/owl#",
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "swrl": "http://www.w3.org/2003/11/swrl#",
        "swrlb": "http://www.w3.org/2003/11/swrlb#",
        "skos": "http://www.w3.org/2004/02/skos/core#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#"
    }
}
