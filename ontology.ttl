@prefix : <https://w3id.org/cpm-arch/cpm#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/cpm-arch/cpm#> .

<https://w3id.org/cpm-arch/cpm> rdf:type owl:Ontology ;
                                 owl:imports <http://www.cidoc-crm.org/cidoc-crm/> ,
                                             <http://www.cidoc-crm.org/extensions/crminf/> ,
                                             <http://www.cidoc-crm.org/extensions/crmsci/> .

#################################################################
#    Annotation properties
#################################################################

###  http://www.w3.org/2004/02/skos/core#notation
<http://www.w3.org/2004/02/skos/core#notation> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/cpm-arch/cpm/Pc10_belongs_to
<https://w3id.org/cpm-arch/cpm/Pc10_belongs_to> rdf:type owl:ObjectProperty ;
                                                owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc10i_owns> ;
                                                rdfs:domain <https://w3id.org/cpm-arch/cpm/CP2_Architecture_Work> ;
                                                rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E39_Actor> ;
                                                rdfs:comment "This property documents that an instance of CP2 Architectural Work belongs to an instance of E39 Actor." ;
                                                rdfs:label "belongs to" ;
                                                <http://www.w3.org/2004/02/skos/core#notation> "Pc10" .


###  https://w3id.org/cpm-arch/cpm/Pc10i_owns
<https://w3id.org/cpm-arch/cpm/Pc10i_owns> rdf:type owl:ObjectProperty ;
                                           rdfs:domain <http://www.cidoc-crm.org/cidoc-crm/E39_Actor> ;
                                           rdfs:range <https://w3id.org/cpm-arch/cpm/CP2_Architecture_Work> ;
                                           rdfs:label "owns" ;
                                           <http://www.w3.org/2004/02/skos/core#notation> "Pc10i" .


###  https://w3id.org/cpm-arch/cpm/Pc11_is_bounded_by
<https://w3id.org/cpm-arch/cpm/Pc11_is_bounded_by> rdf:type owl:ObjectProperty ;
                                                   owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc11i_bounds> ;
                                                   rdfs:domain <https://w3id.org/cpm-arch/cpm/CP16_Urban_Area> ;
                                                   rdfs:range <https://w3id.org/cpm-arch/cpm/CP14_Urban_Unit_Front> ;
                                                   rdfs:comment "This property documents that an instance of CP 16 Urban Area is bounded by (Pc11) an instance of CP 14 Urban Unit Front. The property intends to describe the boundaries of an urban area in the cases in which they are constituted by the façades of the buildings. Particularly the property intends to describe not only the geometrical perimeter but the elevations that characterize the area." ;
                                                   rdfs:label "is bounded by" ;
                                                   <http://www.w3.org/2004/02/skos/core#notation> "Pc11" .


###  https://w3id.org/cpm-arch/cpm/Pc11i_bounds
<https://w3id.org/cpm-arch/cpm/Pc11i_bounds> rdf:type owl:ObjectProperty ;
                                             rdfs:domain <https://w3id.org/cpm-arch/cpm/CP14_Urban_Unit_Front> ;
                                             rdfs:range <https://w3id.org/cpm-arch/cpm/CP16_Urban_Area> ;
                                             rdfs:label "bounds" ;
                                             <http://www.w3.org/2004/02/skos/core#notation> "Pc11i" .


###  https://w3id.org/cpm-arch/cpm/Pc12_is_related_to_public_area_through
<https://w3id.org/cpm-arch/cpm/Pc12_is_related_to_public_area_through> rdf:type owl:ObjectProperty ;
                                                                       rdfs:domain <https://w3id.org/cpm-arch/cpm/CP10_Building_Unit> ;
                                                                       rdfs:range <https://w3id.org/cpm-arch/cpm/CP11_Building_Front> ;
                                                                       rdfs:comment "This class includes instances of coherent architectural organisms populating an urban historical setting. It consists in a single construction phase or by the merging/recasting of several pre-existing building units. This kind of organism is characterized by the presence of one or more functional units (residential and non-residential) connected to each other through common distribution elements and served by access at the road level; it is bordered by external facades with a generally continuous eaves line and a unitary or composite roof composed of flat and/or inclined parts consistent with all fronts (Acierno, Fiorani, Velios 2021). Instances of CP10 Building Unit differ from instances of CP2 Architectural Work for being related to an edifice that is considered a component of an urban historical setting. Meaning that instances of CP10 Building Unit are buildings which are components of an urban tissue, where the main characteristics are the relationships established among them." ;
                                                                       rdfs:label "is related to public area through" ;
                                                                       <http://www.w3.org/2004/02/skos/core#notation> "Pc12" .


###  https://w3id.org/cpm-arch/cpm/Pc12i_allows_the_relationship_to_the_public_area_of
<https://w3id.org/cpm-arch/cpm/Pc12i_allows_the_relationship_to_the_public_area_of> rdf:type owl:ObjectProperty ;
                                                                                    owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc12_is_related_to_public_area_through> ;
                                                                                    rdfs:domain <https://w3id.org/cpm-arch/cpm/CP11_Building_Front> ;
                                                                                    rdfs:range <https://w3id.org/cpm-arch/cpm/CP10_Building_Unit> ;
                                                                                    rdfs:label "allows the relationship to the public area of" ;
                                                                                    <http://www.w3.org/2004/02/skos/core#notation> "Pc12i" .


###  https://w3id.org/cpm-arch/cpm/Pc13_is_regulated_by
<https://w3id.org/cpm-arch/cpm/Pc13_is_regulated_by> rdf:type owl:ObjectProperty ;
                                                     rdfs:domain <https://w3id.org/cpm-arch/cpm/CP2_Architecture_Work> ;
                                                     rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E32_Authority_Document> ;
                                                     rdfs:comment "This property documents that an instance of CP2 Architectural Work is regulated from the legislative point of view by an instance of E32 Authority document, in the sense that every action performed on the object must follow the prescriptions expressed in the document. The authority document may be a monumental constraint, an urban planning tool etc. " ;
                                                     rdfs:label "is regulated by" ;
                                                     <http://www.w3.org/2004/02/skos/core#notation> "Pc13" .


###  https://w3id.org/cpm-arch/cpm/Pc13i_regulates
<https://w3id.org/cpm-arch/cpm/Pc13i_regulates> rdf:type owl:ObjectProperty ;
                                                owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc13_is_regulated_by> ;
                                                rdfs:domain <http://www.cidoc-crm.org/cidoc-crm/E32_Authority_Document> ;
                                                rdfs:range <https://w3id.org/cpm-arch/cpm/CP2_Architecture_Work> ;
                                                rdfs:label "regulates" ;
                                                <http://www.w3.org/2004/02/skos/core#notation> "Pc13i" .


###  https://w3id.org/cpm-arch/cpm/Pc14_is_regulated_by
<https://w3id.org/cpm-arch/cpm/Pc14_is_regulated_by> rdf:type owl:ObjectProperty ;
                                                     owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc14i_regulates> ;
                                                     rdfs:domain <https://w3id.org/cpm-arch/cpm/CP18_Space_Entity> ;
                                                     rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E32_Authority_Document> ;
                                                     rdfs:comment "This property documents that an instance of CP18 Space Entity is protected from the legislative point of view by an instance of E32 Authority document, in the sense that every action performed on the instance considered must follow the prescriptions expressed in the document. The authority document may be a monumental constraint, an urban planning tool etc." ;
                                                     rdfs:label "is regulated by" ;
                                                     <http://www.w3.org/2004/02/skos/core#notation> "Pc14" .


###  https://w3id.org/cpm-arch/cpm/Pc14i_regulates
<https://w3id.org/cpm-arch/cpm/Pc14i_regulates> rdf:type owl:ObjectProperty ;
                                                rdfs:domain <http://www.cidoc-crm.org/cidoc-crm/E32_Authority_Document> ;
                                                rdfs:range <https://w3id.org/cpm-arch/cpm/CP18_Space_Entity> ;
                                                rdfs:label "regulates" ;
                                                <http://www.w3.org/2004/02/skos/core#notation> "Pc14i" .


###  https://w3id.org/cpm-arch/cpm/Pc15_shows_plan_configuration_type
<https://w3id.org/cpm-arch/cpm/Pc15_shows_plan_configuration_type> rdf:type owl:ObjectProperty ;
                                                                   rdfs:domain <https://w3id.org/cpm-arch/cpm/CP10_Building_Unit> ;
                                                                   rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E55_Type> ;
                                                                   rdfs:comment "This property documents that an instance of CP2 Architectural Work shows plan configuration type expressed by an instance of the class E55 Type." ;
                                                                   rdfs:label "shows plan configuration type" ;
                                                                   <http://www.w3.org/2004/02/skos/core#notation> "Pc15" .


###  https://w3id.org/cpm-arch/cpm/Pc15i_is_configuration_type_of
<https://w3id.org/cpm-arch/cpm/Pc15i_is_configuration_type_of> rdf:type owl:ObjectProperty ;
                                                               owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc15_shows_plan_configuration_type> ;
                                                               rdfs:domain <http://www.cidoc-crm.org/cidoc-crm/E55_Type> ;
                                                               rdfs:range <https://w3id.org/cpm-arch/cpm/CP10_Building_Unit> ;
                                                               rdfs:label "is configuration type of" ;
                                                               <http://www.w3.org/2004/02/skos/core#notation> "Pc15i" .


###  https://w3id.org/cpm-arch/cpm/Pc16_shows_structural_system
<https://w3id.org/cpm-arch/cpm/Pc16_shows_structural_system> rdf:type owl:ObjectProperty .


###  https://w3id.org/cpm-arch/cpm/Pc16_shows_structural_system_type
<https://w3id.org/cpm-arch/cpm/Pc16_shows_structural_system_type> rdf:type owl:ObjectProperty ;
                                                                  owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc16i_structural_system_of> ;
                                                                  rdfs:domain <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                                  rdfs:range <https://w3id.org/cpm-arch/cpm/CP35_Building-Formal_Type> ;
                                                                  rdfs:comment "This property associates an instance of CP35 Building Formal Type with an instance of CP1 Built Entity. It allows to describe the structural system of a building relating it to a thesaurus that gathers both formal, constructive and structural features." ;
                                                                  rdfs:label "shows structural system" ;
                                                                  <http://www.w3.org/2004/02/skos/core#notation> "Pc16" .


###  https://w3id.org/cpm-arch/cpm/Pc16i_structural_system_of
<https://w3id.org/cpm-arch/cpm/Pc16i_structural_system_of> rdf:type owl:ObjectProperty ;
                                                           owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc16_shows_structural_system> ;
                                                           rdfs:domain <https://w3id.org/cpm-arch/cpm/CP35_Building-Formal_Type> ;
                                                           rdfs:range <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                           rdfs:label "is structural system of" ;
                                                           <http://www.w3.org/2004/02/skos/core#notation> "Pc16i" .


###  https://w3id.org/cpm-arch/cpm/Pc17_has_performance_efficiency_documented_in
<https://w3id.org/cpm-arch/cpm/Pc17_has_performance_efficiency_documented_in> rdf:type owl:ObjectProperty ;
                                                                              rdfs:domain <https://w3id.org/cpm-arch/cpm/CP2_Architecture_Work> ;
                                                                              rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E73_Information_Object> ;
                                                                              rdfs:comment "This property associates an instance of CP2 Architecture work with an E73 Information Object documenting specifically performance efficiency. This can be required in several different domains as accessibility, sustainability, or plants efficiency." ;
                                                                              rdfs:label "has performance efficiency documented in" ;
                                                                              <http://www.w3.org/2004/02/skos/core#notation> "Pc17" .


###  https://w3id.org/cpm-arch/cpm/Pc17i_documents_performance_efficiency_of
<https://w3id.org/cpm-arch/cpm/Pc17i_documents_performance_efficiency_of> rdf:type owl:ObjectProperty ;
                                                                          owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc17_has_performance_efficiency_documented_in> ;
                                                                          rdfs:domain <http://www.cidoc-crm.org/cidoc-crm/E73_Information_Object> ;
                                                                          rdfs:range <https://w3id.org/cpm-arch/cpm/CP2_Architecture_Work> ;
                                                                          rdfs:label "documents performance efficiency of" ;
                                                                          <http://www.w3.org/2004/02/skos/core#notation> "Pc17i" .


###  https://w3id.org/cpm-arch/cpm/Pc18_has_physical_relation_with
<https://w3id.org/cpm-arch/cpm/Pc18_has_physical_relation_with> rdf:type owl:ObjectProperty ;
                                                                rdfs:domain <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                                rdfs:range <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                                rdfs:comment "This property associates an instance of CP1 Built Entity with another instance of CP1 Built Entity documenting the physical relation existing between them. This property allows to describe the constructive layering shown by a building or a part of it. It is generally completed by a property type which specifies the kind of relation. If, for example, a wall has a physical relation with another wall beeing built on it or filling one of its windows." ;
                                                                rdfs:label "has physical relation with" ;
                                                                <http://www.w3.org/2004/02/skos/core#notation> "Pc18" .


###  https://w3id.org/cpm-arch/cpm/Pc19_shows_masonry_feature
<https://w3id.org/cpm-arch/cpm/Pc19_shows_masonry_feature> rdf:type owl:ObjectProperty ;
                                                           rdfs:domain <https://w3id.org/cpm-arch/cpm/CP5_Construction_Element_Plural> ;
                                                           rdfs:range <https://w3id.org/cpm-arch/cpm/CP28_Building_Feature> ;
                                                           rdfs:comment "This property documents that an instance CP5 Constructive Element Plural Shows masonry features specified by an instance of CP28 Building Feature." ;
                                                           rdfs:label "shows masonry feature" ;
                                                           <http://www.w3.org/2004/02/skos/core#notation> "Pc19" .


###  https://w3id.org/cpm-arch/cpm/Pc19i_masonry_feature_is_shown_in
<https://w3id.org/cpm-arch/cpm/Pc19i_masonry_feature_is_shown_in> rdf:type owl:ObjectProperty ;
                                                                  owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc19_shows_masonry_feature> ;
                                                                  rdfs:domain <https://w3id.org/cpm-arch/cpm/CP28_Building_Feature> ;
                                                                  rdfs:range <https://w3id.org/cpm-arch/cpm/CP5_Construction_Element_Plural> ;
                                                                  rdfs:label "masonry feature is shown in" ;
                                                                  <http://www.w3.org/2004/02/skos/core#notation> "Pc19i" .


###  https://w3id.org/cpm-arch/cpm/Pc1_affects
<https://w3id.org/cpm-arch/cpm/Pc1_affects> rdf:type owl:ObjectProperty ;
                                            rdfs:domain <https://w3id.org/cpm-arch/cpm/CP41_Environmental_Observable_Entity> ;
                                            rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E1_CRM_Entity> ;
                                            rdfs:comment "This property documents that an instance of CP41 Environmental Observable Entity affects an instance of class E1 Entity. This property may be used to describe the fact that external factors that can be observed through visual analysis or by the means of special instruments are affecting a whichever instance of E1 Entity. It has been conceived to describe the action of natural phenomenon such as winds, temperature, atmospheric agents on, either, man-made items, as architecture, or natural elements, as caves or cliffs. Man made items may refer to very heterogenous elements spreading from urban areas to singular building component" ;
                                            rdfs:label "affects" ;
                                            <http://www.w3.org/2004/02/skos/core#notation> "Pc1" .


###  https://w3id.org/cpm-arch/cpm/Pc1i_is_subject_to
<https://w3id.org/cpm-arch/cpm/Pc1i_is_subject_to> rdf:type owl:ObjectProperty ;
                                                   owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc1_affects> ;
                                                   rdfs:domain <http://www.cidoc-crm.org/cidoc-crm/E1_CRM_Entity> ;
                                                   rdfs:range <https://w3id.org/cpm-arch/cpm/CP41_Environmental_Observable_Entity> ;
                                                   rdfs:label "is subject to" ;
                                                   <http://www.w3.org/2004/02/skos/core#notation> "Pc1i" .


###  https://w3id.org/cpm-arch/cpm/Pc20_shows_building_homogeneity_with
<https://w3id.org/cpm-arch/cpm/Pc20_shows_building_homogeneity_with> rdf:type owl:ObjectProperty ;
                                                                     rdfs:domain <https://w3id.org/cpm-arch/cpm/CP2_Architecture_Work> ;
                                                                     rdfs:range <https://w3id.org/cpm-arch/cpm/CP2_Architecture_Work> ;
                                                                     rdfs:comment "This property documents that an instance CP2 Architectural Work shows building homogeneity with another instance of CP2 Architectural Work." ;
                                                                     rdfs:label "shows building homogeneity with" ;
                                                                     <http://www.w3.org/2004/02/skos/core#notation> "Pc20" .


###  https://w3id.org/cpm-arch/cpm/Pc20i_symmetrical
<https://w3id.org/cpm-arch/cpm/Pc20i_symmetrical> rdf:type owl:ObjectProperty ;
                                                  owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc20_shows_building_homogeneity_with> ;
                                                  rdfs:domain <https://w3id.org/cpm-arch/cpm/CP2_Architecture_Work> ;
                                                  rdfs:range <https://w3id.org/cpm-arch/cpm/CP2_Architecture_Work> ;
                                                  rdfs:label "symmetrical" ;
                                                  <http://www.w3.org/2004/02/skos/core#notation> "Pc20i" .


###  https://w3id.org/cpm-arch/cpm/Pc21_addressed
<https://w3id.org/cpm-arch/cpm/Pc21_addressed> rdf:type owl:ObjectProperty ;
                                               rdfs:domain <https://w3id.org/cpm-arch/cpm/CP49_Urban_Plan> ;
                                               rdfs:range <https://w3id.org/cpm-arch/cpm/CP45_Architecture_Project> ;
                                               rdfs:comment "This property documents that an instance CP 49 Urban Plan Addressed an instance of CP45 Architecture project. It intends to describe the relation that exists between an urban plan and an architecture project that is normally subdued to the former and conceived within the framework that the urban plan describes." ;
                                               rdfs:label "addressed" ;
                                               <http://www.w3.org/2004/02/skos/core#notation> "Pc21" .


###  https://w3id.org/cpm-arch/cpm/Pc21i_was_addressed_by
<https://w3id.org/cpm-arch/cpm/Pc21i_was_addressed_by> rdf:type owl:ObjectProperty ;
                                                       owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc21_addressed> ;
                                                       rdfs:domain <https://w3id.org/cpm-arch/cpm/CP45_Architecture_Project> ;
                                                       rdfs:range <https://w3id.org/cpm-arch/cpm/CP49_Urban_Plan> ;
                                                       rdfs:comment "This property documents that an instance CP 49 Urban Plan Addressed an instance of CP45 Architecture project. It intends to describe the relation that exists between an urban plan and an architecture project that is normally subdued to the former and conceived within the framework that the urban plan describes." ;
                                                       rdfs:label "was addressed by" ;
                                                       <http://www.w3.org/2004/02/skos/core#notation> "Pc21i" .


###  https://w3id.org/cpm-arch/cpm/Pc22_shows_building-formal_type
<https://w3id.org/cpm-arch/cpm/Pc22_shows_building-formal_type> rdf:type owl:ObjectProperty ;
                                                                owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc22i_building-formal_type_is_shown_on> ;
                                                                rdfs:domain <https://w3id.org/cpm-arch/cpm/CP2_Architecture_Work> ;
                                                                rdfs:range <https://w3id.org/cpm-arch/cpm/CP35_Building-Formal_Type> ;
                                                                rdfs:comment "This property documents that an instance CP2 Architectural Work shows a particular typology. This may be further specified whether the information concerns its distribution or its structural system (eg. continuous, punctual)." ;
                                                                rdfs:label "shows building-formal type" ;
                                                                <http://www.w3.org/2004/02/skos/core#notation> "Pc22" .


###  https://w3id.org/cpm-arch/cpm/Pc22i_building-formal_type_is_shown_on
<https://w3id.org/cpm-arch/cpm/Pc22i_building-formal_type_is_shown_on> rdf:type owl:ObjectProperty ;
                                                                       rdfs:domain <https://w3id.org/cpm-arch/cpm/CP35_Building-Formal_Type> ;
                                                                       rdfs:range <https://w3id.org/cpm-arch/cpm/CP2_Architecture_Work> ;
                                                                       rdfs:label "building-formal type is shown on" ;
                                                                       <http://www.w3.org/2004/02/skos/core#notation> "Pc22i" .


###  https://w3id.org/cpm-arch/cpm/Pc23_made_use_of
<https://w3id.org/cpm-arch/cpm/Pc23_made_use_of> rdf:type owl:ObjectProperty ;
                                                 owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc23i_used> ;
                                                 rdfs:domain <http://www.cidoc-crm.org/cidoc-crm/E11_Modification> ;
                                                 rdfs:range <https://w3id.org/cpm-arch/cpm/CP9_Building_Material> ;
                                                 rdfs:comment """This property identifies an instance of CP9 Building material used by an instance of E11 Modification.
E11 Modification commonly foresees the use of particular instances of S10 Material substantial. The modification realized to consolidate lime mortars, for example, requires ethyl silicate. This property enables this to be documented.""" ;
                                                 rdfs:label "made use of" ;
                                                 <http://www.w3.org/2004/02/skos/core#notation> "Pc23" .


###  https://w3id.org/cpm-arch/cpm/Pc23i_used
<https://w3id.org/cpm-arch/cpm/Pc23i_used> rdf:type owl:ObjectProperty ;
                                           rdfs:domain <https://w3id.org/cpm-arch/cpm/CP9_Building_Material> ;
                                           rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E11_Modification> ;
                                           rdfs:label "used" ;
                                           <http://www.w3.org/2004/02/skos/core#notation> "Pc23i" .


###  https://w3id.org/cpm-arch/cpm/Pc24_occurred_in
<https://w3id.org/cpm-arch/cpm/Pc24_occurred_in> rdf:type owl:ObjectProperty ;
                                                 owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc24i_was_subdued_to> ;
                                                 rdfs:domain <https://w3id.org/cpm-arch/cpm/CP25_Conservation_Intervention> ;
                                                 rdfs:range <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                 rdfs:comment "This property identifies the result (CP1 Bult Entity) of an instance CP25 Conservation Intervention. This property enables the documentation of the outcome of a conservation intervention. Conservation intervention realized in a building may also entail the modification of some features such as its internal distribution, the shape of some of its components (windows, roof etc.), its function, without modifying its identity and with the aim of preserving it for the future." ;
                                                 rdfs:label "occurred in" ;
                                                 <http://www.w3.org/2004/02/skos/core#notation> "Pc24" .


###  https://w3id.org/cpm-arch/cpm/Pc24i_was_subdued_to
<https://w3id.org/cpm-arch/cpm/Pc24i_was_subdued_to> rdf:type owl:ObjectProperty ;
                                                     rdfs:domain <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                     rdfs:range <https://w3id.org/cpm-arch/cpm/CP25_Conservation_Intervention> ;
                                                     rdfs:label "was subdued to" ;
                                                     <http://www.w3.org/2004/02/skos/core#notation> "Pc24i" .


###  https://w3id.org/cpm-arch/cpm/Pc25_occurs_in
<https://w3id.org/cpm-arch/cpm/Pc25_occurs_in> rdf:type owl:ObjectProperty ;
                                               rdfs:domain <https://w3id.org/cpm-arch/cpm/CP25_Conservation_Intervention> ;
                                               rdfs:range <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                               rdfs:comment "This property identifies the building (CP2 Architectural Work) on which the intervention s occurring at the moment of the documentation." ;
                                               rdfs:label "occurs in" ;
                                               <http://www.w3.org/2004/02/skos/core#notation> "Pc25" .


###  https://w3id.org/cpm-arch/cpm/Pc25i_is_subdued_to
<https://w3id.org/cpm-arch/cpm/Pc25i_is_subdued_to> rdf:type owl:ObjectProperty ;
                                                    owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc25_occurs_in> ;
                                                    rdfs:domain <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                    rdfs:range <https://w3id.org/cpm-arch/cpm/CP25_Conservation_Intervention> ;
                                                    rdfs:label "is subdued to" ;
                                                    <http://www.w3.org/2004/02/skos/core#notation> "Pc25i" .


###  https://w3id.org/cpm-arch/cpm/Pc26_is_illustrated_by
<https://w3id.org/cpm-arch/cpm/Pc26_is_illustrated_by> rdf:type owl:ObjectProperty ;
                                                       owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc26i_illustrates> ;
                                                       rdfs:domain <https://w3id.org/cpm-arch/cpm/CP33_Architecture_Conservation_Project> ;
                                                       rdfs:range <https://w3id.org/cpm-arch/cpm/CP33_Architecture_Conservation_Project> ;
                                                       rdfs:comment "This property associates an instance of CP38 Architecture Representation Object with an instance of CP 33 Architecture Conservation Project and it allows to relate the conservation project to the different levels of representation, that may concern either alphanumeric documents as the project report, bill of quantities or graphic documents." ;
                                                       rdfs:label "is illustrated by" ;
                                                       <http://www.w3.org/2004/02/skos/core#notation> "Pc26" .


###  https://w3id.org/cpm-arch/cpm/Pc26i_illustrates
<https://w3id.org/cpm-arch/cpm/Pc26i_illustrates> rdf:type owl:ObjectProperty ;
                                                  rdfs:domain <https://w3id.org/cpm-arch/cpm/CP33_Architecture_Conservation_Project> ;
                                                  rdfs:range <https://w3id.org/cpm-arch/cpm/CP33_Architecture_Conservation_Project> ;
                                                  rdfs:label "illustrates" ;
                                                  <http://www.w3.org/2004/02/skos/core#notation> "Pc26i" .


###  https://w3id.org/cpm-arch/cpm/Pc27_entails
<https://w3id.org/cpm-arch/cpm/Pc27_entails> rdf:type owl:ObjectProperty ;
                                             rdfs:domain <https://w3id.org/cpm-arch/cpm/CP25_Conservation_Intervention> ;
                                             rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E11_Modification> ;
                                             rdfs:comment "This property documents that a conservation intervention (CP25) has realised a modification (E11) on the building it has involved. It is useful to specify the kind of result obtained by the conservation intervention." ;
                                             rdfs:label "entails" ;
                                             <http://www.w3.org/2004/02/skos/core#notation> "Pc27" .


###  https://w3id.org/cpm-arch/cpm/Pc27i_is_entailed_by
<https://w3id.org/cpm-arch/cpm/Pc27i_is_entailed_by> rdf:type owl:ObjectProperty ;
                                                     owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc27_entails> ;
                                                     rdfs:domain <http://www.cidoc-crm.org/cidoc-crm/E11_Modification> ;
                                                     rdfs:range <https://w3id.org/cpm-arch/cpm/CP25_Conservation_Intervention> ;
                                                     rdfs:label "is entailed by" ;
                                                     <http://www.w3.org/2004/02/skos/core#notation> "Pc27i" .


###  https://w3id.org/cpm-arch/cpm/Pc28_requires_to_be_repeated_within
<https://w3id.org/cpm-arch/cpm/Pc28_requires_to_be_repeated_within> rdf:type owl:ObjectProperty ;
                                                                    rdfs:domain <https://w3id.org/cpm-arch/cpm/CP23_Maintenance> ;
                                                                    rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E52_Time-Span> ;
                                                                    rdfs:comment "This property associates an instance of the class CP23 Maintenance with and instance of the class of E52 Timespan. It enables to document the timespan that it is foreseen to be observed between two consequent maintenance interventions (CP23)." ;
                                                                    rdfs:label "requires to be repeated within" ;
                                                                    <http://www.w3.org/2004/02/skos/core#notation> "Pc28" .


###  https://w3id.org/cpm-arch/cpm/Pc29_adopted
<https://w3id.org/cpm-arch/cpm/Pc29_adopted> rdf:type owl:ObjectProperty ;
                                             rdfs:domain <http://www.cidoc-crm.org/cidoc-crm/E81_Transformation> ;
                                             rdfs:range <https://w3id.org/cpm-arch/cpm/CP9_Building_Material> ;
                                             rdfs:comment """This property identifies the materials (CP9) adopted by (Pc30i) an instance of E81 Transformation.
E81 Transformation necessarily adopts different materials. This property enables this to be documented.""" ;
                                             rdfs:label "adopted" ;
                                             <http://www.w3.org/2004/02/skos/core#notation> "Pc29" .


###  https://w3id.org/cpm-arch/cpm/Pc29i_was_adopted_by
<https://w3id.org/cpm-arch/cpm/Pc29i_was_adopted_by> rdf:type owl:ObjectProperty ;
                                                     owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc29_adopted> ;
                                                     rdfs:domain <https://w3id.org/cpm-arch/cpm/CP9_Building_Material> ;
                                                     rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E81_Transformation> ;
                                                     rdfs:label "was adopted by" ;
                                                     <http://www.w3.org/2004/02/skos/core#notation> "Pc29i" .


###  https://w3id.org/cpm-arch/cpm/Pc2_has_as_general_vocation
<https://w3id.org/cpm-arch/cpm/Pc2_has_as_general_vocation> rdf:type owl:ObjectProperty ;
                                                            rdfs:domain <https://w3id.org/cpm-arch/cpm/CP18_Space_Entity> ;
                                                            rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E7_Activity> ;
                                                            rdfs:comment "This property documents that an instance of E7 Activity is mainly performed within an instance of CP18 Space Entity. The property allows the description of the functional vocation of activity mainly performed in an architectural (CP20 Spatial Unit or CP22 Space Component) or urban space (CP19 Historic Centre or CP 20 Space Ensemble), that are subclasses of CP18 Space Entity. This property is mainly referring to conditions revealed by economic and statistical surveys. As an example, this property may describe the agricultural vocation of a village or the specific productive activity (industry, fishing, handycrafts etc.) of an historic centre or the religious vocation of a district." ;
                                                            rdfs:label "has as general vocation" ;
                                                            <http://www.w3.org/2004/02/skos/core#notation> "Pc2" .


###  https://w3id.org/cpm-arch/cpm/Pc2i_is_the_general_vocation_of
<https://w3id.org/cpm-arch/cpm/Pc2i_is_the_general_vocation_of> rdf:type owl:ObjectProperty ;
                                                                owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc2_has_as_general_vocation> ;
                                                                rdfs:domain <http://www.cidoc-crm.org/cidoc-crm/E7_Activity> ;
                                                                rdfs:range <https://w3id.org/cpm-arch/cpm/CP18_Space_Entity> ;
                                                                rdfs:comment "" ;
                                                                rdfs:label "is the general vocation of" ;
                                                                <http://www.w3.org/2004/02/skos/core#notation> "Pc2i" .


###  https://w3id.org/cpm-arch/cpm/Pc30_resulted_in
<https://w3id.org/cpm-arch/cpm/Pc30_resulted_in> rdf:type owl:ObjectProperty ;
                                                 owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc30i_resulted_from> ;
                                                 rdfs:domain <http://www.cidoc-crm.org/cidoc-crm/E81_Transformation> ;
                                                 rdfs:range <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                 rdfs:comment "This property associates an instance of E81 Transformation with an instance of CP1 Built Entity. It aims at documenting the result of transformation interventions which may involve either a building or a part of it." ;
                                                 rdfs:label "resulted in" ;
                                                 <http://www.w3.org/2004/02/skos/core#notation> "Pc30" .


###  https://w3id.org/cpm-arch/cpm/Pc30i_resulted_from
<https://w3id.org/cpm-arch/cpm/Pc30i_resulted_from> rdf:type owl:ObjectProperty ;
                                                    rdfs:domain <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                    rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E81_Transformation> ;
                                                    rdfs:label "resulted from" ;
                                                    <http://www.w3.org/2004/02/skos/core#notation> "Pc30i" .


###  https://w3id.org/cpm-arch/cpm/Pc31_transformed
<https://w3id.org/cpm-arch/cpm/Pc31_transformed> rdf:type owl:ObjectProperty ;
                                                 owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc31i_was_transformed_by> ;
                                                 rdfs:domain <http://www.cidoc-crm.org/cidoc-crm/E81_Transformation> ;
                                                 rdfs:range <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                 rdfs:comment "This property associates an instance of E81 Transformation with an instance of CP1 Buit Entity. It allows to describe all the interventions occurred on a building or part of it that have modified its identity." ;
                                                 rdfs:label "transformed" ;
                                                 <http://www.w3.org/2004/02/skos/core#notation> "Pc31" .


###  https://w3id.org/cpm-arch/cpm/Pc31i_was_transformed_by
<https://w3id.org/cpm-arch/cpm/Pc31i_was_transformed_by> rdf:type owl:ObjectProperty ;
                                                         rdfs:domain <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                         rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E81_Transformation> ;
                                                         rdfs:label "was transformed by" ;
                                                         <http://www.w3.org/2004/02/skos/core#notation> "Pc31i" .


###  https://w3id.org/cpm-arch/cpm/Pc32_provided_as_output
<https://w3id.org/cpm-arch/cpm/Pc32_provided_as_output> rdf:type owl:ObjectProperty ;
                                                        owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc32i_was_output_for> ;
                                                        rdfs:domain <https://w3id.org/cpm-arch/cpm/CP32_Architecture_Features_Assessment> ;
                                                        rdfs:range <https://w3id.org/cpm-arch/cpm/CP27_Architecture_Analysis_Output> ;
                                                        rdfs:comment "This property associates an instance of CP32 Architecture Features assessment with an instance of CP27 Architecture Analysis Output. The outputs of the architectural analysis result from inferences as the assessments that orient the conservation project are not only based on data collection but require reasoning taking into account the architectural features of the building or the documentary sources existing on it. Inferences elaborated from the observation of architectural features provide as output the result of the architectural analysis." ;
                                                        rdfs:label "provided as output" ;
                                                        <http://www.w3.org/2004/02/skos/core#notation> "Pc32" .


###  https://w3id.org/cpm-arch/cpm/Pc32i_was_output_for
<https://w3id.org/cpm-arch/cpm/Pc32i_was_output_for> rdf:type owl:ObjectProperty ;
                                                     rdfs:domain <https://w3id.org/cpm-arch/cpm/CP27_Architecture_Analysis_Output> ;
                                                     rdfs:range <https://w3id.org/cpm-arch/cpm/CP32_Architecture_Features_Assessment> ;
                                                     rdfs:label "was output for" ;
                                                     <http://www.w3.org/2004/02/skos/core#notation> "Pc32i" .


###  https://w3id.org/cpm-arch/cpm/Pc33_forsees
<https://w3id.org/cpm-arch/cpm/Pc33_forsees> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc33i_is_foreseen_by> ;
                                             rdfs:domain <https://w3id.org/cpm-arch/cpm/CP33_Conservation_Project> ;
                                             rdfs:range <https://w3id.org/cpm-arch/cpm/CP25_Conservation_Intervention> ;
                                             rdfs:comment "This property associates an instance of CP25 Conservation Intervention with an instance of CP33 Conservation Project and it allows to express the allographic nature of architecture and its conservation. The project itself is a subclass of E29 design while its realisation is conceived as a subclass of E7 activity." ;
                                             rdfs:label "forsees" ;
                                             <http://www.w3.org/2004/02/skos/core#notation> "Pc33" .


###  https://w3id.org/cpm-arch/cpm/Pc33i_forsees
<https://w3id.org/cpm-arch/cpm/Pc33i_forsees> rdf:type owl:ObjectProperty .


###  https://w3id.org/cpm-arch/cpm/Pc33i_is_foreseen_by
<https://w3id.org/cpm-arch/cpm/Pc33i_is_foreseen_by> rdf:type owl:ObjectProperty ;
                                                     owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc33i_forsees> ;
                                                     rdfs:domain <https://w3id.org/cpm-arch/cpm/CP25_Conservation_Intervention> ;
                                                     rdfs:range <https://w3id.org/cpm-arch/cpm/CP33_Conservation_Project> ;
                                                     rdfs:label "is foreseen by" ;
                                                     <http://www.w3.org/2004/02/skos/core#notation> "Pc33i" .


###  https://w3id.org/cpm-arch/cpm/Pc34_used_as_input
<https://w3id.org/cpm-arch/cpm/Pc34_used_as_input> rdf:type owl:ObjectProperty ;
                                                   rdfs:domain <https://w3id.org/cpm-arch/cpm/CP24_Architecture_Conservation_Project_Activity> ;
                                                   rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E13_Attribute_Assignment> ;
                                                   rdfs:comment "This property associates an instance of CP33 Conservation Project activity with instances of E 13 Attribute Assignment that act as a guideline for the conservation project. Conservation Project (CP33) is elaborated moving from the attribute assignments carried out as outputs (CP27) during the architecture analysis which is compulsory to intervene on cultural heritage architecture. A use case of this property is to describe what elements, retrieved from the architecture analysis, have oriented the conservation project." ;
                                                   rdfs:label "used as input" ;
                                                   <http://www.w3.org/2004/02/skos/core#notation> "Pc34" .


###  https://w3id.org/cpm-arch/cpm/Pc34i_was_input_for
<https://w3id.org/cpm-arch/cpm/Pc34i_was_input_for> rdf:type owl:ObjectProperty ;
                                                    owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc34_used_as_input> ;
                                                    rdfs:domain <http://www.cidoc-crm.org/cidoc-crm/E13_Attribute_Assignment> ;
                                                    rdfs:range <https://w3id.org/cpm-arch/cpm/CP24_Architecture_Conservation_Project_Activity> ;
                                                    rdfs:label "was input for" ;
                                                    <http://www.w3.org/2004/02/skos/core#notation> "Pc34i" .


###  https://w3id.org/cpm-arch/cpm/Pc35_is_expressed_in
<https://w3id.org/cpm-arch/cpm/Pc35_is_expressed_in> rdf:type owl:ObjectProperty ;
                                                     rdfs:domain <https://w3id.org/cpm-arch/cpm/CP24_Architecture_Conservation_Project_Activity> ;
                                                     rdfs:range <https://w3id.org/cpm-arch/cpm/CP33_Conservation_Project> ;
                                                     rdfs:comment "This property associates an instance of CP24 Conservation Project Activity with an instance of CP33 Conservation Project and it allows to distinguish between the activity of elaborating the conservation project and the document that represents the result of this activity which is the project itself." ;
                                                     rdfs:label "is expressed in" ;
                                                     <http://www.w3.org/2004/02/skos/core#notation> "Pc35" .


###  https://w3id.org/cpm-arch/cpm/Pc35i_expresses
<https://w3id.org/cpm-arch/cpm/Pc35i_expresses> rdf:type owl:ObjectProperty ;
                                                owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc35_is_expressed_in> ;
                                                rdfs:domain <https://w3id.org/cpm-arch/cpm/CP33_Conservation_Project> ;
                                                rdfs:range <https://w3id.org/cpm-arch/cpm/CP24_Architecture_Conservation_Project_Activity> ;
                                                rdfs:label "expresses" ;
                                                <http://www.w3.org/2004/02/skos/core#notation> "Pc35i" .


###  https://w3id.org/cpm-arch/cpm/Pc36_addressed
<https://w3id.org/cpm-arch/cpm/Pc36_addressed> rdf:type owl:ObjectProperty ;
                                               rdfs:domain <https://w3id.org/cpm-arch/cpm/CP24_Architecture_Conservation_Project_Activity> ;
                                               rdfs:range <https://w3id.org/cpm-arch/cpm/CP25_Conservation_Intervention> ;
                                               rdfs:comment "This property associates an instance of CP24 Conservation Project Activity with an instance of CP25 Conservation Intervention and it allows to distinguish between the activity of elaborating the conservation project and the realisation of it. The conservation Project Activity (CP24) has addressed the conservation intervention (CP25) which was realised by the construction company. Esempi nella classe (per me non chiaro): the activity for the development of the maintenance plan for the Fontana dei Fiumi in piazza Navona, Rome (Pandolfi 2016). The activity for the definition of the monitoring plan of the Basilica di Massenzio in Rome (Moretti et al. 2018)." ;
                                               rdfs:label "addressed" ;
                                               <http://www.w3.org/2004/02/skos/core#notation> "Pc36" .


###  https://w3id.org/cpm-arch/cpm/Pc36i_was_addressed_by
<https://w3id.org/cpm-arch/cpm/Pc36i_was_addressed_by> rdf:type owl:ObjectProperty ;
                                                       owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc36_addressed> ;
                                                       rdfs:domain <https://w3id.org/cpm-arch/cpm/CP25_Conservation_Intervention> ;
                                                       rdfs:range <https://w3id.org/cpm-arch/cpm/CP24_Architecture_Conservation_Project_Activity> ;
                                                       rdfs:label "was addressed by" ;
                                                       <http://www.w3.org/2004/02/skos/core#notation> "Pc36i" .


###  https://w3id.org/cpm-arch/cpm/Pc37_complies_with
<https://w3id.org/cpm-arch/cpm/Pc37_complies_with> rdf:type owl:ObjectProperty ;
                                                   owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc37i_binds> ;
                                                   rdfs:domain <https://w3id.org/cpm-arch/cpm/CP33_Architecture_Conservation_Project> ;
                                                   rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E32_Authority_Document> ;
                                                   rdfs:comment "This property associates an instance of CP33 Architecture Conservation Project with an instance of E32 Autority Document and it allows to associate the conservation project activity to the pertaining normative references. The conservation project activity in Italy complies necessarily with the D.lgs. n.42/2004." ;
                                                   rdfs:label "complies with" ;
                                                   <http://www.w3.org/2004/02/skos/core#notation> "Pc37" .


###  https://w3id.org/cpm-arch/cpm/Pc37i_binds
<https://w3id.org/cpm-arch/cpm/Pc37i_binds> rdf:type owl:ObjectProperty ;
                                            rdfs:domain <https://w3id.org/cpm-arch/cpm/CP33_Architecture_Conservation_Project> ;
                                            rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E32_Authority_Document> ;
                                            rdfs:label "binds" ;
                                            <http://www.w3.org/2004/02/skos/core#notation> "Pc37i" .


###  https://w3id.org/cpm-arch/cpm/Pc38_specifies
<https://w3id.org/cpm-arch/cpm/Pc38_specifies> rdf:type owl:ObjectProperty ;
                                               rdfs:domain <https://w3id.org/cpm-arch/cpm/CP27_Architecture_Analysis_Output> ;
                                               rdfs:range <https://w3id.org/cpm-arch/cpm/CP9_Building_Material> ;
                                               rdfs:comment "This property associates an instance of CP27Architecture Analysis Output with an instance of CP9 Building material and it allows to express which materials have been identified within the building material analysis. The specification of the material substantial is the result of an assessment and is considered as an output of the analysis process." ;
                                               rdfs:label "specifies" ;
                                               <http://www.w3.org/2004/02/skos/core#notation> "Pc38" .


###  https://w3id.org/cpm-arch/cpm/Pc38i_is_specified_by
<https://w3id.org/cpm-arch/cpm/Pc38i_is_specified_by> rdf:type owl:ObjectProperty ;
                                                      owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc38_specifies> ;
                                                      rdfs:domain <https://w3id.org/cpm-arch/cpm/CP9_Building_Material> ;
                                                      rdfs:range <https://w3id.org/cpm-arch/cpm/CP27_Architecture_Analysis_Output> ;
                                                      rdfs:label "is specified by" ;
                                                      <http://www.w3.org/2004/02/skos/core#notation> "Pc38i" .


###  https://w3id.org/cpm-arch/cpm/Pc39_characterises
<https://w3id.org/cpm-arch/cpm/Pc39_characterises> rdf:type owl:ObjectProperty ;
                                                   owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc39i_is_characterised_by> ;
                                                   rdfs:domain <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                   rdfs:range <https://w3id.org/cpm-arch/cpm/CP18_Space_Entity> ;
                                                   rdfs:comment "This property associates an instance of CP1 Built Entity with an instance of CP18 Space Entity and allows to describe which is the connotative element of an historical centre or an urban area. Connotative elements may be very heterogeneous such as built towers or balconies or opus craticium walls." ;
                                                   rdfs:label "characterises" ;
                                                   <http://www.w3.org/2004/02/skos/core#notation> "Pc39" .


###  https://w3id.org/cpm-arch/cpm/Pc39i_is_characterised_by
<https://w3id.org/cpm-arch/cpm/Pc39i_is_characterised_by> rdf:type owl:ObjectProperty ;
                                                          rdfs:domain <https://w3id.org/cpm-arch/cpm/CP18_Space_Entity> ;
                                                          rdfs:range <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                          rdfs:label "is characterised by" ;
                                                          <http://www.w3.org/2004/02/skos/core#notation> "Pc39i" .


###  https://w3id.org/cpm-arch/cpm/Pc3_has_connection_through
<https://w3id.org/cpm-arch/cpm/Pc3_has_connection_through> rdf:type owl:ObjectProperty ;
                                                           owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc3i_connects> ;
                                                           rdfs:domain <https://w3id.org/cpm-arch/cpm/CP40_Historic_Centre> ;
                                                           rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing> ;
                                                           rdfs:comment "This property documents that an instance of CP40 Historic Centre is joined (connected) to its environment through an instance of E24 Physical Human made thing. The property is mainly conceived to describe which is the main route of communication that connects an historical centre to the territory." ;
                                                           rdfs:label "has connection through" ;
                                                           <http://www.w3.org/2004/02/skos/core#notation> "Pc3" .


###  https://w3id.org/cpm-arch/cpm/Pc3i_connects
<https://w3id.org/cpm-arch/cpm/Pc3i_connects> rdf:type owl:ObjectProperty ;
                                              rdfs:domain <http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing> ;
                                              rdfs:range <https://w3id.org/cpm-arch/cpm/CP40_Historic_Centre> ;
                                              rdfs:label "connects" ;
                                              <http://www.w3.org/2004/02/skos/core#notation> "Pc3i" .


###  https://w3id.org/cpm-arch/cpm/Pc40_is_facing_onto
<https://w3id.org/cpm-arch/cpm/Pc40_is_facing_onto> rdf:type owl:ObjectProperty ;
                                                    owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc40i_is_the_overlook_of> ;
                                                    rdfs:domain <https://w3id.org/cpm-arch/cpm/CP2_Architecture_Work> ;
                                                    rdfs:range <https://w3id.org/cpm-arch/cpm/CP16_Urban_Area> ;
                                                    rdfs:comment "This property associates an instance of CP2 Architecture work with an instance of CP16 Urban Area and allows to describe that a building is overlooking an Urba Area (CP 16). This property is necessary to express the physical relation that is established between a building and the space onto it is facing through the façade. This relation is expressing the threshold role that is recognized to a façade between private and public space. It is describing a twofold relationship referring either to the connection that an observer may have with the outer space through a window looking outside or to the role that the building façade is playing as a backdrop for the urban space." ;
                                                    rdfs:label "is facing onto" ;
                                                    <http://www.w3.org/2004/02/skos/core#notation> "Pc40" .


###  https://w3id.org/cpm-arch/cpm/Pc40i_is_facing_onto
<https://w3id.org/cpm-arch/cpm/Pc40i_is_facing_onto> rdf:type owl:ObjectProperty .


###  https://w3id.org/cpm-arch/cpm/Pc40i_is_shown_as_main_material_of
<https://w3id.org/cpm-arch/cpm/Pc40i_is_shown_as_main_material_of> rdf:type owl:ObjectProperty .


###  https://w3id.org/cpm-arch/cpm/Pc40i_is_the_overlook_of
<https://w3id.org/cpm-arch/cpm/Pc40i_is_the_overlook_of> rdf:type owl:ObjectProperty ;
                                                         owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc40i_is_facing_onto> ;
                                                         rdfs:domain <https://w3id.org/cpm-arch/cpm/CP16_Urban_Area> ;
                                                         rdfs:range <https://w3id.org/cpm-arch/cpm/CP2_Architecture_Work> ;
                                                         rdfs:label "is the overlook of" ;
                                                         <http://www.w3.org/2004/02/skos/core#notation> "Pc40i" .


###  https://w3id.org/cpm-arch/cpm/Pc41_shows_as_main_material
<https://w3id.org/cpm-arch/cpm/Pc41_shows_as_main_material> rdf:type owl:ObjectProperty ;
                                                            owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc40i_is_shown_as_main_material_of> ;
                                                            rdfs:domain <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                            rdfs:range <https://w3id.org/cpm-arch/cpm/CP9_Building_Material> ;
                                                            rdfs:comment "This property associates an instance of CP1 Built Entity with an instance of CP9 Building material and allows to describe which is the principal material that can be observed in a building, or a part of it, without intending to specify all the materials that have been used to build the edifice, but the one which is prevailing and directly observable through the view. It refers explicitly to a building material (eg. concrete, marble etc.)." ;
                                                            rdfs:label "shows as main material" ;
                                                            <http://www.w3.org/2004/02/skos/core#notation> "Pc41" .


###  https://w3id.org/cpm-arch/cpm/Pc41i_is_shown_as_main_material_of
<https://w3id.org/cpm-arch/cpm/Pc41i_is_shown_as_main_material_of> rdf:type owl:ObjectProperty ;
                                                                   owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc41_shows_as_main_material> ;
                                                                   rdfs:domain <https://w3id.org/cpm-arch/cpm/CP9_Building_Material> ;
                                                                   rdfs:range <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                                   rdfs:label "is shown as main material of" ;
                                                                   <http://www.w3.org/2004/02/skos/core#notation> "Pc41i" .


###  https://w3id.org/cpm-arch/cpm/Pc42_was_embodied_by
<https://w3id.org/cpm-arch/cpm/Pc42_was_embodied_by> rdf:type owl:ObjectProperty ;
                                                     rdfs:domain <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                     rdfs:range <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                     rdfs:comment "This property associates an instance of E11 Modification with an instance of CP1 Built Entity and allows to describe the physical result of the modification a building went through. This property makes it possible to represent the physical Entity that resulted from the activity of modifying a building or a part of it." ;
                                                     rdfs:label "was embodied by" ;
                                                     <http://www.w3.org/2004/02/skos/core#notation> "Pc42" .


###  https://w3id.org/cpm-arch/cpm/Pc42i_embodied
<https://w3id.org/cpm-arch/cpm/Pc42i_embodied> rdf:type owl:ObjectProperty ;
                                               owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc42_was_embodied_by> ;
                                               rdfs:domain <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                               rdfs:range <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                               rdfs:label "embodied" ;
                                               <http://www.w3.org/2004/02/skos/core#notation> "Pc42i" .


###  https://w3id.org/cpm-arch/cpm/Pc43_is_used_for
<https://w3id.org/cpm-arch/cpm/Pc43_is_used_for> rdf:type owl:ObjectProperty ;
                                                 owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc43i_uses> ;
                                                 rdfs:domain <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                 rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E7_Activity> ;
                                                 rdfs:comment "This property associates an instance of E7 Activity with an instance of CP1 Built Entity and allows to describe the activity the building (CP2 architectural Work) or a part of it (CP1 Built Entity) is used for. It refers to the utilitas of the building coping with the building as physical shelter, differently from the property Pc 6 that put into relation an activity with an architectural space (formalized as a space time volume)." ;
                                                 rdfs:label "is used for" ;
                                                 <http://www.w3.org/2004/02/skos/core#notation> "Pc43" .


###  https://w3id.org/cpm-arch/cpm/Pc43i_uses
<https://w3id.org/cpm-arch/cpm/Pc43i_uses> rdf:type owl:ObjectProperty ;
                                           rdfs:domain <http://www.cidoc-crm.org/cidoc-crm/E7_Activity> ;
                                           rdfs:range <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                           rdfs:label "uses" ;
                                           <http://www.w3.org/2004/02/skos/core#notation> "Pc43i" .


###  https://w3id.org/cpm-arch/cpm/Pc44_illustrates
<https://w3id.org/cpm-arch/cpm/Pc44_illustrates> rdf:type owl:ObjectProperty ;
                                                 rdfs:domain <https://w3id.org/cpm-arch/cpm/CP34_Architecture_Depiction> ;
                                                 rdfs:range <https://w3id.org/cpm-arch/cpm/CP38_Architecture_Conservation_Project> ;
                                                 rdfs:comment "This property associates an instance of CP38 Architecture Representation Object with an instance of CP 34 Architecture Depiction and allows to describe the content of a graphic representation." ;
                                                 rdfs:label "illustrates" ;
                                                 <http://www.w3.org/2004/02/skos/core#notation> "Pc44" .


###  https://w3id.org/cpm-arch/cpm/Pc44i_is_illustrated_by
<https://w3id.org/cpm-arch/cpm/Pc44i_is_illustrated_by> rdf:type owl:ObjectProperty ;
                                                        owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc44_illustrates> ;
                                                        rdfs:domain <https://w3id.org/cpm-arch/cpm/CP38_Architecture_Conservation_Project> ;
                                                        rdfs:range <https://w3id.org/cpm-arch/cpm/CP34_Architecture_Depiction> ;
                                                        rdfs:label "is illustrated by" ;
                                                        <http://www.w3.org/2004/02/skos/core#notation> "Pc44i" .


###  https://w3id.org/cpm-arch/cpm/Pc45_has_morphology_type
<https://w3id.org/cpm-arch/cpm/Pc45_has_morphology_type> rdf:type owl:ObjectProperty ;
                                                         rdfs:domain <https://w3id.org/cpm-arch/cpm/CP44_Construction_Site> ;
                                                         rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E55_Type> ;
                                                         rdfs:comment "This property associates an instance of CP44 Construction Site with an instance of E55 Type. The property intends to describe the morphology of identifiable features, as they are described in CIDOC CRM, that “are physically attached in an integral way to particular physical objects or are portions of particular objects with partially imaginary borders, such as the core of the Earth, an area of property on the surface of the Earth, a landscape or the head of a contiguous marble statue”. In architecture this property may be used to describe the morphology of the CP 44 Construction Site, that is a subclass of E26 Physical feature. It is conceived to represent the land involved in the construction, regardless of the construction consistency and nature. The morphology of the construction site may be documented either for a historical centre or for a building." ;
                                                         rdfs:label "has morphology type" ;
                                                         <http://www.w3.org/2004/02/skos/core#notation> "Pc45" .


###  https://w3id.org/cpm-arch/cpm/Pc46_has_geology_type
<https://w3id.org/cpm-arch/cpm/Pc46_has_geology_type> rdf:type owl:ObjectProperty ;
                                                      rdfs:domain <https://w3id.org/cpm-arch/cpm/CP44_Construction_Site> ;
                                                      rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E55_Type> ;
                                                      rdfs:comment "This property associates an instance of CP44 Construction Site with an instance of E55 Type. The property intends to describe the specific geological nature of an area of property on the surface of the Earth or a landscape involved in the built area. As for the morphology documentation it may concern either historical centres or buildings." ;
                                                      rdfs:label "has geology type" ;
                                                      <http://www.w3.org/2004/02/skos/core#notation> "Pc46" .


###  https://w3id.org/cpm-arch/cpm/Pc47_modified
<https://w3id.org/cpm-arch/cpm/Pc47_modified> rdf:type owl:ObjectProperty ;
                                              rdfs:domain <https://w3id.org/cpm-arch/cpm/CP49_Urban_Plan> ;
                                              rdfs:range <https://w3id.org/cpm-arch/cpm/CP49_Urban_Plan> ;
                                              rdfs:comment "This property allows to document the modifications that may occur on an urban plan. This circumstance may be addressed either to describe modifications that may be needed during the urban designing process or as the result of later intervention. These modifications may be triggered by intrinsic or extrinsic factors that may have intervened also independently of the designer's will." ;
                                              rdfs:label "modified" ;
                                              <http://www.w3.org/2004/02/skos/core#notation> "Pc47" .


###  https://w3id.org/cpm-arch/cpm/Pc48_planned
<https://w3id.org/cpm-arch/cpm/Pc48_planned> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc48i_was_planned_by> ;
                                             rdfs:domain <https://w3id.org/cpm-arch/cpm/CP49_Urban_Plan> ;
                                             rdfs:range <https://w3id.org/cpm-arch/cpm/CP16_Urban_Area> ;
                                             rdfs:comment "This property associates an instance of CP49 Urban Plan with an instance of CP 16 Urban Area and it allows to refer an urban area (CP 16) to an urban plan (CP49)." ;
                                             rdfs:label "planned" ;
                                             <http://www.w3.org/2004/02/skos/core#notation> "Pc48" .


###  https://w3id.org/cpm-arch/cpm/Pc48i_was_planned_by
<https://w3id.org/cpm-arch/cpm/Pc48i_was_planned_by> rdf:type owl:ObjectProperty ;
                                                     rdfs:domain <https://w3id.org/cpm-arch/cpm/CP16_Urban_Area> ;
                                                     rdfs:range <https://w3id.org/cpm-arch/cpm/CP49_Urban_Plan> ;
                                                     rdfs:label "was planned by" ;
                                                     <http://www.w3.org/2004/02/skos/core#notation> "Pc48i" .


###  https://w3id.org/cpm-arch/cpm/Pc49_fostered
<https://w3id.org/cpm-arch/cpm/Pc49_fostered> rdf:type owl:ObjectProperty ;
                                              owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc49i_was_fostered_by> ;
                                              rdfs:domain <https://w3id.org/cpm-arch/cpm/CP43_Structural_Damage> ;
                                              rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E3_Condition_State> ;
                                              rdfs:comment "This property allows to relate an instance of CP 43 Structural damage with an instance of E3 Condition State. It allows to describe the conditions of a building or part of it that have fostered a structural damage. As a matter of facts the structural damage may be caused by specific events or by some building conditions that may influence the decay phenomenons. Those condition may be referred either to a inadequate maintenance or to not inappropriate interventions. As an example, a defect in a roof if not quickly repaired could make it possible that the water hits the structure which may be not able to resist. As a consequence, the building or part of it at first shows cracks and secondly collapses. Also a superelevation of a building if not adequately planned may provoke an excessive load on the masonry generating cracks." ;
                                              rdfs:label "fostered" ;
                                              <http://www.w3.org/2004/02/skos/core#notation> "Pc49" .


###  https://w3id.org/cpm-arch/cpm/Pc49i_was_fostered_by
<https://w3id.org/cpm-arch/cpm/Pc49i_was_fostered_by> rdf:type owl:ObjectProperty ;
                                                      rdfs:domain <http://www.cidoc-crm.org/cidoc-crm/E3_Condition_State> ;
                                                      rdfs:range <https://w3id.org/cpm-arch/cpm/CP43_Structural_Damage> ;
                                                      rdfs:label "fostered" ;
                                                      <http://www.w3.org/2004/02/skos/core#notation> "Pc49i" .


###  https://w3id.org/cpm-arch/cpm/Pc4_shows_building_feature
<https://w3id.org/cpm-arch/cpm/Pc4_shows_building_feature> rdf:type owl:ObjectProperty ;
                                                           rdfs:domain <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                           rdfs:range <https://w3id.org/cpm-arch/cpm/CP28_Building_Feature> ;
                                                           rdfs:comment "This property documents that an instance of CP1 Built entity Shows building features specified by an instance of CP28 Building Feature" ;
                                                           rdfs:label "shows building feature" ;
                                                           <http://www.w3.org/2004/02/skos/core#notation> "Pc4" .


###  https://w3id.org/cpm-arch/cpm/Pc4i_building_feature_is_shown_in
<https://w3id.org/cpm-arch/cpm/Pc4i_building_feature_is_shown_in> rdf:type owl:ObjectProperty ;
                                                                  owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc4_shows_building_feature> ;
                                                                  rdfs:domain <https://w3id.org/cpm-arch/cpm/CP28_Building_Feature> ;
                                                                  rdfs:range <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                                  rdfs:label "building feature is shown in" ;
                                                                  <http://www.w3.org/2004/02/skos/core#notation> "Pc4i" .


###  https://w3id.org/cpm-arch/cpm/Pc50_incorporates
<https://w3id.org/cpm-arch/cpm/Pc50_incorporates> rdf:type owl:ObjectProperty ;
                                                  owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc50i_is_incorporated_in> ;
                                                  rdfs:domain <https://w3id.org/cpm-arch/cpm/CP33_Architecture_Conservation_Project> ;
                                                  rdfs:range <https://w3id.org/cpm-arch/cpm/CP34_Architecture_Depiction> ;
                                                  rdfs:comment "This property associates an instance of CP33 Conservation Project with an instance of CP 34 Architecture Depiction. The property intends to describe the specificity of the conservation project that is conceived as a result of the gathering of several analysis that are normally represented through different architectural depictions." ;
                                                  rdfs:label "incorporates" ;
                                                  <http://www.w3.org/2004/02/skos/core#notation> "Pc50" .


###  https://w3id.org/cpm-arch/cpm/Pc50i_is_incorporated_in
<https://w3id.org/cpm-arch/cpm/Pc50i_is_incorporated_in> rdf:type owl:ObjectProperty ;
                                                         rdfs:domain <https://w3id.org/cpm-arch/cpm/CP34_Architecture_Depiction> ;
                                                         rdfs:range <https://w3id.org/cpm-arch/cpm/CP33_Architecture_Conservation_Project> ;
                                                         rdfs:label "is incorporated in" ;
                                                         <http://www.w3.org/2004/02/skos/core#notation> "Pc50i" .


###  https://w3id.org/cpm-arch/cpm/Pc51_was_affected_by
<https://w3id.org/cpm-arch/cpm/Pc51_was_affected_by> rdf:type owl:ObjectProperty ;
                                                     owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc51i_was_generated_on> ;
                                                     rdfs:domain <https://w3id.org/cpm-arch/cpm/CP9_Building_Material> ;
                                                     rdfs:range <https://w3id.org/cpm-arch/cpm/CP42_Material_Decay> ;
                                                     rdfs:comment "This property associates an instance of CP 9 Building Material with an instance of CP 42 Material Decay. The property intends to describe which is the material decay (CP 42 Material Decay) that has affected the material that constitutes a particular physical object or part of it." ;
                                                     rdfs:label "was affected by" ;
                                                     <http://www.w3.org/2004/02/skos/core#notation> "Pc51" .


###  https://w3id.org/cpm-arch/cpm/Pc51i_was_generated_on
<https://w3id.org/cpm-arch/cpm/Pc51i_was_generated_on> rdf:type owl:ObjectProperty ;
                                                       rdfs:domain <https://w3id.org/cpm-arch/cpm/CP42_Material_Decay> ;
