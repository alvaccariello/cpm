                                                                     rdfs:domain <https://w3id.org/cpm-arch/cpm/CP3_Construction_Unit> ;
                                                                     rdfs:range <https://w3id.org/cpm-arch/cpm/CP4_Construction_Component> ;
                                                                     rdfs:comment "This property allows to relate an instance of CP3 Construction Unit with an instance of the class CP4 Construction Component to describe their specific mereological relation. The property intends to make explicit the components that are constituting the construction unit. As an example the façade of a church shows as construction component the wall." ;
                                                                     rdfs:label "shows as construction component" ;
                                                                     <http://www.w3.org/2004/02/skos/core#notation> "Pc67" .


