                                                    rdfs:domain <https://w3id.org/cpm-arch/cpm/CP8_Equipment> ;
                                                    rdfs:range <https://w3id.org/cpm-arch/cpm/CP20_Construction_Work> ;
                                                    rdfs:comment "This property allows to relate an instance of CP8 Equipment with an instance of the class CP 20 Construction Work to describe the condition of an equipment crossing a whatever part of the building. Particularly within conservation process this is a very sensitive condition that requires a major care, as ancient buildings may not bear the presence of them if not adequately designed." ;
                                                    rdfs:label "passes through" ;
                                                    <http://www.w3.org/2004/02/skos/core#notation> "Pc70" .


###  https://w3id.org/cpm-arch/cpm/Pc70i_is_crossed_by
<https://w3id.org/cpm-arch/cpm/Pc70i_is_crossed_by> rdf:type owl:ObjectProperty ;
                                                    rdfs:domain <https://w3id.org/cpm-arch/cpm/CP20_Construction_Work> ;
                                                    rdfs:range <https://w3id.org/cpm-arch/cpm/CP8_Equipment> ;
                                                    rdfs:label "is crossed by" ;
                                                    <http://www.w3.org/2004/02/skos/core#notation> "Pc70i" .


###  https://w3id.org/cpm-arch/cpm/Pc71_is_intrinsically_connected_to
<https://w3id.org/cpm-arch/cpm/Pc71_is_intrinsically_connected_to> rdf:type owl:ObjectProperty ;
                                                                   rdfs:domain <https://w3id.org/cpm-arch/cpm/CP12_Building_Floor> ;
                                                                   rdfs:range <https://w3id.org/cpm-arch/cpm/CP12_Building_Floor> ;
                                                                   rdfs:comment "This property allows to relate two instances of CP 12 Building Floor to describe the condition of the connection between two floors. Particularly within conservation process this is a very sensitive condition that requires a major care, as ancient buildings may not bear the presence of them if not adequately designed." ;
                                                                   rdfs:label "is intrinsically connected to" ;
                                                                   <http://www.w3.org/2004/02/skos/core#notation> "Pc71" .


###  https://w3id.org/cpm-arch/cpm/Pc72_shows_geometry_plan_type
<https://w3id.org/cpm-arch/cpm/Pc72_shows_geometry_plan_type> rdf:type owl:ObjectProperty ;
                                                              rdfs:domain <https://w3id.org/cpm-arch/cpm/CP13_Urban_Unit> ;
                                                              rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E55_Type> ;
                                                              rdfs:comment "This property allows to relate an instance of CP 13 Urban Unit to an instance of E55 Type in order to identify the geometry plan type of the building. The property is conceived to allow referring to thesauri describing the different geometries that are relevant not only for the formal reasons but mainly because they are influencing the structural vulnerability of the building." ;
                                                              rdfs:label "shows geometry plan type" ;
                                                              <http://www.w3.org/2004/02/skos/core#notation> "Pc72" .


###  https://w3id.org/cpm-arch/cpm/Pc73_is_facing_onto
<https://w3id.org/cpm-arch/cpm/Pc73_is_facing_onto> rdf:type owl:ObjectProperty ;
                                                    owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc73i_is_the_overlook_of> ;
                                                    rdfs:domain <https://w3id.org/cpm-arch/cpm/CP2_Architecture_Work> ;
                                                    rdfs:range <https://w3id.org/cpm-arch/cpm/CP15_Open_Air_Area> ;
                                                    rdfs:comment "This property associates an instance of CP2 Architecture work with an instance of CP 15 Open Air Area and allows to describe that a building is overlooking an area that is not a urban area. This property is necessary to express the physical relation that is established between a building and the space onto it is facing. It is describing a twofold relationship referring either to the connection that an observer may have with the outer space through a window looking outside or to the role that the building façade is playing as a backdrop for the open air area." ;
                                                    rdfs:label "is facing onto" ;
                                                    <http://www.w3.org/2004/02/skos/core#notation> "Pc73" .


###  https://w3id.org/cpm-arch/cpm/Pc73i_is_the_overlook_of
<https://w3id.org/cpm-arch/cpm/Pc73i_is_the_overlook_of> rdf:type owl:ObjectProperty ;
                                                         rdfs:domain <https://w3id.org/cpm-arch/cpm/CP15_Open_Air_Area> ;
                                                         rdfs:range <https://w3id.org/cpm-arch/cpm/CP2_Architecture_Work> ;
                                                         rdfs:label "is the overlook of" ;
                                                         <http://www.w3.org/2004/02/skos/core#notation> "Pc73i" .


###  https://w3id.org/cpm-arch/cpm/Pc74_can_be_referred_to_landscape_type
<https://w3id.org/cpm-arch/cpm/Pc74_can_be_referred_to_landscape_type> rdf:type owl:ObjectProperty ;
                                                                       rdfs:domain <https://w3id.org/cpm-arch/cpm/CP17_Landscape_Element> ;
                                                                       rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E55_Type> ;
                                                                       rdfs:comment "This property allows to relate an instance of CP 17 Landscape Element to an instance of E55 Type in order to describe the element and associate it to the thesaurus derived from the Institutional Cultural Heritage Protection Lists. As a matter of facts the Italian Cultural Heritage code specifies different type of landscape element such as: parcs, panoramic views etc." ;
                                                                       rdfs:label "can be referred to landscape type" ;
                                                                       <http://www.w3.org/2004/02/skos/core#notation> "Pc75" .


###  https://w3id.org/cpm-arch/cpm/Pc74_was_caused_by
<https://w3id.org/cpm-arch/cpm/Pc74_was_caused_by> rdf:type owl:ObjectProperty ;
                                                   rdfs:domain <https://w3id.org/cpm-arch/cpm/CP42_Material_Decay> ;
                                                   rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E5_Event> ;
                                                   rdfs:comment "This property allows to relate an instance of CP 42 Material Decay to an instance of E5 Event in order to describe the event that eventually caused the material decay. Although material decay is mostly triggered by environmental condition, some events may occur fostering decay or provoking some specific deterioration. The property is mainly conceived to describe extraordinary events, such as earthquakes of floodings." ;
                                                   rdfs:label "was caused by" ;
                                                   <http://www.w3.org/2004/02/skos/core#notation> "Pc74" .


###  https://w3id.org/cpm-arch/cpm/Pc74i_caused
<https://w3id.org/cpm-arch/cpm/Pc74i_caused> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc74_was_caused_by> ;
                                             rdfs:domain <http://www.cidoc-crm.org/cidoc-crm/E5_Event> ;
                                             rdfs:range <https://w3id.org/cpm-arch/cpm/CP42_Material_Decay> ;
                                             rdfs:label "caused" ;
                                             <http://www.w3.org/2004/02/skos/core#notation> "Pc74i" .


###  https://w3id.org/cpm-arch/cpm/Pc74i_landscape_type_can_be_referred_to
<https://w3id.org/cpm-arch/cpm/Pc74i_landscape_type_can_be_referred_to> rdf:type owl:ObjectProperty ;
                                                                        owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc74_can_be_referred_to_landscape_type> ;
                                                                        rdfs:domain <http://www.cidoc-crm.org/cidoc-crm/E55_Type> ;
                                                                        rdfs:range <https://w3id.org/cpm-arch/cpm/CP17_Cultural_Heritage_Landscape_Element> ;
                                                                        rdfs:label "landscape type can be referred to" ;
                                                                        <http://www.w3.org/2004/02/skos/core#notation> "Pc75i" .


###  https://w3id.org/cpm-arch/cpm/Pc76_is_marked_by
<https://w3id.org/cpm-arch/cpm/Pc76_is_marked_by> rdf:type owl:ObjectProperty ;
                                                  owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc76i_marks> ;
                                                  rdfs:domain <https://w3id.org/cpm-arch/cpm/CP19_Historic_Centre> ;
                                                  rdfs:range <https://w3id.org/cpm-arch/cpm/CP17_Landscape_Element> ;
                                                  rdfs:comment "This property allows to relate an instance of CP 40 Historic Centre to an instance of CP 17 Landscape Element in order to describe the features characterizing the urban landscape of an historic centre. different types of landscape element could be parks, gardens, special viewpoints, panoramic views etc." ;
                                                  rdfs:label "is marked by" ;
                                                  <http://www.w3.org/2004/02/skos/core#notation> "Pc76" .


###  https://w3id.org/cpm-arch/cpm/Pc76i_marks
<https://w3id.org/cpm-arch/cpm/Pc76i_marks> rdf:type owl:ObjectProperty ;
                                            rdfs:domain <https://w3id.org/cpm-arch/cpm/CP17_Landscape_Element> ;
                                            rdfs:range <https://w3id.org/cpm-arch/cpm/CP19_Historic_Centre> ;
                                            rdfs:label "marks" ;
                                            <http://www.w3.org/2004/02/skos/core#notation> "Pc76i" .


###  https://w3id.org/cpm-arch/cpm/Pc77_has_as_space_component
<https://w3id.org/cpm-arch/cpm/Pc77_has_as_space_component> rdf:type owl:ObjectProperty ;
                                                            owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc77i_is_a_space_component_of> ;
                                                            rdfs:domain <https://w3id.org/cpm-arch/cpm/CP21_Space_Unit> ;
                                                            rdfs:range <https://w3id.org/cpm-arch/cpm/CP22_Space_Component> ;
                                                            rdfs:comment "This property allows to relate an instance of CP 21 Space Unit to an instance of CP 22 Space Component in order to describe the mereological relations between the elements that produce the spatial composition of an architecture work considering both dimension of space and time. A space unit may be a unitary area or the result of the juxtaposition of several space components. As an example, a church that shows Hallenkirche typology is conceived as a CP 21 Space Unit that cannot be further divided into spatial components) CP 22). Besides, a three naves church with an apse, is considered as a CP 21 Space Unit, that may be divided into several space components as the central nave, the two ailes and the apse." ;
                                                            rdfs:label "has as space component" ;
                                                            <http://www.w3.org/2004/02/skos/core#notation> "Pc77" .


###  https://w3id.org/cpm-arch/cpm/Pc77i_is_a_space_component_of
<https://w3id.org/cpm-arch/cpm/Pc77i_is_a_space_component_of> rdf:type owl:ObjectProperty ;
                                                              rdfs:domain <https://w3id.org/cpm-arch/cpm/CP22_Space_Component> ;
                                                              rdfs:range <https://w3id.org/cpm-arch/cpm/CP21_Space_Unit> ;
                                                              rdfs:label "is a space component of" ;
                                                              <http://www.w3.org/2004/02/skos/core#notation> "Pc77i" .


###  https://w3id.org/cpm-arch/cpm/Pc78_is_visually_related_to
<https://w3id.org/cpm-arch/cpm/Pc78_is_visually_related_to> rdf:type owl:ObjectProperty ;
                                                            rdfs:domain <https://w3id.org/cpm-arch/cpm/CP18_Space_Entity> ;
                                                            rdfs:range <https://w3id.org/cpm-arch/cpm/CP18_Space_Entity> ;
                                                            rdfs:comment "This property allows to describe the relation between two instances of CP18 Space Entity to specify whether there is a visual continuity or not. As an example, a chapel may be communicating with the aisle of a church or may be separated from it through a wall and put into connection through a door. The property is conceived to express the relation at the higher level of the hierarchy of the architecture spaces (CP18 Space Entity) so to describe all the possible spatial solutions occurred in a specific time." ;
                                                            rdfs:label "is visually related to" ;
                                                            <http://www.w3.org/2004/02/skos/core#notation> "Pc78" .


###  https://w3id.org/cpm-arch/cpm/Pc79_transformed
<https://w3id.org/cpm-arch/cpm/Pc79_transformed> rdf:type owl:ObjectProperty ;
                                                 rdfs:domain <https://w3id.org/cpm-arch/cpm/CP26_Typological_Variation> ;
                                                 rdfs:range <https://w3id.org/cpm-arch/cpm/CP2_Architecture_Work> ;
                                                 rdfs:comment "This property allows to relate an instance of CP 26 Typological variation with an instance of CP2 Architecture Work to describe the kind of transformation that occurred in an architecture work. The typological variation implies the transformation of architecture identity as it may tackle figurative, functional and structural issues that qualify a building." ;
                                                 rdfs:label "transformed" ;
                                                 <http://www.w3.org/2004/02/skos/core#notation> "Pc79" .


###  https://w3id.org/cpm-arch/cpm/Pc79i_was_transformed_by
<https://w3id.org/cpm-arch/cpm/Pc79i_was_transformed_by> rdf:type owl:ObjectProperty ;
                                                         owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc79_transformed> ;
                                                         rdfs:domain <https://w3id.org/cpm-arch/cpm/CP2_Architecture_Work> ;
                                                         rdfs:range <https://w3id.org/cpm-arch/cpm/CP26_Typological_Variation> ;
                                                         rdfs:label "was transformed by" ;
                                                         <http://www.w3.org/2004/02/skos/core#notation> "Pc79i" .


###  https://w3id.org/cpm-arch/cpm/Pc7_is_connected_through
<https://w3id.org/cpm-arch/cpm/Pc7_is_connected_through> rdf:type owl:ObjectProperty ;
                                                         owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc7i_connects> ;
                                                         rdfs:domain <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                         rdfs:range <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                         rdfs:comment "This property documents that an instance of CP1 Built Entity is connected through an instance of CP1 Built Entity to another built element. This circumstance is mainly referred to historical centres’ fabric." ;
                                                         rdfs:label "is connected through" ;
                                                         <http://www.w3.org/2004/02/skos/core#notation> "Pc7" .


###  https://w3id.org/cpm-arch/cpm/Pc7i_connects
<https://w3id.org/cpm-arch/cpm/Pc7i_connects> rdf:type owl:ObjectProperty ;
                                              rdfs:domain <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                              rdfs:range <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                              rdfs:label "connects" ;
                                              <http://www.w3.org/2004/02/skos/core#notation> "Pc7i" .


###  https://w3id.org/cpm-arch/cpm/Pc80_is_referred_to
<https://w3id.org/cpm-arch/cpm/Pc80_is_referred_to> rdf:type owl:ObjectProperty ;
                                                    owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc80i_is_referred_to_by> ;
                                                    rdfs:domain <https://w3id.org/cpm-arch/cpm/CP29_Building_Phase> ;
                                                    rdfs:range <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                    rdfs:comment "This property allows to relate an instance of CP 29 Building Phase with an instance of CP1 Built Entity to refer a building or part of it to the reconstruction of the transformation phases formulated through a study to asses its historical and architectural value. More in detail the property allows to specify which is the building phase the architecture may be referred to." ;
                                                    rdfs:label "is referred to" ;
                                                    <http://www.w3.org/2004/02/skos/core#notation> "Pc80" .


###  https://w3id.org/cpm-arch/cpm/Pc80_is_referred_to_
<https://w3id.org/cpm-arch/cpm/Pc80_is_referred_to_> rdf:type owl:ObjectProperty .


###  https://w3id.org/cpm-arch/cpm/Pc80i_is_referred_to_by
<https://w3id.org/cpm-arch/cpm/Pc80i_is_referred_to_by> rdf:type owl:ObjectProperty ;
                                                        owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc80_is_referred_to_> ;
                                                        rdfs:domain <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                        rdfs:range <https://w3id.org/cpm-arch/cpm/CP29_Building_Phase> ;
                                                        rdfs:label "is referred to by" ;
                                                        <http://www.w3.org/2004/02/skos/core#notation> "Pc80i" .


###  https://w3id.org/cpm-arch/cpm/Pc81_planned_the_conservation_of
<https://w3id.org/cpm-arch/cpm/Pc81_planned_the_conservation_of> rdf:type owl:ObjectProperty ;
                                                                 owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc81i_was_planned_by> ;
                                                                 rdfs:domain <https://w3id.org/cpm-arch/cpm/CP50_Urban_Conservation_Plan> ;
                                                                 rdfs:range <https://w3id.org/cpm-arch/cpm/CP16_Urban_Area> ;
                                                                 rdfs:comment "This property allows to relate an instance of CP 50 Urban conservation Plan with an instance of CP16 Urban Area. It specifies the object of the urban conservation plan." ;
                                                                 rdfs:label "planned the conservation of" ;
                                                                 <http://www.w3.org/2004/02/skos/core#notation> "Pc81" .


###  https://w3id.org/cpm-arch/cpm/Pc81i_was_planned_by
<https://w3id.org/cpm-arch/cpm/Pc81i_was_planned_by> rdf:type owl:ObjectProperty ;
                                                     rdfs:domain <https://w3id.org/cpm-arch/cpm/CP16_Urban_Area> ;
                                                     rdfs:range <https://w3id.org/cpm-arch/cpm/CP50_Urban_Conservation_Plan> ;
                                                     rdfs:label "was planned by" ;
                                                     <http://www.w3.org/2004/02/skos/core#notation> "Pc81i" .


###  https://w3id.org/cpm-arch/cpm/Pc82_assessed_the_structural_conditions_of
<https://w3id.org/cpm-arch/cpm/Pc82_assessed_the_structural_conditions_of> rdf:type owl:ObjectProperty ;
                                                                           owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc82i_was_assessed_in_its_structural_conditions_by> ;
                                                                           rdfs:domain <https://w3id.org/cpm-arch/cpm/CP30_Architecture_Condition_Assessment> ;
                                                                           rdfs:range <https://w3id.org/cpm-arch/cpm/CP2_Architecture_Work> ;
                                                                           rdfs:comment """This property allows to relate an instance of CP 30 Architecture Condition Assessment
with an instance of CP2 Architecture Work specifying the nature of the assessment the building or part of is going through. Particularly the property refers to the structural assessment that may detect a structural damage.""" ;
                                                                           rdfs:label "assessed the structural conditions of" ;
                                                                           <http://www.w3.org/2004/02/skos/core#notation> "Pc82" .


###  https://w3id.org/cpm-arch/cpm/Pc82i_was_assessed_in_its_structural_conditions_by
<https://w3id.org/cpm-arch/cpm/Pc82i_was_assessed_in_its_structural_conditions_by> rdf:type owl:ObjectProperty ;
                                                                                   rdfs:domain <https://w3id.org/cpm-arch/cpm/CP30_Architecture_Condition_Assessment> ;
                                                                                   rdfs:range <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                                                   rdfs:label "assesses the structural conditions of" ;
                                                                                   <http://www.w3.org/2004/02/skos/core#notation> "Pc82i" .


###  https://w3id.org/cpm-arch/cpm/Pc83_assessed_the_decay_condition_of
<https://w3id.org/cpm-arch/cpm/Pc83_assessed_the_decay_condition_of> rdf:type owl:ObjectProperty ;
                                                                     rdfs:domain <https://w3id.org/cpm-arch/cpm/CP30_Architecture_Condition_Assessment> ;
                                                                     rdfs:range <https://w3id.org/cpm-arch/cpm/CP9_Building_Material> ;
                                                                     rdfs:comment "This property allows to relate an instance of CP 30 Architecture Condition Assessment with an instance of CP9 Building Material specifying the nature of the assessment the building is going through. Particularly the property refers to the decay condition of the building materials the architecture is made of. " ;
                                                                     rdfs:label "assessed the decay conditions of" ;
                                                                     <http://www.w3.org/2004/02/skos/core#notation> "Pc83" .


###  https://w3id.org/cpm-arch/cpm/Pc83i_was_assessed_in_its_decay_condition_by
<https://w3id.org/cpm-arch/cpm/Pc83i_was_assessed_in_its_decay_condition_by> rdf:type owl:ObjectProperty ;
                                                                             owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc83_assessed_the_decay_condition_of> ;
                                                                             rdfs:domain <https://w3id.org/cpm-arch/cpm/CP9_Building_Material> ;
                                                                             rdfs:range <https://w3id.org/cpm-arch/cpm/CP30_Architecture_Condition_Assessment> ;
                                                                             rdfs:label "was assessed in its decay condition by" ;
                                                                             <http://www.w3.org/2004/02/skos/core#notation> "Pc83i" .


###  https://w3id.org/cpm-arch/cpm/Pc84_gathers
<https://w3id.org/cpm-arch/cpm/Pc84_gathers> rdf:type owl:ObjectProperty ;
                                             rdfs:domain <https://w3id.org/cpm-arch/cpm/CP34_Architecture_Depiction> ;
                                             rdfs:range <https://w3id.org/cpm-arch/cpm/CP27_Architecture_Analysis_Output> ;
                                             rdfs:comment "This property allows to relate an instance of CP 34 Architecture Depiction with an instance of CP27 Architecture Analysis Output. This property allows to describe the nature of the class architectural depiction. It specifies its role within conservation process as a document that, gathering the results of the analysis that have been developed on the building, represents the knowledge required to orient a conservation project." ;
                                             rdfs:label "gathers" ;
                                             <http://www.w3.org/2004/02/skos/core#notation> "Pc84" .


###  https://w3id.org/cpm-arch/cpm/Pc84i_is_gathered_by
<https://w3id.org/cpm-arch/cpm/Pc84i_is_gathered_by> rdf:type owl:ObjectProperty ;
                                                     owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc84_gathers> ;
                                                     rdfs:domain <https://w3id.org/cpm-arch/cpm/CP27_Architecture_Analysis_Output> ;
                                                     rdfs:range <https://w3id.org/cpm-arch/cpm/CP34_Architecture_Depiction> ;
                                                     rdfs:label "is gathered by" ;
                                                     <http://www.w3.org/2004/02/skos/core#notation> "Pc84i" .


###  https://w3id.org/cpm-arch/cpm/Pc85_was_subdued_to
<https://w3id.org/cpm-arch/cpm/Pc85_was_subdued_to> rdf:type owl:ObjectProperty ;
                                                    rdfs:domain <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                    rdfs:range <https://w3id.org/cpm-arch/cpm/CP23_Maintenance> ;
                                                    rdfs:comment """This property allows to relate an instance of CP1 Built Entity
with an instance of CP 23 Maintenance. This property allows to describe that a building or part of it was the object of a maintenance activity. Differently from conservation intervention, maintenance may be realised without a proper project, but just referring to a sequence of activities to be repeated in time.""" ;
                                                    rdfs:label "was subdued to" ;
                                                    <http://www.w3.org/2004/02/skos/core#notation> "Pc85" .


###  https://w3id.org/cpm-arch/cpm/Pc85i_was_realised_on
<https://w3id.org/cpm-arch/cpm/Pc85i_was_realised_on> rdf:type owl:ObjectProperty ;
                                                      owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc85_was_subdued_to> ;
                                                      rdfs:domain <https://w3id.org/cpm-arch/cpm/CP23_Maintenance> ;
                                                      rdfs:range <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                      rdfs:label "was realised on" ;
                                                      <http://www.w3.org/2004/02/skos/core#notation> "Pc85i" .


###  https://w3id.org/cpm-arch/cpm/Pc86_addressed
<https://w3id.org/cpm-arch/cpm/Pc86_addressed> rdf:type owl:ObjectProperty ;
                                               rdfs:domain <https://w3id.org/cpm-arch/cpm/CP50_Urban_Conservation_Plan> ;
                                               rdfs:range <https://w3id.org/cpm-arch/cpm/CP33_Architecture_Conservation_Plan> ;
                                               rdfs:comment "This property allows to relate an instance of CP 50 Urban conservation Plan with an instance of CP 33 Conservation Project addressing the hierarchy relationship existing between the urban and the architectural scale. The conservation activity developed at the urban level necessarily orient the conservation of the buildings." ;
                                               rdfs:label "addressed" ;
                                               <http://www.w3.org/2004/02/skos/core#notation> "Pc86" .


###  https://w3id.org/cpm-arch/cpm/Pc86i_was_addressed_by
<https://w3id.org/cpm-arch/cpm/Pc86i_was_addressed_by> rdf:type owl:ObjectProperty ;
                                                       owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc86_addressed> ;
                                                       rdfs:domain <https://w3id.org/cpm-arch/cpm/CP33_Architecture_Conservation_Plan> ;
                                                       rdfs:range <https://w3id.org/cpm-arch/cpm/CP50_Urban_Conservation_Plan> ;
                                                       rdfs:label "was addressed by" ;
                                                       <http://www.w3.org/2004/02/skos/core#notation> "Pc86i" .


###  https://w3id.org/cpm-arch/cpm/Pc87_specified
<https://w3id.org/cpm-arch/cpm/Pc87_specified> rdf:type owl:ObjectProperty ;
                                               owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc87i_was_specified_by> ;
                                               rdfs:domain <https://w3id.org/cpm-arch/cpm/CP50_Urban_Conservation_Plan> ;
                                               rdfs:range <https://w3id.org/cpm-arch/cpm/CP49_Urban_Plan> ;
                                               rdfs:comment "This property allows to relate an instance of CP 50 Urban conservation Plan with an instance of CP49 Urban Plan addressing the hierarchy relationship existing between the urban planning and urban conservation planning. The first needs to be specified by the latter and leaves necessarily some open issues that are addressed to by conservation." ;
                                               rdfs:label "specified" ;
                                               <http://www.w3.org/2004/02/skos/core#notation> "Pc87" .


###  https://w3id.org/cpm-arch/cpm/Pc87i_was_specified_by
<https://w3id.org/cpm-arch/cpm/Pc87i_was_specified_by> rdf:type owl:ObjectProperty ;
                                                       rdfs:domain <https://w3id.org/cpm-arch/cpm/CP49_Urban_Plan> ;
                                                       rdfs:range <https://w3id.org/cpm-arch/cpm/CP50_Urban_Conservation_Plan> ;
                                                       rdfs:label "was specified by" ;
                                                       <http://www.w3.org/2004/02/skos/core#notation> "Pc87i" .


###  https://w3id.org/cpm-arch/cpm/Pc88_is_regulated_by
<https://w3id.org/cpm-arch/cpm/Pc88_is_regulated_by> rdf:type owl:ObjectProperty ;
                                                     owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc88i_regulates> ;
                                                     rdfs:domain <https://w3id.org/cpm-arch/cpm/CP16_Urban_Area> ;
                                                     rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E32_Authority_Document> ;
                                                     rdfs:comment "This property documents that an instance of CP16 Urban area is regulated by (regulates), from the legislative point of view, an instance of E32 Authority Document, in the sense that every intervention performed on the area must follow the prescriptions expressed in the document. The authority document may be a monumental constraint, an urban planning tool etc. There is no case of a urban area not being under legislative authority control." ;
                                                     rdfs:label "is regulated by" ;
                                                     <http://www.w3.org/2004/02/skos/core#notation> "Pc88" .


###  https://w3id.org/cpm-arch/cpm/Pc88_planned_the_conservation_of
<https://w3id.org/cpm-arch/cpm/Pc88_planned_the_conservation_of> rdf:type owl:ObjectProperty .


###  https://w3id.org/cpm-arch/cpm/Pc88i_regulates
<https://w3id.org/cpm-arch/cpm/Pc88i_regulates> rdf:type owl:ObjectProperty ;
                                                owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc88_planned_the_conservation_of> ;
                                                rdfs:domain <http://www.cidoc-crm.org/cidoc-crm/E32_Authority_Document> ;
                                                rdfs:range <https://w3id.org/cpm-arch/cpm/CP16_Urban_Area> ;
                                                rdfs:label "regulates" ;
                                                <http://www.w3.org/2004/02/skos/core#notation> "Pc88i" .


###  https://w3id.org/cpm-arch/cpm/Pc8_is_connected_to
<https://w3id.org/cpm-arch/cpm/Pc8_is_connected_to> rdf:type owl:ObjectProperty ;
                                                    rdfs:domain <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                    rdfs:range <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                    rdfs:comment "This property documents that an instance of CP1 Built Entity is connected to another instance of CP1 Built Entity. This circumstance is mainly referred to historical centres’ fabric." ;
                                                    rdfs:label "is_connected_to" ;
                                                    <http://www.w3.org/2004/02/skos/core#notation> "Pc8" .


###  https://w3id.org/cpm-arch/cpm/Pc9_belongs_to
<https://w3id.org/cpm-arch/cpm/Pc9_belongs_to> rdf:type owl:ObjectProperty ;
                                               owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc9i_owns> ;
                                               rdfs:domain <https://w3id.org/cpm-arch/cpm/CP18_Space_Entity> ;
                                               rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E39_Actor> ;
                                               rdfs:comment "This property documents that an instance CP18 Space Entity belongs to an instance of E39 Actor." ;
                                               rdfs:label "belongs to" ;
                                               <http://www.w3.org/2004/02/skos/core#notation> "Pc9" .


###  https://w3id.org/cpm-arch/cpm/Pc9i_owns
<https://w3id.org/cpm-arch/cpm/Pc9i_owns> rdf:type owl:ObjectProperty ;
                                          rdfs:domain <http://www.cidoc-crm.org/cidoc-crm/E39_Actor> ;
                                          rdfs:range <https://w3id.org/cpm-arch/cpm/CP18_Space_Entity> ;
                                          rdfs:label "owns" ;
                                          <http://www.w3.org/2004/02/skos/core#notation> "Pc9i" .


###  https://w3id.org/cpm-arch/cpm/myProperty
<https://w3id.org/cpm-arch/cpm/myProperty> rdf:type owl:ObjectProperty .


#################################################################
#    Classes
#################################################################

###  http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-made_Thing
<http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-made_Thing> rdf:type owl:Class .


###  http://www.cidoc-crm.org/cidoc-crm/E29_Design_orProcedures
<http://www.cidoc-crm.org/cidoc-crm/E29_Design_orProcedures> rdf:type owl:Class .


###  https://w3id.org/cpm-arch/cpm/CP10_Building_Unit
<https://w3id.org/cpm-arch/cpm/CP10_Building_Unit> rdf:type owl:Class ;
                                                   rdfs:subClassOf <https://w3id.org/cpm-arch/cpm/CP2_Architecture_Work> ;
                                                   rdfs:comment "This class includes instances of coherent architectural organisms populating an urban historical setting. It consists in a single construction phase or by the merging/recasting of several pre-existing building units. This kind of organism is characterized by the presence of one or more functional units (residential and non-residential) connected to each other through common distribution elements and served by access at the road level; it is bordered by external facades with a generally continuous eaves line and a unitary or composite roof composed of flat and/or inclined parts consistent with all fronts (Acierno, Fiorani, Velios 2021). Instances of CP10 Building Unit differ from instances of CP2 Architectural Work for being related to an edifice that is considered a component of an urban historical setting. Meaning that instances of CP10 Building Unit are buildings which are components of an urban tissue, where the main characteristics are the relationships established among them." ;
                                                   rdfs:label "Building Unit" ;
                                                   <http://www.w3.org/2004/02/skos/core#notation> "CP10" .


###  https://w3id.org/cpm-arch/cpm/CP11_Building_Front
<https://w3id.org/cpm-arch/cpm/CP11_Building_Front> rdf:type owl:Class ;
                                                    rdfs:subClassOf <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                    rdfs:comment "This class includes instances corresponding to the façades of single building unit overlooking on an urban space or, more generally, on a street or a square but also on the natural margin of the town (maritime, river, lake coast, promontory limit, etc.) (Acierno, Fiorani, Velios 2021)" ;
                                                    rdfs:label "Building Front" ;
                                                    <http://www.w3.org/2004/02/skos/core#notation> "CP11" .


###  https://w3id.org/cpm-arch/cpm/CP12_Building_Floor
<https://w3id.org/cpm-arch/cpm/CP12_Building_Floor> rdf:type owl:Class ;
                                                    rdfs:subClassOf <https://w3id.org/cpm-arch/cpm/CP2_Architecture_Work> ;
                                                    rdfs:comment "This class includes instances relating to a portion of a CP10 Building Unit between the floor and the ceiling. In residential buildings, instances of CP12 Building Floor normally correspond to the presence of one or more residential units, but in historic buildings, instances of CP12 Building Floor may include only part of a residential unit (such as for a row house, composed of overlapping rooms, or for a noble palace, which housed and may still house a family and its employees on all levels of the building). It is also not uncommon for historic residential buildings to combine a ground floor with commercial functions and residential upper floors or for different functions to overlap with each other. This is often the case in specialised buildings, where instances of CP12 Building Floor may also involve floor-to-ceiling portions with different organisational and functional characteristics (e.g. classrooms and staff offices in a school)." ;
                                                    rdfs:label "Building Floor" ;
                                                    <http://www.w3.org/2004/02/skos/core#notation> "CP12" .


###  https://w3id.org/cpm-arch/cpm/CP13_Urban_Unit
<https://w3id.org/cpm-arch/cpm/CP13_Urban_Unit> rdf:type owl:Class ;
                                                rdfs:subClassOf <https://w3id.org/cpm-arch/cpm/CP2_Architecture_Work> ;
                                                rdfs:comment """This class includes instances corresponding to a coherent architectural organism populating an urban historical setting. It consists in a single construction phase or by the merging/recasting of several pre-existing building units and can be described only in its exterior features. This organism is characterized by the presence of one or more functional units (residential and non-residential) connected to each other through common distribution elements and served by access at the road level; it is bordered by external facades with a generally continuous eaves line and a unitary or composite roof composed of flat and/or inclined parts consistent with all fronts. An urban unit can be constituted by a continuous set of structurally connected but distinguishable building units as organisms that are architecturally coherent populating an urban historical setting and may contain within it places relevant to one or more building units.  In this case, it overlooks on urban spaces through fronts that result from the succession of the individual facades of the building units. This specific type of urban unit is called ‘aggregate’. Alternatively, the urban unit can be a homogeneous and autonomous unitary element, bordered by urban spaces with whom it communicates through accesses to the ground floor and can contain open places inside. It overlooks urban spaces through a variable number of fronts generally figuratively and constructively coherent with each other. This another type is called 'residential or specialist punctual building unit' and consists in buildings such as villas or cottages (residential building) or complexes as hospitals or schools (specialist building) (Acierno, Fiorani, Velios 2021). Instances of CP13 Urban Unit differ from instances of CP2 Architectural Work for being related to an edifice that is considered a component of an urban historical setting. Meaning that instances of CP12 Urban Unit are building which are components of an urban tissue, where the main characteristic are the relationships established among them.
""" ;
                                                rdfs:label "Urban Unit" ;
                                                <http://www.w3.org/2004/02/skos/core#notation> "CP13" .


###  https://w3id.org/cpm-arch/cpm/CP14_Urban_Unit_Front
<https://w3id.org/cpm-arch/cpm/CP14_Urban_Unit_Front> rdf:type owl:Class ;
                                                      rdfs:subClassOf <https://w3id.org/cpm-arch/cpm/CP2_Architecture_Work> ;
                                                      rdfs:comment "This class includes instances corresponding to the set of facades on the same urban space – street or square – of the individual building units composing an urban unit." ;
                                                      rdfs:label "Urban Unit Front" ;
                                                      <http://www.w3.org/2004/02/skos/core#notation> "CP14" .


###  https://w3id.org/cpm-arch/cpm/CP15_Open_Air_Area
<https://w3id.org/cpm-arch/cpm/CP15_Open_Air_Area> rdf:type owl:Class ;
                                                   rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E19_Physical_Object> ;
                                                   rdfs:comment "This class includes instances relating to environments and landscapes resulting consistent for natural and anthropic features. Sometimes this consistency is evident from a perceptive viewpoint, sometimes this consistency is perceivable as homogeneity of constituent features. Instances of CP15 Open Air Area can be squares, streets or gardens of an urban centre, but also parks and open landscapes related to a historic architectures or urban centres. Such instances may have a particular cultural value or also constitute elements of local connotation of a specific urban landscape." ;
                                                   rdfs:label "Open Air Area" ;
                                                   <http://www.w3.org/2004/02/skos/core#notation> "CP15" .


###  https://w3id.org/cpm-arch/cpm/CP16_Urban_Area
<https://w3id.org/cpm-arch/cpm/CP16_Urban_Area> rdf:type owl:Class ;
                                                rdfs:subClassOf <https://w3id.org/cpm-arch/cpm/CP15_Open_Air_Area> ;
                                                rdfs:comment "This class includes instances relating to the hollows of historic urban settlements, bounded by the fronts related to the urban units facing them and containing pavements, furniture, and possibly public green elements. These instances constitute a unified whole from a perceptual and functional point of view and very often represent particularly connotative elements of historic centers." ;
                                                rdfs:label "Urban Area" ;
                                                <http://www.w3.org/2004/02/skos/core#notation> "CP16" .


###  https://w3id.org/cpm-arch/cpm/CP17_Cultural_Heritage_Landscape_Element
<https://w3id.org/cpm-arch/cpm/CP17_Cultural_Heritage_Landscape_Element> rdf:type owl:Class .


###  https://w3id.org/cpm-arch/cpm/CP17_Landscape_Element
<https://w3id.org/cpm-arch/cpm/CP17_Landscape_Element> rdf:type owl:Class ;
                                                       rdfs:subClassOf <https://w3id.org/cpm-arch/cpm/CP15_Open_Air_Area> ;
                                                       rdfs:comment "This class includes instances relating to environments resulting consistent for natural and anthropic features and having a special cultural value. Sometimes this consistency is evident from a perceptive viewpoint, sometimes this consistency is perceivable as homogeneity. Such instances may possess a special cultural value and be defined as outstanding universal value in Unesco list or may have been subject to spatial and landscape constraints by national conservation agencies or zoning regulations. However, instances of CP17 Cultural Heritage Landscape Element may also simply connote a recognized locally significant urban or rural landscape." ;
                                                       rdfs:label "Landscape Element" ;
                                                       <http://www.w3.org/2004/02/skos/core#notation> "CP17" .


###  https://w3id.org/cpm-arch/cpm/CP18_Space_Entity
<https://w3id.org/cpm-arch/cpm/CP18_Space_Entity> rdf:type owl:Class ;
                                                  owl:equivalentClass <https://w3id.org/cpm-arch/cpm/CR10_CdR_Space_Entity> ;
                                                  rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E92_Spacetime_Volume> ;
                                                  rdfs:comment "This class includes instances defined by sets of CP2 Architectural Work together with spaces related to architectural organisms, urban ensembles, or man-made landscapes. These instances represent 4D ensembles and can refer to the set that collects the constructed buildings and the empty spaces between them or to just the footprint of the empty spaces bounded by an urban physical perimeter or an architectural envelope. In either case, these instances are mutable over time, meaning that the shape and extent of the CP20 Spatial Entity can be changed over time and become precisely defined with the intersection of E53 Place and E52 Time-Span instances." ;
                                                  rdfs:label "Space Entity" ;
                                                  <http://www.w3.org/2004/02/skos/core#notation> "CP18" .


###  https://w3id.org/cpm-arch/cpm/CP19_Historic_Centre
<https://w3id.org/cpm-arch/cpm/CP19_Historic_Centre> rdf:type owl:Class ;
                                                     rdfs:subClassOf <https://w3id.org/cpm-arch/cpm/CP18_Space_Entity> ;
                                                     rdfs:comment "This class includes instances of urban agglomeration composed by the historical buildings and the open spaces which formerly constituted the town during all the time of its existence. These instances represent 4D ensembles and refer to the set that collects the constructed buildings and the empty spaces between them. These instances are mutable over time, meaning that the shape and extent of the CP19 Historic Centre can be changed over time and become precisely defined with the intersection of E53 Place and E52 Time-Span instances." ;
                                                     rdfs:label "Historic Centre" ;
                                                     <http://www.w3.org/2004/02/skos/core#notation> "CP19" .


###  https://w3id.org/cpm-arch/cpm/CP1_Built_Entity
<https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> rdf:type owl:Class ;
                                                 rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing> ;
                                                 rdfs:comment "This class comprises instances of man-made things such as freestanding buildings, construction units, construction components, construction elements, and complexes of buildings. It refers to man-made environments serving a practical purpose, being relatively permanent and stable. Instances of CP1 Built Entity consist of parts that perform a specific constructive or architectural function. Natural components, such as caves or rocky outcrops, even unworked ones, that are constructively and/or functionally integrated with existing architecture are also instances of CP1 Built Entity." ;
                                                 rdfs:label "Built Entity" ;
                                                 <http://www.w3.org/2004/02/skos/core#notation> "CP1" .


###  https://w3id.org/cpm-arch/cpm/CP20_Construction_Work
<https://w3id.org/cpm-arch/cpm/CP20_Construction_Work> rdf:type owl:Class ;
                                                       rdfs:subClassOf <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                       rdfs:comment "This class includes instances of the constructive apparatus that characterizes an architecture. Instances of CP20 Construction Work can gather building units, components and elements that have specific functions from a constructional point of view or that delimit and/or support the building or parts of it." ;
                                                       rdfs:label "Construction Work" ;
                                                       <http://www.w3.org/2004/02/skos/core#notation> "CP20" .


###  https://w3id.org/cpm-arch/cpm/CP21_Space_Unit
<https://w3id.org/cpm-arch/cpm/CP21_Space_Unit> rdf:type owl:Class ;
                                                rdfs:subClassOf <https://w3id.org/cpm-arch/cpm/CP18_Space_Entity> ;
                                                rdfs:comment "This class includes instances relating to the substance of the architectural or urban organism uniquely determinable on the basis of the characters of continuity and recognizability referred to the built (A-F Ingenio 2017). The instances of CP21 Space Unit are not physical objects but deals with the footprint of empty spaces defined by its changing physical presence over time, representing 4D ensembles." ;
                                                rdfs:label "Space Unit" ;
                                                <http://www.w3.org/2004/02/skos/core#notation> "CP21" .


###  https://w3id.org/cpm-arch/cpm/CP22_Space_Component
<https://w3id.org/cpm-arch/cpm/CP22_Space_Component> rdf:type owl:Class ;
                                                     rdfs:subClassOf <https://w3id.org/cpm-arch/cpm/CP18_Space_Entity> ;
                                                     rdfs:comment "This class includes instances relating to a part of the architectural organism endowed with a spatial identity that cannot be further subdivided. Instances of CP22 Space Component are identified by their specific characters of continuity and recognizability referring to the built (A-F Ingenio 2017). They do not involve physical objects, but the footprint of empty space defined by them, subject to change over time, and represent 4D ensembles." ;
                                                     rdfs:label "Space Component" ;
                                                     <http://www.w3.org/2004/02/skos/core#notation> "CP22" .


###  https://w3id.org/cpm-arch/cpm/CP23_Maintenance
<https://w3id.org/cpm-arch/cpm/CP23_Maintenance> rdf:type owl:Class ;
                                                 rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E11_Modification> ;
                                                 rdfs:comment "This class comprises instances of E11 Modification undertaken to maintain the form, structure, and construction apparatus of the CP2 Architectural Work. This activity occurs at periodic scheduled intervals or resulting from the detection of local malfunctions in the building system; it is aimed at extending the life of the existing building and may involve the replacement or addition of materials, elements and construction components, while still pursuing a conservative intent. Instances of CP23 Maintenance differ from instances of CP25 Conservation Intervention because of their specific character of repetitiveness and cyclicality and the low conceptual problematic nature of the operations to be performed. In fact, these are carried out using general protocols based on different issues that can be: 1) the expectation of effectiveness of a product (e.g., a stone surface protector); 2) the expectation of effectiveness of a building component (such as the drainage of an eave in a roof); 3) the expectation of effectiveness of a building technique (such as the roofing tile covering of a roof); 4) the potential harmfulness of a climatic event (rain, heavy wind, etc); 5) the expected consequences of a phenomenon (deposition of limestone contained in water, growth of nearby vegetation). These issues can be tackled without having to field special diagnostics and studies and the severity of the problem, as well as the material impact of the intervention are always limited. It follows that the maintenance plan, as a simple management protocol, can be formalised via the CIDOC CRM. This plan can in fact be instantiated using the class E29 Design or Procedure, related to an instance of CP23 Maintenance via the property P33 used specific technique (was used by), inherited from its superclass E7 Activity. " ;
                                                 rdfs:label "Maintenance" ;
                                                 <http://www.w3.org/2004/02/skos/core#notation> "CP23" .


###  https://w3id.org/cpm-arch/cpm/CP24_Architecture_Conservation_Project_Activity
<https://w3id.org/cpm-arch/cpm/CP24_Architecture_Conservation_Project_Activity> rdf:type owl:Class ;
                                                                                rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E7_Activity> ;
                                                                                rdfs:comment "This class comprises instances of E7 Activity intentionally carried out by instances of E39 Actor in order to develop a CP33 Conservation Project. The aim of this activity is to define technically the best choices for preserving, safeguarding, and using in a compatible way historic architectures, archaeological sites, hight value modern buildings developing the appropriate project tools. This activity has a multidisciplinary character and is oriented by the knowledge of the architecture to conserve." ;
                                                                                rdfs:label "Architecture Conservation Project Activity" ;
                                                                                <http://www.w3.org/2004/02/skos/core#notation> "CP24" .


###  https://w3id.org/cpm-arch/cpm/CP25_Conservation_Intervention
<https://w3id.org/cpm-arch/cpm/CP25_Conservation_Intervention> rdf:type owl:Class ;
                                                               rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E7_Activity> ;
                                                               rdfs:comment "This class comprises instances of E7 Activity produced to preserve historic architectures following the prescriptions of a CP24 Conservation Project Activity documented in CP33 Conservation Project.  as restoration project, protocols for planned conservation, maintenance plans, diagnostic plan." ;
                                                               rdfs:label "Conservation Intervention" ;
                                                               <http://www.w3.org/2004/02/skos/core#notation> "CP25" .


###  https://w3id.org/cpm-arch/cpm/CP26_Typological_Variation
<https://w3id.org/cpm-arch/cpm/CP26_Typological_Variation> rdf:type owl:Class .


###  https://w3id.org/cpm-arch/cpm/CP27_Architecture_Analysis_Output
<https://w3id.org/cpm-arch/cpm/CP27_Architecture_Analysis_Output> rdf:type owl:Class ;
                                                                  rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E13_Attribute_Assignment> ;
                                                                  rdfs:comment """This class comprises the actions of making assertions about one historical architecture or one or more of its components, also considering any single relation between various aspects concerning different architectures.  These assertions derive from the specialistic study of the historic architecture, concerning different aspects of the discipline.  For example, the class describes the actions of scholars and architects who make propositions and statements during some scientific procedures. These may be pertaining to the nature and layering of construction techniques present in the building, past units of measurement used to dimension spaces and structures, geometric proportioning criteria underlying the definition of spaces and structures, and lexical and linguistic references adopted as reference for formal choices. Possible instances of this class describe the results of the CP30 Architecture Condition Assessment or  the CP34 Architectural Feature Assessment.
""" ;
                                                                  rdfs:label "Architecture Analysis Output" ;
                                                                  <http://www.w3.org/2004/02/skos/core#notation> "CP27" .


###  https://w3id.org/cpm-arch/cpm/CP28_Building_Feature
<https://w3id.org/cpm-arch/cpm/CP28_Building_Feature> rdf:type owl:Class ;
                                                      rdfs:subClassOf <https://w3id.org/cpm-arch/cpm/CP27_Architecture_Analysis_Output> ;
                                                      rdfs:comment "This class comprises instances of CP2 Architectural Work related to the constitution of the building by a certain condition over a timespan. Among them, we have instances related to the masonry quality under different points of view, concerning the building characteristics, structural capacity, resistance to decay etc. Instances of CP28 Building Feature are also other characteristic, such as the presence and the nature of transverse connections, vertical inhomogeneities, connections between orthogonal walls and so on." ;
                                                      rdfs:label "Building Feature" ;
                                                      <http://www.w3.org/2004/02/skos/core#notation> "CP28" .


###  https://w3id.org/cpm-arch/cpm/CP29_Building_Phase
<https://w3id.org/cpm-arch/cpm/CP29_Building_Phase> rdf:type owl:Class ;
                                                    rdfs:subClassOf <https://w3id.org/cpm-arch/cpm/CP27_Architecture_Analysis_Output> ;
                                                    rdfs:comment "This class comprises instances of CP2 Architectural Work related to a unified construction process carried out over a defined period of time of a built presence. These instances, related to the restitution of the configuration of a historical building in a given historical period, are the product of in-depth knowledge of the building in its current state and inferential processes that can offer as objective indications as possible of the configuration of the building in a specific era." ;
                                                    rdfs:label "Building Phase" ;
                                                    <http://www.w3.org/2004/02/skos/core#notation> "CP29" .


###  https://w3id.org/cpm-arch/cpm/CP2_Architecture_Work
<https://w3id.org/cpm-arch/cpm/CP2_Architecture_Work> rdf:type owl:Class ;
                                                      rdfs:subClassOf <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                      rdfs:comment "This class comprises instances of Physical Human-Made Thing such as freestanding buildings and complexes of buildings, created for hosting or supporting every kind of human activities. Other instances can be urban or rural constructions realised to protect humans or to host different functions also with a symbolic meaning, as for triumphal arches and for funeral chapels. In addition, instances can be terminals of infrastructures, such as monumental fountains, as well as rooms created by excavating and modelling a rock for residential or religious purposes. CP2 Architectural Work may also comprise components of buildings when they maintain a recognisable formal identity, such as for a renaissance chapel built in a medieval basilica or a façade of a building, with its proper formal, constructive and material features. It refers to man-made environments, built for human needs, either practical, aesthetic or symbolic, being relatively permanent and stable and with a size and scale appropriate for - but not limited to - habitable buildings." ;
                                                      rdfs:label "Architecture work" ;
                                                      <http://www.w3.org/2004/02/skos/core#notation> "CP2" .


###  https://w3id.org/cpm-arch/cpm/CP30_Architecture_Condition_Assessment
<https://w3id.org/cpm-arch/cpm/CP30_Architecture_Condition_Assessment> rdf:type owl:Class ;
                                                                       rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E14_Condition_Assessment> ;
                                                                       rdfs:comment "This class comprises actions of making propositions or statements about architecture conditions based on hypothesis and any form or formal or informal logic. The aim of the CP30 Architecture Condition Assessment is the understanding of material decay and structural failure of CP2 Architectural Work and B1 Built Work." ;
                                                                       rdfs:label "Architecture Condition Assessment" ;
                                                                       <http://www.w3.org/2004/02/skos/core#notation> "CP30" .


###  https://w3id.org/cpm-arch/cpm/CP31_Mechanical_Damage_Assessment
<https://w3id.org/cpm-arch/cpm/CP31_Mechanical_Damage_Assessment> rdf:type owl:Class ;
                                                                  rdfs:subClassOf <https://w3id.org/cpm-arch/cpm/CP30_Architecture_Condition_Assessment> ;
                                                                  rdfs:comment "This class describes the act of assessing the mechanical damage of a structure during a particular period. The mechanical damage may be carried out by the observation (directly or using a sufficient number of photos) of the structural disruptions found on the building (cracks, deformation and so on) and/or through historical research. It indicates the assessment about the manner in which a building is deformed and/or damaged by kinematic stresses, with particular reference to seismic phenomena." ;
                                                                  rdfs:label "Mechanical Failure Assessment" ;
                                                                  <http://www.w3.org/2004/02/skos/core#notation> "CP31" .


###  https://w3id.org/cpm-arch/cpm/CP32_Architecture_Features_Analysis
<https://w3id.org/cpm-arch/cpm/CP32_Architecture_Features_Analysis> rdf:type owl:Class ;
                                                                    rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E7_Activity> ;
                                                                    rdfs:comment "This class comprises actions investigating instances of CP1 Built Entity, that can be determined by a systematic procedure. The aim of the CP32 Architectural Features Assessment is the understanding of constructive and formal features of CP2 Architectural Work and CP1 Built Entity. This class is used to document the building development, the technical, figurative and typological references of the architecture. " ;
                                                                    rdfs:label "Architecture Features Analysis" ;
                                                                    <http://www.w3.org/2004/02/skos/core#notation> "CP32" .


###  https://w3id.org/cpm-arch/cpm/CP32_Architecture_Features_Assessment
<https://w3id.org/cpm-arch/cpm/CP32_Architecture_Features_Assessment> rdf:type owl:Class .


###  https://w3id.org/cpm-arch/cpm/CP33_Architecture_Conservation_Plan
<https://w3id.org/cpm-arch/cpm/CP33_Architecture_Conservation_Plan> rdf:type owl:Class .


###  https://w3id.org/cpm-arch/cpm/CP33_Architecture_Conservation_Project
<https://w3id.org/cpm-arch/cpm/CP33_Architecture_Conservation_Project> rdf:type owl:Class ;
                                                                       rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E29_Design_or_Procedure> ;
                                                                       rdfs:comment "This class comprises documented plans for the executions of actions in order to achieve the preservation and compatible use or fruition of historic architectures, archaeological sites, hight-value modern buildings. These plans are depicted by drawings, protocols, and check list and they may result in new instances of CP38 Architecture Representation Object. They are used for shaping or guiding the execution of an instance of CP25 Conservation Intervention though the property Pc33 foresees (is foreseen by).  The existence of an instance of CP33 Architecture Conservation Project normally implies the intention of any actor to realize it, because it derives from the necessity to hinder any kind of conservation problems. CP33 Architecture Conservation Project is an architectural project dedicated to an existing building that is recognised as being of particular interest and value. For this reason, the role assumed by the study of the pre-existence takes on a particular importance, since the design choices of both conservative and creative nature are based on it. In fact, the main objective of the project is to preserve the material, historical and figurative values of the historic building, without sacrificing the building's formal and functional effectiveness. CP33 Architecture Conservation Project differs from ActE2 Activity Plan because of its specific nature that requires special technical tools also prescribed by law which must give information about the final state of the building and the specific techniques of intervention. An instance of an ActE2 Activity Plan, on the other hand, consists of a site implementation plan or a site safety plan, which regulate how the various restoration activities are to be conducted on site, also taking into account workers' clothing, as well as working times and methods." ;
                                                                       rdfs:label "Architecture Conservation Project" ;
                                                                       <http://www.w3.org/2004/02/skos/core#notation> "CP33" .


###  https://w3id.org/cpm-arch/cpm/CP33_Conservation_Project
<https://w3id.org/cpm-arch/cpm/CP33_Conservation_Project> rdf:type owl:Class .


###  https://w3id.org/cpm-arch/cpm/CP34_Architecture_Depiction
<https://w3id.org/cpm-arch/cpm/CP34_Architecture_Depiction> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E31_Document> ;
                                                            rdfs:comment "This class allows the study of architecture to be documented through a description in words, orthophotos, drawings, digital models retrieved from an architectural survey.  It represents the knowledge expressed through a physical document (E22 Human made object) such as a drawing or a report." ;
                                                            rdfs:label "Architecture Depiction" ;
                                                            <http://www.w3.org/2004/02/skos/core#notation> "CP34" .


###  https://w3id.org/cpm-arch/cpm/CP35_Building-Formal_Type
<https://w3id.org/cpm-arch/cpm/CP35_Building-Formal_Type> rdf:type owl:Class ;
                                                          rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E55_Type> ;
                                                          rdfs:comment "This class includes types that collect formal or constructive characteristics shared by structures, units, components, and elements of architecture. Instances of CP35 Building-formal Type may concern the figurative organization of facades (e.g., facades with overlapping orders, with giant order, with regular windows) or the construction characteristics of masonry (e.g., regular row wall in squared ashlars; rubble masonry; reticulated work). Each aspect of architecture that lends itself to being identified according to defined design or construction rules can be instantiated using CP35 Building-formal Type, according to its own typology of reference." ;
                                                          rdfs:label "Building-Formal Type" ;
                                                          <http://www.w3.org/2004/02/skos/core#notation> "CP35" .


###  https://w3id.org/cpm-arch/cpm/CP36_Architecture_Type
<https://w3id.org/cpm-arch/cpm/CP36_Architecture_Type> rdf:type owl:Class ;
                                                       rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E55_Type> ;
                                                       rdfs:comment "This class describes the presence of specific formal invariants related to the inherent organizational, functional and constructive aspects of the building. Instances of CP38 Architectural Type can concern form and relative distribution of spaces in architecture, the nature of which has been codified over time by architectural history. Instances of CP38 Architectural Type are the residential building types of townhouses, courtyard, in-line, etc., or the church types with three naves, central, Greek cross, etc." ;
                                                       rdfs:label "Architecture Type" ;
                                                       <http://www.w3.org/2004/02/skos/core#notation> "CP36" .


###  https://w3id.org/cpm-arch/cpm/CP37_Architecture_Graphic_Representation_Type
<https://w3id.org/cpm-arch/cpm/CP37_Architecture_Graphic_Representation_Type> rdf:type owl:Class ;
                                                                              rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E55_Type> ;
                                                                              rdfs:comment "This class is a specialization of E55 Type and comprises the concepts of architectural representation. Instances of Cp37 Architecture Graphic Representation can be orthophotos, 3D models, orthographic projections." ;
                                                                              rdfs:label "Architecture Graphic Representation Type" ;
                                                                              <http://www.w3.org/2004/02/skos/core#notation> "CP37" .


###  https://w3id.org/cpm-arch/cpm/CP38_Architecture_Conservation_Project
<https://w3id.org/cpm-arch/cpm/CP38_Architecture_Conservation_Project> rdf:type owl:Class .


###  https://w3id.org/cpm-arch/cpm/CP38_Architecture_Representation_Element
<https://w3id.org/cpm-arch/cpm/CP38_Architecture_Representation_Element> rdf:type owl:Class ;
                                                                         rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing> ;
                                                                         rdfs:comment "This class comprises discrete, identifiable human made items created with the purpose to represent every kind of CP1 Built Entity using graphic or alpha-numeric representation, regardless to the scale of representation (from the urban scale to the detailed one). Instances of Cp38 Architecture Representation Object can be printed drawings, handmade sketches on paper, maquettes, reports on paper, or even digital models or 2D representation, files with structural or economic calculation, etc." ;
                                                                         rdfs:label "Architecture Representation Object" ;
                                                                         <http://www.w3.org/2004/02/skos/core#notation> "CP38" .


###  https://w3id.org/cpm-arch/cpm/CP39_Architecture_Alpha-Numeric_Representation_Type
<https://w3id.org/cpm-arch/cpm/CP39_Architecture_Alpha-Numeric_Representation_Type> rdf:type owl:Class ;
                                                                                    rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E55_Type> ;
                                                                                    rdfs:comment "This class is a specialization of E55 Type and comprises the concepts of architecture that can be expressed by written and/or numerical elaboration. Instances of CP39 Architecture Alpha-Numeric Representation can be written reports, calculation reports, sheets and tables." ;
                                                                                    rdfs:label "Architecture Alpha-Numeric Representation Type" ;
                                                                                    <http://www.w3.org/2004/02/skos/core#notation> "CP39" .


###  https://w3id.org/cpm-arch/cpm/CP3_Construction_Unit
<https://w3id.org/cpm-arch/cpm/CP3_Construction_Unit> rdf:type owl:Class ;
                                                      rdfs:subClassOf <https://w3id.org/cpm-arch/cpm/CP20_Construction_Work> ;
                                                      rdfs:comment "This class includes instances of composite portions of a building that have specific functions from a constructional point of view or that delimit and/or support the building or parts of it.  Such instances may consist of the network of empty channels within the walls for smoke evacuation, the construction system of a wall (e.g., the two opposing faces and the intermediate core, any stone or plaster cladding), the construction system of a floor (e.g., consisting of main beams, secondary frames and wood planking, a layer of bedding mortar, and flooring)." ;
                                                      rdfs:label "Construction Unit" ;
                                                      <http://www.w3.org/2004/02/skos/core#notation> "CP3" .


###  https://w3id.org/cpm-arch/cpm/CP40_Historic_Centre
<https://w3id.org/cpm-arch/cpm/CP40_Historic_Centre> rdf:type owl:Class ;
                                                     rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing> ;
                                                     rdfs:comment "This class includes instances of urban agglomeration composed by the historical buildings and the open spaces which formerly constituted the town. The historic centre is delimited by a perimeter that can sometimes coincide with the boundary of the city walls when they still exist or when they can be identified on the basis of historical records, material evidence, or on natural limits (streams, strong slopes, etc.). The chronological limit before the World War 1 (1919) normally identifies a part - generally central - of the town, but the contemporary city can also include several historic districts that are in fact disjointed. This threshold can sometimes result from the evident constructive mutation of the building, verified by the comparison with the available cartographic and historical graphic documentation and direct feedback (Fiorani 2019; Geores 2021). In terms of CPM ontology, instances of CP40 Historic Centres are composed by instances of CP13 Urban Units and CP16 Urban Area." ;
                                                     rdfs:label "Historic Centre" ;
                                                     <http://www.w3.org/2004/02/skos/core#notation> "CP40" .


###  https://w3id.org/cpm-arch/cpm/CP41_Environmental_Observable_Entity
<https://w3id.org/cpm-arch/cpm/CP41_Environmental_Observable_Entity> rdf:type owl:Class ;
                                                                     rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E1_CRM_Entity> ;
                                                                     rdfs:comment "This class includes instances of E5 Event that can be observed by human sensory impression on a global scale. It describes different types of environmental phenomena related to a specific place and affecting the state of preservation of buildings located there.  Class CP41 Observable Environmental Entity describes qualitatively - referring to common categories developed by experts in the field - the most relevant environmental conditions of a site, especially in relation to weather and climate conditions" ;
                                                                     rdfs:label "Environmental Observable Entity" ;
                                                                     <http://www.w3.org/2004/02/skos/core#notation> "CP41" .


###  https://w3id.org/cpm-arch/cpm/CP42_Material_Decay
<https://w3id.org/cpm-arch/cpm/CP42_Material_Decay> rdf:type owl:Class ;
                                                    rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E5_Event> ;
                                                    rdfs:comment "This class comprises natural events or man-made processes that create, alter or change physical things, with special reference to building material, by affecting permanently their form or consistency without changing their identity. These phenomena are generally pathological in nature per se or potentially and affect the physical features of a B1 Built Entity or, more generally, of a E18 Physical Thing. Instances of CP42 Material Decay are specifically referred to the phenomenon of material deterioration as defined in the Italian UNI 11182/2006 or in the Illustrated Glossary on Stone Deterioration Patterns from Icomos and ISCS. They collect the effect of addition to the material (surface deposit, efflorescence, crust, biological coating), but also the situations derived from the loss of material (disintegration, detachment, exfoliation, lacuna) or, simply, the change of some original characteristic of the material, such as the color appearance or the formation of stains, due to deterioration mechanisms." ;
                                                    rdfs:label "Material Decay" ;
                                                    <http://www.w3.org/2004/02/skos/core#notation> "CP42" .


###  https://w3id.org/cpm-arch/cpm/CP43_Structural_Damage
<https://w3id.org/cpm-arch/cpm/CP43_Structural_Damage> rdf:type owl:Class ;
                                                       rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E5_Event> ;
                                                       rdfs:comment """CP43 Structural Damage cases refer specifically to phenomena that cause changes in the structural behaviour of a CP1 Built Entity. These changes are normally due to failure mechanisms that favour the partial or total loss of a building's resistance capacity. Induced failure mechanisms manifest themselves with specific recognisable effects on building structures.Instances of CP43 Structural Damage thus refer, among others, to the phenomena of cracking, crushing of materials, deformation or change in the original position of a building structure as a whole or a part thereof.
""" ;
                                                       rdfs:label "Structural Damage" ;
                                                       <http://www.w3.org/2004/02/skos/core#notation> "CP43" .


###  https://w3id.org/cpm-arch/cpm/CP44_Construction_Site
<https://w3id.org/cpm-arch/cpm/CP44_Construction_Site> rdf:type owl:Class ;
                                                       rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E27_Site> ;
                                                       rdfs:comment "This class includes pieces of land or see plan where a single building, a group of buildings, or a historic centre has been placed. The concept of a site is broader than the area exactly occupied by the single architecture and defines the main characters of this area and its surroundings; in the presence of a villa, the construction site gathers the area of the entire complex, both built and green. In contrast to the purely geometric notion of E53 Place, this class describes constellations of matter on the surface of the Earth containing buildings, which can be represented by photographs, paintings, and maps. Instances of CP44 Construction Site e are composed of relatively immobile material items and features with specific morphology and use and a proper geologic composition of the ground." ;
                                                       rdfs:label "Construction Site" ;
                                                       <http://www.w3.org/2004/02/skos/core#notation> "CP44" .


###  https://w3id.org/cpm-arch/cpm/CP45_Architecture_Project
<https://w3id.org/cpm-arch/cpm/CP45_Architecture_Project> rdf:type owl:Class ;
                                                          rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E29_Design_orProcedures> ;
                                                          rdfs:comment "This class comprises documented plans for the executions of actions to realise new architectures (in the present or in the past) or to radically transform existing buildings. These plans are depicted by drawings, reports, check list, bill of quantities, etc., and they may result in new instances of CP1 Built Entity or for shaping or guiding the execution of an instance of E7 Activity.Instances of CP45 Architectural Project can be related to the different kinds of the project of an architecture (concept plan, final project, executive project, execution variant, etc.). Architectural project can be also constituted by models, sketches, analytic description, in short, any kind of indication that may have been worked out for the purpose of on-site implementation of the building." ;
                                                          rdfs:label "Architecture Project" ;
                                                          <http://www.w3.org/2004/02/skos/core#notation> "CP45" .


###  https://w3id.org/cpm-arch/cpm/CP46_Building_Activity
<https://w3id.org/cpm-arch/cpm/CP46_Building_Activity> rdf:type owl:Class ;
                                                       rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E7_Activity> ;
                                                       rdfs:comment "This class comprises instances of E7 Activity produced to build a new architecture or to introduce new important transformation in it, normally documented in CP45 Architectural Project. Instances of CP45 Architectural Project can also deal with activities carried out without any real design when they are equally significant for the final architectural configuration" ;
                                                       rdfs:label "Building Activity" ;
                                                       <http://www.w3.org/2004/02/skos/core#notation> "CP46" .


###  https://w3id.org/cpm-arch/cpm/CP47_Decoration_Type
<https://w3id.org/cpm-arch/cpm/CP47_Decoration_Type> rdf:type owl:Class ;
                                                     rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E55_Type> ;
                                                     rdfs:comment "This class specifies the different types of decoration existing in a CP1 Built Entity. Instances of CP47 Decoration Type concern techniques used for decorating architectures, components or elements, such as painting techniques, sculptural treatments of stone or wood, etc" ;
                                                     rdfs:label "Building Activity" ;
                                                     <http://www.w3.org/2004/02/skos/core#notation> "CP47" .


###  https://w3id.org/cpm-arch/cpm/CP48_Equipment_Type
<https://w3id.org/cpm-arch/cpm/CP48_Equipment_Type> rdf:type owl:Class ;
                                                    rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E55_Type> ;
                                                    rdfs:comment "This class specifies the different types of CP8 Equipment. Instances of CP48 Equipment Type can refer to plumbing, electrical or heating system, etc" ;
                                                    rdfs:label "Equipment Type" ;
                                                    <http://www.w3.org/2004/02/skos/core#notation> "CP48" .


###  https://w3id.org/cpm-arch/cpm/CP49_Urban_Plan
<https://w3id.org/cpm-arch/cpm/CP49_Urban_Plan> rdf:type owl:Class ;
                                                rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E29_Design_or_Procedure> ;
                                                rdfs:comment "This class includes urban planning instruments aimed at planning the activities to be carried out on cities; these instruments design and regulate uses of space focused on the physical form, economic functions, and social impacts of the urban environment. Instances of CP49 Urban Plan are urban instruments that identify the architectural, functional and constructive characteristics of existing buildings and sites and envisage the operations to be carried out in terms of the provision of services and infrastructure, new construction, transformation of existing buildings They can also contain restrictive constraints on the actions to be taken on the existing building. These plans are depicted by drawings, reports, check list, and forms address new instances of CP5 Architecture Project. Instances of CP49 Urban Plan can also be related to plans that modify already existing plans" ;
                                                rdfs:label "Urban Plan" ;
                                                <http://www.w3.org/2004/02/skos/core#notation> "CP49" .


###  https://w3id.org/cpm-arch/cpm/CP4_Construction_Component
<https://w3id.org/cpm-arch/cpm/CP4_Construction_Component> rdf:type owl:Class ;
                                                           rdfs:subClassOf <https://w3id.org/cpm-arch/cpm/CP20_Construction_Work> ;
                                                           rdfs:comment "This class includes instances of a part of the building unit which is consistent from the structural or technological viewpoint. Such instances may consist of the structural component of a floor or of a vault, excluding finishings such as flooring and plastering, the construction part of a wall (e.g., the two opposing faces and the intermediate core), as well as the door and window shutters." ;
                                                           rdfs:label "Construction Component" ;
                                                           <http://www.w3.org/2004/02/skos/core#notation> "CP4" .


###  https://w3id.org/cpm-arch/cpm/CP50_Urban_Conservation_Plan
<https://w3id.org/cpm-arch/cpm/CP50_Urban_Conservation_Plan> rdf:type owl:Class ;
                                                             rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E29_Design_or_Procedure> ;
                                                             rdfs:comment "This class includes urban planning instruments aimed at planning the conservation activities to be carried out on historical architecture; these instruments design and regulate interventions focused on the physical form and the construction structure of the historical urban environment. Instances of CP50 Urban Conservation Plan are urban instruments that identify the architectural, functional and constructive characteristics of existing buildings and sites and envisage the operations to be carried out in terms conservation and restoration of of existing buildings They contain restrictive constraints on the actions to be taken on the existing building but also the guidelines to orient how to intervene on the historical façades (in terms of colours, materials and constructive solutions), to the inner part of the building (preserving their historical character but also using compatible solution to allow the introduction of modern equipment and services), to the open areas (orienting the choices about materials, techniques and furniture). These plans are depicted by drawings, reports, check list, and forms address new instances of CP33 Architecture Conservation Project. Instances of CP50 Urban Conservation Plan can also be related to plans that modify already existing plans" ;
                                                             rdfs:label "Urban Conservation Plan" ;
                                                             <http://www.w3.org/2004/02/skos/core#notation> "CP50" .


###  https://w3id.org/cpm-arch/cpm/CP51_Building_Component
<https://w3id.org/cpm-arch/cpm/CP51_Building_Component> rdf:type owl:Class ;
                                                        rdfs:subClassOf <https://w3id.org/cpm-arch/cpm/CP2_Architecture_Work> ;
                                                        rdfs:comment "This class includes instances relating to parts of the architectural organism that subtend spaces that cannot be further subdivided. The instances of CP51 Building Component are identified on the basis of their specific characters of continuity and recognisability ascribable to a given period of time. These characters refer both to the physical architectural and building components and to the space that is defined by them.  " ;
                                                        rdfs:label "Building Component" ;
                                                        <http://www.w3.org/2004/02/skos/core#notation> "CP51" .


###  https://w3id.org/cpm-arch/cpm/CP5_Construction_Element_Plural
<https://w3id.org/cpm-arch/cpm/CP5_Construction_Element_Plural> rdf:type owl:Class ;
                                                                rdfs:subClassOf <https://w3id.org/cpm-arch/cpm/CP20_Construction_Work> ;
                                                                rdfs:comment "This class includes instances of the constructive component characterised by a technical specificity. Such instances may consist of masonry faces, roofing systems covering the trusses in a wooden roof, coffering ceiling, the window frames, the plaster cladding a wall." ;
                                                                rdfs:label "Construction Element Plural" ;
                                                                <http://www.w3.org/2004/02/skos/core#notation> "CP5" .


###  https://w3id.org/cpm-arch/cpm/CP6_Construction_Element_Singular
<https://w3id.org/cpm-arch/cpm/CP6_Construction_Element_Singular> rdf:type owl:Class ;
                                                                  rdfs:subClassOf <https://w3id.org/cpm-arch/cpm/CP20_Construction_Work> ;
                                                                  rdfs:comment "This class includes instances of the constructive component characterised by a proper material specificity. Such instances may consist of masonry faces, roofing systems covering the trusses in a wooden roof, coffering ceiling, the window frames, the plaster cladding a wall." ;
                                                                  rdfs:label "Construction Element Singular" ;
                                                                  <http://www.w3.org/2004/02/skos/core#notation> "CP6" .


###  https://w3id.org/cpm-arch/cpm/CP7_Architecture_Decoration
<https://w3id.org/cpm-arch/cpm/CP7_Architecture_Decoration> rdf:type owl:Class ;
                                                            rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-made_Thing> ;
                                                            rdfs:comment "This class includes instances of decorative apparatus closely related to the composition of the architectural work. Such instances may consist of figurative paintings on the façades of a building or on the inner face of the walls in a church, as well as stuccoes, graffiti, ceramic cladding and sculptures attached to the walls of the building. Unlike instances of CP6 Constructive Element Singular, instances of CP7 Architectural Decoration do not usually play a specific role in the construction other than strictly decorative. This means that in the presence of a stone lintel carved in bas-relief, the lintel as a structural element must be considered as an instance of CP6 Constructive Element Singular, while its vertical surface with bas-relief can be instantiated as CP7 Architectural Decoration. Similarly, the metal key head should be instantiated as of CP6 Constructive Element Singular, while the cover stud should be instantiated as CP7 Architectural Decoration. When the constructive and decorative aspects are not separable (e.g. the decorated wrought iron balustrade of a balcony), the element may be instantiated as either CP6 Constructive Element Singular or CP7 Architectural Decoration." ;
                                                            rdfs:label "Architecture Decoration" ;
                                                            <http://www.w3.org/2004/02/skos/core#notation> "CP7" .


###  https://w3id.org/cpm-arch/cpm/CP8_Equipment
<https://w3id.org/cpm-arch/cpm/CP8_Equipment> rdf:type owl:Class ;
                                              rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-made_Thing> ;
                                              rdfs:comment "This class includes instances of plant systems pertaining a single architectural work. Such instances can have different nature, regarding the web and the terminals used for the distribution of water, electricity, heating or cooling etc. in a building." ;
