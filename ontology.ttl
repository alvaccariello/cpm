                                                                            rdfs:range <https://w3id.org/cpm-arch/cpm/CP6_Construction_Element_Singular> ;
                                                                            rdfs:comment "This property allows to relate an instance of CP5 Construction Element Plural with an instance of the class CP6 Construction Element Singular to describe their specific mereological relation. The property intends to make explicit the singular elements (CP6) that are constituting the construction element plural (CP5). As an example the plaster shows as single construction elements the different layers of mortar, or a masonry shows as single construction elements the stone ashlars." ;
                                                                            rdfs:label "shows as construction element singular" ;
                                                                            <http://www.w3.org/2004/02/skos/core#notation> "Pc69" .


