                                                       rdfs:label "was generated on" ;
                                                       <http://www.w3.org/2004/02/skos/core#notation> "Pc51i" .


###  https://w3id.org/cpm-arch/cpm/Pc52_was_assessed_by
<https://w3id.org/cpm-arch/cpm/Pc52_was_assessed_by> rdf:type owl:ObjectProperty ;
                                                     owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc52i_assessed> ;
                                                     rdfs:domain <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                     rdfs:range <https://w3id.org/cpm-arch/cpm/CP31_Mechanical_Damage_Assessment> ;
                                                     rdfs:comment "This property associates an instance of CP1 Built Entity with an instance of CP31 Mechanical damage assessment. The property intends to describe which structural evaluation process CP31 Mechanical damage assessment has involved a particular building or part of it." ;
                                                     rdfs:label "was assessed by" ;
                                                     <http://www.w3.org/2004/02/skos/core#notation> "Pc52" .


###  https://w3id.org/cpm-arch/cpm/Pc52i_assessed
<https://w3id.org/cpm-arch/cpm/Pc52i_assessed> rdf:type owl:ObjectProperty ;
                                               rdfs:domain <https://w3id.org/cpm-arch/cpm/CP31_Mechanical_Damage_Assessment> ;
                                               rdfs:range <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                               rdfs:label "assessed" ;
                                               <http://www.w3.org/2004/02/skos/core#notation> "Pc52i" .


###  https://w3id.org/cpm-arch/cpm/Pc53_has_modified
<https://w3id.org/cpm-arch/cpm/Pc53_has_modified> rdf:type owl:ObjectProperty ;
                                                  owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc53i_was_modified_by> ;
                                                  rdfs:domain <https://w3id.org/cpm-arch/cpm/CP45_Architecture_Project> ;
                                                  rdfs:range <https://w3id.org/cpm-arch/cpm/CP45_Architecture_Project> ;
                                                  rdfs:comment "This property allows to relate two different instances of Pc45 Architecture Project making it possible describe all the modifications that may occur during the constructive phases of an architectural project." ;
                                                  rdfs:label "has modified" ;
                                                  <http://www.w3.org/2004/02/skos/core#notation> "Pc53" .


###  https://w3id.org/cpm-arch/cpm/Pc53i_was_modified_by
<https://w3id.org/cpm-arch/cpm/Pc53i_was_modified_by> rdf:type owl:ObjectProperty ;
                                                      rdfs:domain <https://w3id.org/cpm-arch/cpm/CP45_Architecture_Project> ;
                                                      rdfs:range <https://w3id.org/cpm-arch/cpm/CP45_Architecture_Project> ;
                                                      rdfs:label "was modified by" ;
                                                      <http://www.w3.org/2004/02/skos/core#notation> "Pc53i" .


###  https://w3id.org/cpm-arch/cpm/Pc54_planned
<https://w3id.org/cpm-arch/cpm/Pc54_planned> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc54i_was_planned_by> ;
                                             rdfs:domain <https://w3id.org/cpm-arch/cpm/CP45_Architecture_Project> ;
                                             rdfs:range <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                             rdfs:comment "This property allows to relate a project to a building or a part of it. Such a description is generally needed within the documentation of an architecture when it is necessary to distinguish the phases of the transformation occurred and more specifically the origin of the particular parts." ;
                                             rdfs:label "planned" ;
                                             <http://www.w3.org/2004/02/skos/core#notation> "Pc54" .


###  https://w3id.org/cpm-arch/cpm/Pc54i_was_planned_by
<https://w3id.org/cpm-arch/cpm/Pc54i_was_planned_by> rdf:type owl:ObjectProperty ;
                                                     rdfs:domain <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
                                                     rdfs:range <https://w3id.org/cpm-arch/cpm/CP45_Architecture_Project> ;
                                                     rdfs:label "was planned by" ;
                                                     <http://www.w3.org/2004/02/skos/core#notation> "Pc54i" .


###  https://w3id.org/cpm-arch/cpm/Pc55_directed
<https://w3id.org/cpm-arch/cpm/Pc55_directed> rdf:type owl:ObjectProperty ;
                                              owl:inverseOf <https://w3id.org/cpm-arch/cpm/Pc55i_was_directed_by> ;
                                              rdfs:domain <https://w3id.org/cpm-arch/cpm/CP45_Architecture_Project> ;
                                              rdfs:range <https://w3id.org/cpm-arch/cpm/CP46_Building_Activity> ;
                                              rdfs:comment "This property associates an instance of CP45 Architecture Project to an instance of CP46 Building Activity to allow the description of the document the building activity is referring to. Actually, the architecture project involves many different activities, not only describing the design but also giving practical instructions to make the realisation of the building possible, such as the executive drawings or the planning of the yard." ;
                                              rdfs:label "directed" ;
                                              <http://www.w3.org/2004/02/skos/core#notation> "Pc55" .


###  https://w3id.org/cpm-arch/cpm/Pc55i_was_directed_by
<https://w3id.org/cpm-arch/cpm/Pc55i_was_directed_by> rdf:type owl:ObjectProperty ;
                                                      rdfs:domain <https://w3id.org/cpm-arch/cpm/CP46_Building_Activity> ;
                                                      rdfs:range <https://w3id.org/cpm-arch/cpm/CP45_Architecture_Project> ;
                                                      rdfs:label "was directed by" ;
                                                      <http://www.w3.org/2004/02/skos/core#notation> "Pc55i" .


###  https://w3id.org/cpm-arch/cpm/Pc56_was_realised_on
<https://w3id.org/cpm-arch/cpm/Pc56_was_realised_on> rdf:type owl:ObjectProperty ;
                                                     rdfs:domain <https://w3id.org/cpm-arch/cpm/CP46_Building_Activity> ;
                                                     rdfs:range <https://w3id.org/cpm-arch/cpm/CP1_Built_Entity> ;
